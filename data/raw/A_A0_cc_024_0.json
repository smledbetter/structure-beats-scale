    "code": "import sys\nfrom collections import defaultdict\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = []\n    b = []\n    cnt_a = defaultdict(int)\n    cnt_b = defaultdict(int)\n    for _ in range(n):\n        ai, bi = map(int, input().split())\n        a.append(ai)\n        b.append(bi)\n        cnt_a[ai] += 1\n        cnt_b[bi] += 1\n    \n    total = n * (n-1) * (n-2) // 6\n    \n    # bad: same topic pair AND same difficulty pair\n    # For each same-topic pair (i,j), count k != i,j with b[k]==b[i] or b[k]==b[j]\n    # Group by topic\n    topic_groups = defaultdict(list)\n    for i in range(n):\n        topic_groups[a[i]].append(i)\n    \n    bad = 0\n    for topic, indices in topic_groups.items():\n        m = len(indices)\n        if m < 2:\n            continue\n        for i in range(len(indices)):\n            for j in range(i+1, len(indices)):\n                pi, pj = indices[i], indices[j]\n                cnt = (cnt_b[b[pi]] - 1) + (cnt_b[b[pj]] - 1)\n                bad += cnt\n    # Each bad triple with exactly one same-topic pair counted once. Good.\n    # Bad triple with 3 same topic: counted 3 times. Need to subtract 2* those.\n    for topic, indices in topic_groups.items():\n        m = len(indices)\n        if m >= 3:\n            bad -= 2 * (m * (m-1) * (m-2) // 6)\n    \n    print(total - bad)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
