      "final_code": "def solve():\n    s = input().strip()\n    n = len(s)\n    has_X = 'X' in s\n    x_range = range(10) if has_X else [None]\n    \n    count = 0\n    \n    endings = ['00', '25', '50', '75'] if n >= 2 else ['0']\n    \n    for xv in x_range:\n        # Apply X substitution\n        t = list(s)\n        if xv is not None:\n            for i in range(n):\n                if t[i] == 'X':\n                    t[i] = str(xv)\n        \n        for ending in endings:\n            # Check if ending is compatible with last len(ending) chars of t\n            end_len = len(ending)\n            suffix = t[n - end_len:]\n            \n            compatible = True\n            for i in range(end_len):\n                if suffix[i] != '_' and suffix[i] != ending[i]:\n                    compatible = False\n                    break\n            \n            if not compatible:\n                continue\n            \n            # Count ways to fill remaining blanks\n            # Positions not in suffix\n            prefix = t[:n - end_len]\n            \n            # Count blanks in prefix\n            prefix_blanks = sum(1 for c in prefix for _ in [1] if c == '_')\n            \n            ways = 10 ** prefix_blanks\n            \n            # Handle leading zero constraint\n            if n > 1:\n                # First character must not be '0'\n                first = prefix[0] if prefix else suffix[0]\n                \n                if prefix:\n                    if first == '0':\n                        # All assignments lead to leading zero\n                        ways = 0\n                    elif first == '_':\n                        # One of the 10 choices (0) is invalid\n                        ways = ways // 10 * 9\n                    # else first is nonzero digit, all fine\n                else:\n                    # prefix is empty, first char is in suffix\n                    if ending[0] == '0':\n                        ways = 0\n                    # else it's fine\n            \n            count += ways\n    \n    print(count)\n\nsolve()",
