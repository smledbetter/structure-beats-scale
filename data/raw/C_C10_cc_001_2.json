      "final_code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    n = int(input_data[0])\n    A = list(map(int, input_data[1:n+1]))\n    \n    A_tuple = tuple(A)\n    \n    @lru_cache(maxsize=None)\n    def can_win(l, r, last):\n        # Returns True if current player can win\n        if l > r:\n            return False  # no moves available, current player loses\n        \n        can_left = A_tuple[l] > last\n        can_right = A_tuple[r] > last\n        \n        if not can_left and not can_right:\n            return False  # current player can't move, loses\n        \n        # Current player wins if there exists a move that makes opponent lose\n        if can_left:\n            if not can_win(l + 1, r, A_tuple[l]):\n                return True\n        if can_right:\n            if not can_win(l, r - 1, A_tuple[r]):\n                return True\n        \n        return False\n    \n    if can_win(0, n - 1, -1):\n        print(\"Alice\")\n    else:\n        print(\"Bob\")\n\nsolve()",
