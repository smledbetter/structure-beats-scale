      "final_code": "from collections import deque\n\ndef solve():\n    x, y = map(int, input().split())\n    \n    MAX_VAL = 2 * 10**18 + 10\n    \n    visited = set()\n    queue = deque([x])\n    visited.add(x)\n    \n    while queue:\n        cur = queue.popleft()\n        if cur == y:\n            print(\"YES\")\n            return\n        b = bin(cur)[2:]\n        for bit in ['0', '1']:\n            nb = b + bit\n            nb_rev = nb[::-1].lstrip('0') or '0'\n            nval = int(nb_rev, 2)\n            if nval == y:\n                print(\"YES\")\n                return\n            if nval not in visited and nval <= MAX_VAL:\n                visited.add(nval)\n                queue.append(nval)\n    \n    print(\"NO\")\n\nsolve()",
