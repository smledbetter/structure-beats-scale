    "code": "import sys\nfrom itertools import product\n\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    x = list(map(int, input().split()))\n    s = []\n    for _ in range(n):\n        s.append(input().strip())\n    \n    w = []\n    for j in range(m):\n        col = [int(s[i][j]) for i in range(n)]\n        w.append(col)\n    \n    best_val = -1\n    best_p = None\n    \n    for mask in range(1 << n):\n        sigma = [1 if (mask >> i) & 1 else -1 for i in range(n)]\n        weights = []\n        for j in range(m):\n            wj = sum(sigma[i] * w[j][i] for i in range(n))\n            weights.append((wj, j))\n        weights.sort()\n        p = [0] * m\n        for rank, (wj, j) in enumerate(weights):\n            p[j] = rank + 1\n        r = [0] * n\n        for j in range(m):\n            for i in range(n):\n                r[i] += p[j] * w[j][i]\n        val = sum(abs(x[i] - r[i]) for i in range(n))\n        if val > best_val:\n            best_val = val\n            best_p = p[:]\n    \n    print(*best_p)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
