    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    x = list(map(int, input().split()))\n    s = []\n    for _ in range(n):\n        s.append(input().strip())\n    \n    # w[j] = list of s[i][j] for each student i\n    w = []\n    for j in range(m):\n        col = tuple(int(s[i][j]) for i in range(n))\n        w.append(col)\n    \n    best_val = -1\n    best_p = None\n    \n    for mask in range(1 << n):\n        sigma = [1 if (mask >> i) & 1 else -1 for i in range(n)]\n        \n        # Compute weight for each question j\n        # To minimize sum(sigma_i * r_i), assign smallest ranks to largest weights\n        # Sort descending by weight, assign rank 1 to largest weight\n        weights = []\n        for j in range(m):\n            wj = sum(sigma[i] * w[j][i] for i in range(n))\n            weights.append((wj, j))\n        \n        # Sort descending: largest weight gets rank 1 (smallest point value)\n        weights.sort(reverse=True)\n        p = [0] * m\n        for rank, (wj, j) in enumerate(weights):\n            p[j] = rank + 1\n        \n        # Compute r[i] for each student\n        r = [0] * n\n        for j in range(m):\n            pj = p[j]\n            col = w[j]\n            for i in range(n):\n                r[i] += pj * col[i]\n        \n        val = sum(abs(x[i] - r[i]) for i in range(n))\n        if val > best_val:\n            best_val = val\n            best_p = p[:]\n    \n    print(*best_p)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
