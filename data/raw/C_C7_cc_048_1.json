 d in S:\n            if pos == 0 and d == 0 and L > 1:\n                continue\n            if d < lo:\n                continue\n            digits.append(d)\n            new_tight = (d == lo) and tight\n            if not new_tight:\n                for i in range(pos+1, L):\n                    digits.append(S[0])\n                return True\n            if greedy(pos+1, new_tight):\n                return True\n            digits.pop()\n        return False\n    \n    if greedy(0, True):\n        return int(''.join(map(str, digits)))\n    else:\n        return find_min_length(L + 1)\n\nresults = []\nfor _ in range(t):\n    n = int(input_data[idx]); idx += 1\n    k = int(input_data[idx]); idx += 2\n    \n    best = None\n    all_digits = list(range(10))\n    for size in range(1, k+1):\n        for combo in combinations(all_digits, size):\n            val = min_with_digits(n, list(combo))\n            if val is not None and (best is None or val < best):\n                best = val\n    results.append(best)\n\nprint('\\n'.join(map(str, results)))",
