  "fix": {
    "model": "claude-sonnet-4-6",
    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve(n, m):\n    if n > m:\n        return 0\n    \n    # Find minimum v = n^x for x > m\n    # Try each \"branching point\": highest bit where x diverges above m\n    best = float('inf')\n    \n    # For each bit i, consider x where:\n    # - bits above i: x matches m\n    # - bit i: x has 1, m has 0 (so x > m guaranteed for upper bits)\n    # - bits below i: x = n (to minimize XOR, giving 0s in those positions)\n    \n    for i in range(30, -1, -1):\n        # Check if bit i of m is 0 (so we can set it to 1 in x)\n        if not (m >> i & 1):\n            # x upper bits (above i) match m, bit i is 1, lower bits = n\n            # upper bits of x = upper bits of m\n            upper = m & ~((1 << (i+1)) - 1)\n            x = upper | (1 << i) | (n & ((1 << i) - 1))\n            # x > m? upper bits same, bit i: x has 1, m has 0 => yes\n            if x > m:\n                v = n ^ x\n                if v < best:\n                    best = v\n    \n    # Also try x = m+1 directly\n    x = m + 1\n    v = n ^ x\n    if v < best:\n        best = v\n    \n    return best\n\nt = int(input())\nfor _ in range(t):\n    n, m = map(int, input().split())\n    print(solve(n, m))",
