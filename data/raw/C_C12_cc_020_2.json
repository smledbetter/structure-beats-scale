      "final_code": "import sys\nfrom math import gcd\ninput = sys.stdin.readline\n\ndef solve():\n    n, d = map(int, input().split())\n    a = list(map(int, input().split()))\n    \n    if not any(a):\n        print(0)\n        return\n    \n    cycle_len = n // gcd(n, d)\n    run = [0] * n\n    \n    # For each position, compute run length going in -d direction\n    # We need to detect cycles\n    # Process in topological order... but it's a cycle structure\n    # Each node i points to (i - d) % n (predecessor)\n    # We need run[i] = 1 + run[(i-d)%n] if a[i]==1, else 0\n    # But cycles exist! If all in cycle are 1, it's infinite.\n    \n    # Use the fact that cycles have length cycle_len\n    # Do multiple passes or detect\n    \n    for i in range(n):\n        if a[i] == 0:\n            run[i] = 0\n    \n    # iterate enough times\n    for _ in range(cycle_len + 1):\n        new_run = [0] * n\n        for i in range(n):\n            if a[i] == 1:\n                prev = (i - d) % n\n                new_run[i] = run[prev] + 1\n        run = new_run\n    \n    # If any run[i] > cycle_len, it means infinite\n    if any(r > cycle_len for r in run):\n        print(-1)\n    else:\n        print(max(run))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
