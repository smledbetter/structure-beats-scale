    "code": "import sys\nfrom collections import Counter\n\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    a.sort()\n    \n    ans = []\n    cost = 0\n    ptr = 0  # pointer into sorted array\n    # For MEX = i, we need 0..i-1 covered, and i not present\n    \n    cnt = Counter(a)\n    \n    # Process incrementally\n    # cost_cover: cost to cover 0..i-1 using greedy on sorted array\n    cost_cover = 0\n    used_ptr = 0  # how many elements of sorted array used to cover 0..i-1\n    \n    for i in range(n + 1):\n        # Currently covered 0..i-1, now need to handle value i not being present\n        # Count elements equal to i that are NOT used\n        # Elements used: first `used_ptr` elements of sorted array\n        # Remaining elements equal to i: cnt[i] but some may be in used portion\n        # Actually used elements are a[0..used_ptr-1], all <= i-1 (since we only use <= v for each v)\n        # So remaining elements equal to i = cnt[i]\n        extra = cnt[i]\n        ans.append(cost_cover + extra)\n        \n        # Now prepare for i+1: need to cover value i\n        # Find next element <= i in sorted array starting from used_ptr\n        if used_ptr < n and a[used_ptr] <= i:\n            cost_cover += i - a[used_ptr]\n            used_ptr += 1\n        else:\n            # Can't cover i, so MEX = i+1, i+2, ... all impossible\n            for j in range(i + 1, n + 1):\n                ans.append(-1)\n            break\n    \n    print(*ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
