      "final_code": "t = int(input())\nfor _ in range(t):\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    best = float('inf')\n    \n    for c1 in range(3):\n        for c2 in range(3):\n            # Check if (c1, c2) can handle all remainders, find min c3\n            feasible = True\n            max_c3 = 0\n            for x in a:\n                r = x % 3\n                # Try all ways to use c1 ones and c2 twos to cover remainder\n                min_c3_needed = float('inf')\n                for use1 in range(c1 + 1):\n                    for use2 in range(c2 + 1):\n                        remainder = x - use1 - 2 * use2\n                        if remainder < 0:\n                            continue\n                        if remainder % 3 == 0:\n                            min_c3_needed = min(min_c3_needed, remainder // 3)\n                if min_c3_needed == float('inf'):\n                    feasible = False\n                    break\n                max_c3 = max(max_c3, min_c3_needed)\n            \n            if feasible:\n                total = c1 + c2 + max_c3\n                best = min(best, total)\n    \n    print(best)",
