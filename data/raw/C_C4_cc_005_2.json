          "code": "def solve():\n    s = input().strip()\n    n = len(s)\n    \n    has_X = 'X' in s\n    x_range = range(10) if has_X else [None]\n    \n    endings = ['00', '25', '50', '75']\n    \n    count = 0\n    \n    for xv in x_range:\n        # Replace X with xv\n        t = list(s)\n        if xv is not None:\n            for i in range(n):\n                if t[i] == 'X':\n                    t[i] = str(xv)\n        \n        if n == 1:\n            # Only divisible by 25 if it's 0\n            c = t[0]\n            if c == '0':\n                count += 1\n            elif c == '_':\n                count += 1  # only '0' works, no leading zero issue for single digit 0\n            continue\n        \n        # Try each valid ending\n        for end in endings:\n            d1, d2 = end[0], end[1]\n            # Check last two positions\n            pos1, pos2 = n-2, n-1\n            c1, c2 = t[pos1], t[pos2]\n            \n            if c1 != '_' and c1 != d1:\n                continue\n            if c2 != '_' and c2 != d2:\n                continue\n            \n            # Now count ways to fill remaining positions (0 to n-3)\n            # Each '_' has 10 choices, except position 0 can't be '0'\n            # But if n==2, there are no remaining positions\n            \n            # Count free blanks in positions 0..n-3\n            free_blanks = 0\n            first_pos_is_blank = False\n            first_pos_fixed = None\n            \n            ways = 1\n            for i in range(n-2):\n                c = t[i]\n                if c == '_':\n                    ways *= 10\n                    if i == 0:\n                        first_pos_is_blank = True\n            \n            # Subtract cases where first digit is 0 (leading zero)\n            # leading zero: first digit is 0\n            if n == 2:\n                # first digit is position 0, which is d1\n                if d1 == '0':\n                    continue  # leading zero (unless... but n>=2 so skip)\n            else:\n                # positions 0..n-3 are \"free\" except constrained by t\n                first = t[0]\n                if first == '_':\n                    # ways counted 10 for first position, subtract 1 for '0'\n                    ways -= ways // 10  # subtract cases where first is 0\n                    # ways = ways - ways/10 = 9 * (ways/10)\n                elif first == '0':\n                    continue  # leading zero\n            \n            count += ways\n    \n    print(count)\n\nsolve()",
