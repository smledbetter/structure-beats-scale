    "code": "import sys\nfrom bisect import bisect_right\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n, m, k = int(input_data[idx]), int(input_data[idx+1]), int(input_data[idx+2]); idx += 3\n        x_list = []\n        for i in range(n):\n            x_list.append(int(input_data[idx])); idx += 1\n        y_list = []\n        for i in range(m):\n            y_list.append(int(input_data[idx])); idx += 1\n        \n        xs = set(x_list)\n        ys = set(y_list)\n        \n        # For vertical-only persons: key = horizontal strip index\n        # For horizontal-only persons: key = vertical strip index\n        # Cell = (v_strip, h_strip)\n        \n        cell_vert = {}   # cell -> count of vertical-only persons in that cell\n        cell_horiz = {}  # cell -> count of horizontal-only persons in that cell\n        \n        for p in range(k):\n            xp, yp = int(input_data[idx]), int(input_data[idx+1]); idx += 2\n            on_v = xp in xs\n            on_h = yp in ys\n            \n            if on_v and not on_h:\n                # vertical-only: find horizontal strip of yp\n                h_strip = bisect_right(y_list, yp) - 1\n                v_strip = x_list.index(xp) if False else bisect_right(x_list, xp) - 1\n                cell = (v_strip, h_strip)\n                cell_vert[cell] = cell_vert.get(cell, 0) + 1\n            elif on_h and not on_v:\n                # horizontal-only: find vertical strip of xp\n                v_strip = bisect_right(x_list, xp) - 1\n                h_strip = y_list.index(yp) if False else bisect_right(y_list, yp) - 1\n                cell = (v_strip, h_strip)\n                cell_horiz[cell] = cell_horiz.get(cell, 0) + 1\n            # intersection persons: convenient with everyone (path = Manhattan)\n        \n        ans = 0\n        for cell, vc in cell_vert.items():\n            hc = cell_horiz.get(cell, 0)\n            ans += vc * hc\n        \n        print(ans)\n\nsolve()",
