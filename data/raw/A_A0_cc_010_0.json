    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import deque\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx+=1\n    for _ in range(t):\n        n,m = int(input_data[idx]),int(input_data[idx+1]); idx+=2\n        grid = []\n        lab = None\n        for i in range(n):\n            row = input_data[idx].decode(); idx+=1\n            grid.append(list(row))\n            for j,c in enumerate(row):\n                if c=='L': lab=(i,j)\n        dirs=[(-1,0),(1,0),(0,-1),(0,1)]\n        free_nbr=[[0]*m for _ in range(n)]\n        bad_count=[[0]*m for _ in range(n)]\n        good=[[False]*m for _ in range(n)]\n        for i in range(n):\n            for j in range(m):\n                if grid[i][j]!='#':\n                    for di,dj in dirs:\n                        ni,nj=i+di,j+dj\n                        if 0<=ni<n and 0<=nj<m and grid[ni][nj]!='#':\n                            free_nbr[i][j]+=1\n                            bad_count[i][j]+=1\n        q=deque()\n        li,lj=lab\n        good[li][lj]=True\n        q.append((li,lj))\n        while q:\n            i,j=q.popleft()\n            for di,dj in dirs:\n                ni,nj=i+di,j+dj\n                if 0<=ni<n and 0<=nj<m and grid[ni][nj]!='#' and not good[ni][nj]:\n                    bad_count[ni][nj]-=1\n                    good_nbrs=free_nbr[ni][nj]-bad_count[ni][nj]\n                    if bad_count[ni][nj]<=1 and good_nbrs>=1:\n                        good[ni][nj]=True\n                        q.append((ni,nj))\n        out=[]\n        for i in range(n):\n            for j in range(m):\n                if grid[i][j]=='.' and good[i][j]:\n                    grid[i][j]='+'\n            out.append(''.join(grid[i]))\n        print('\\n'.join(out))\n\nsolve()",
