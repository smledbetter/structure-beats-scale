    "code": "import sys\nfrom collections import defaultdict\nimport bisect\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    n = int(input_data[0])\n    a = list(map(int, input_data[1:n+1]))\n    \n    # For each value, store sorted list of positions (1-indexed)\n    positions = defaultdict(list)\n    for i in range(1, n+1):\n        v = a[i-1]\n        positions[v].append(i)\n    \n    # Greedy: try to extend chain with values 1, 2, 3, ...\n    last_pos = 0\n    count = 0\n    \n    for v in range(1, n+1):\n        if v not in positions:\n            continue\n        pos_list = positions[v]\n        # Find smallest position > last_pos\n        idx = bisect.bisect_right(pos_list, last_pos)\n        if idx < len(pos_list):\n            last_pos = pos_list[idx]\n            count += 1\n        # If not found, we can't include value v, but we might still include v+1, v+2...\n        # Wait - no! If we can't place value v at position v in the new sequence,\n        # we can't have any fixed point with new index > v either... \n        # Actually we CAN skip value v and try v+1 for position v+1? No.\n        # The values must be exactly 1,2,...,k consecutively.\n        # If we can't find value v after last_pos, we must stop.\n        else:\n            break\n    \n    print(count)\n\nsolve()",
