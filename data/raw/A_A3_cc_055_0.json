    "model": "claude-sonnet-4-6",
    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve(n, m):\n    if n > m:\n        return 0\n    L = m + 1\n    # Find minimum v >= 0 such that v ^ n >= L\n    # Try branching at each bit position i (from high to low)\n    # where L's bit i is 0: we can set v^n bit i = 1 (making it exceed L at this bit)\n    # For upper bits, v^n must equal L's upper bits\n    # meaning v's upper bits = L's upper bits ^ n's upper bits\n    # Then at bit i: v bit = 1 ^ n_bit (to get v^n bit = 1 > 0 = L bit)\n    # Lower bits of v: set to 0 to minimize v\n    \n    bits = 30\n    best = float('inf')\n    \n    for i in range(bits, -1, -1):\n        bit_L = (L >> i) & 1\n        if bit_L == 0:\n            # Upper bits of v must satisfy v^n = L for bits above i\n            upper_mask = ~((1 << (i+1)) - 1)\n            upper_v = (L ^ n) & upper_mask  # upper bits of v\n            # At bit i: v^n bit = 1, so v bit = 1 ^ n_bit_i\n            bit_n = (n >> i) & 1\n            v_bit_i = 1 ^ bit_n\n            v_candidate = upper_v | (v_bit_i << i)\n            # lower bits = 0\n            if v_candidate >= 0:\n                best = min(best, v_candidate)\n    \n    # Also check v = L^n (v^n = L exactly)\n    v_exact = L ^ n\n    if v_exact ^ n >= L:\n        best = min(best, v_exact)\n    \n    return best\n\nt = int(input())\nfor _ in range(t):\n    n, m = map(int, input().split())\n    print(solve(n, m))",
