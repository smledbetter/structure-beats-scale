      "code": "from math import comb\nfrom fractions import Fraction\n\ndef solve():\n    line = input().split()\n    N = int(line[0])\n    P_str = line[1]\n    \n    # Convert P to fraction\n    if '.' in P_str:\n        decimals = len(P_str.split('.')[1])\n        denom = 10**decimals\n        numer = int(P_str.replace('.', ''))\n        P_frac = Fraction(numer, denom)\n    else:\n        P_frac = Fraction(int(P_str), 1)\n    \n    total = comb(N, 3)\n    \n    for k in range(0, N+1):\n        # compute probability\n        prob = Fraction(0)\n        for s in range(0, 4):\n            if s > k or (3-s) > (N-k):\n                continue\n            ways = comb(k, s) * comb(N-k, 3-s)\n            if s == 1:\n                contrib = Fraction(ways, total) * Fraction(1, 3)\n            elif s == 2:\n                contrib = Fraction(ways, total) * Fraction(2, 3)\n            elif s == 3:\n                contrib = Fraction(ways, total) * Fraction(1, 1)\n            else:\n                contrib = Fraction(0)\n            prob += contrib\n        \n        if prob >= P_frac:\n            print(k)\n            return\n\nsolve()",
