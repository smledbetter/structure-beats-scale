    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import deque\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    grid = []\n    lab_r, lab_c = 0, 0\n    for i in range(n):\n        row = list(input().strip())\n        grid.append(row)\n        for j in range(len(row)):\n            if row[j] == 'L':\n                lab_r, lab_c = i, j\n\n    # A cell is \"forceable\" if the robot can be forced to reach the lab from it.\n    # Key insight: a free cell is forceable if the number of free neighbors minus 1 <= 0\n    # i.e., it has at most 1 free neighbor (degree <= 1), OR all its neighbors except one are forceable.\n    # More precisely: a cell can be forced if (number of free neighbors) - (number of forceable neighbors) <= 1\n    # Because we can always \"block\" one direction by commanding it, so the robot must choose from remaining.\n    # If remaining free non-forceable neighbors = 0, robot has no choice but to go to a forceable cell or lab.\n    \n    # The condition: cell is forceable if free_neighbors - forceable_neighbors <= 1\n    # (the robot can be commanded to go in any direction, it picks a different one;\n    #  if at most 1 free neighbor is not forceable, we can command that direction and robot must go elsewhere)\n    \n    # Actually the correct condition:\n    # A cell u is forceable if: (number of free neighbors of u) - (number of forceable neighbors of u) <= 1\n    # Because if we send command = direction of the one non-forceable neighbor (or any blocked direction),\n    # then robot must choose from the other free neighbors, all of which are forceable.\n    \n    # BFS/topological approach: start with lab (forceable), then propagate.\n    \n    dirs = [(-1,0),(1,0),(0,-1),(0,1)]\n    \n    # Count free neighbors for each cell\n    free_deg = [[0]*m for _ in range(n)]\n    for r in range(n):\n        for c in range(m):\n            if grid[r][c] == '#':\n                continue\n            cnt = 0\n            for dr, dc in dirs:\n                nr, nc = r+dr, c+dc\n                if 0 <= nr < n and 0 <= nc < m and grid[nr][nc] != '#':\n                    cnt += 1\n            free_deg[r][c] = cnt\n    \n    forceable = [[False]*m for _ in range(n)]\n    # forceable_count[r][c] = number of forceable neighbors\n    forceable_count = [[0]*m for _ in range(n)]\n    \n    queue = deque()\n    # Lab is forceable\n    forceable[lab_r][lab_c] = True\n    queue.append((lab_r, lab_c))\n    \n    while queue:\n        r, c = queue.popleft()\n        # Update neighbors\n        for dr, dc in dirs:\n            nr, nc = r+dr, c+dc\n            if 0 <= nr < n and 0 <= nc < m and grid[nr][nc] != '#':\n                if not forceable[nr][nc]:\n                    forceable_count[nr][nc] += 1\n                    # Check if (nr, nc) becomes forceable\n                    if free_deg[nr][nc] - forceable_count[nr][nc] <= 1:\n                        forceable[nr][nc] = True\n                        queue.append((nr, nc))\n    \n    # Build output\n    result = []\n    for r in range(n):\n        row = grid[r]\n        line = []\n        for c in range(m):\n            if row[c] == '#':\n                line.append('#')\n            elif row[c] == 'L':\n                line.append('L')\n            elif forceable[r][c]:\n                line.append('+')\n            else:\n                line.append('.')\n        result.append(''.join(line))\n    print('\\n'.join(result))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
