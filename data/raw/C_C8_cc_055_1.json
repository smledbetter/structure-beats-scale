      "final_code": "import sys\ninput = sys.stdin.readline\n\ndef solve(n, m):\n    if n > m:\n        return 0\n    \n    # Find minimum v = x^n where x > m\n    # Equivalently, find x > m minimizing x^n\n    # \n    # Try: for each prefix of (m+1), force a bit to be higher, then freely choose rest\n    \n    target = m + 1\n    best = float('inf')\n    \n    # Consider x where x agrees with target on bits [31..i+1], has bit i set higher than target,\n    # then bits [i-1..0] chosen freely to minimize x^n\n    \n    # First candidate: x = target itself\n    best = min(best, target ^ n)\n    \n    # For each bit position i, if we can \"branch off\" at bit i:\n    # x has same bits as target for positions > i, bit i is 1 while target's bit i is 0\n    # then lower bits chosen to equal n (minimizing xor)\n    \n    for i in range(30, -1, -1):\n        if not (target >> i & 1):\n            # target has 0 at bit i; we set x to have 1 at bit i\n            # prefix above bit i same as target\n            prefix = (target >> (i+1)) << (i+1)\n            x = prefix | (1 << i)\n            # set lower bits to match n\n            lower_mask = (1 << i) - 1\n            x = x | (n & lower_mask)\n            if x > m:\n                best = min(best, x ^ n)\n    \n    return best\n\nt = int(input())\nfor _ in range(t):\n    n, m = map(int, input().split())\n    print(solve(n, m))",
