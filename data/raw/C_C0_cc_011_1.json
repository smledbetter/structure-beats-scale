      "code": "from collections import deque\n\ndef solve():\n    x, y = map(int, input().split())\n    \n    if x == y:\n        print(\"YES\")\n        return\n    \n    visited = set()\n    queue = deque([x])\n    visited.add(x)\n    \n    while queue:\n        curr = queue.popleft()\n        \n        bin_curr = bin(curr)[2:]\n        \n        for bit in ['0', '1']:\n            new_bin = bin_curr + bit\n            reversed_bin = new_bin[::-1].lstrip('0')\n            if not reversed_bin:\n                reversed_bin = '0'\n            new_val = int(reversed_bin, 2)\n            \n            if new_val == y:\n                print(\"YES\")\n                return\n            \n            if new_val not in visited:\n                # Pruning: if new_val > some threshold, skip\n                # x, y <= 10^18, binary length <= 63\n                # After operation, length increases by 1 or stays same (if leading zero removed)\n                # We should limit search\n                if new_val <= 2 * 10**18:\n                    visited.add(new_val)\n                    queue.append(new_val)\n    \n    print(\"NO\")\n\nsolve()",
