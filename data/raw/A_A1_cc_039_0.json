    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    s = input().strip()\n    \n    dx, dy = 0, 0\n    min_dx, max_dx = 0, 0\n    min_dy, max_dy = 0, 0\n    \n    best_k = 0\n    best_min_dx, best_min_dy = 0, 0\n    \n    for cmd in s:\n        if cmd == 'U': dx -= 1\n        elif cmd == 'D': dx += 1\n        elif cmd == 'L': dy -= 1\n        elif cmd == 'R': dy += 1\n        \n        min_dx = min(min_dx, dx)\n        max_dx = max(max_dx, dx)\n        min_dy = min(min_dy, dy)\n        max_dy = max(max_dy, dy)\n        \n        if max_dx - min_dx <= n - 1 and max_dy - min_dy <= m - 1:\n            best_k += 1  # not really needed\n            best_min_dx = min_dx\n            best_min_dy = min_dy\n        else:\n            break\n    \n    r = 1 - best_min_dx\n    c = 1 - best_min_dy\n    r = max(1, min(n, r))\n    c = max(1, min(m, c))\n    print(r, c)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
