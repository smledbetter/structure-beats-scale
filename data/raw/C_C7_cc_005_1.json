      "final_code": "from itertools import product\n\ndef solve():\n    s = input().strip()\n    n = len(s)\n    \n    valid_endings = ['00', '25', '50', '75']\n    \n    count = 0\n    seen = set()\n    \n    for x_val in range(10):\n        # Build template with X replaced\n        template = []\n        for c in s:\n            if c == 'X':\n                template.append(str(x_val))\n            else:\n                template.append(c)\n        \n        # Now template has digits 0-9 and '_'\n        # Enumerate only positions that are '_'\n        blank_positions = [i for i, c in enumerate(template) if c == '_']\n        \n        # For efficiency, separate last 2 positions from rest\n        # With n<=8 and blanks<=8, but we use seen set to avoid duplicates\n        # Max distinct templates: 10 * 10^(blanks) but seen handles X dedup\n        \n        for blank_combo in product(range(10), repeat=len(blank_positions)):\n            digits = list(template)\n            for i, pos in enumerate(blank_positions):\n                digits[pos] = str(blank_combo[i])\n            \n            key = tuple(digits)\n            if key in seen:\n                continue\n            seen.add(key)\n            \n            # Check leading zero\n            if len(digits) > 1 and digits[0] == '0':\n                continue\n            \n            # Check divisible by 25\n            if n == 1:\n                if digits[0] == '0':\n                    count += 1\n            else:\n                last_two = digits[-2] + digits[-1]\n                if last_two in valid_endings:\n                    count += 1\n    \n    print(count)\n\nsolve()",
