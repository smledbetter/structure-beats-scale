    "code": "from itertools import product\n\ndef solve():\n    s = input().strip()\n    n = len(s)\n    \n    count = 0\n    \n    has_x = 'X' in s\n    x_range = range(10) if has_x else [None]\n    \n    for x_val in x_range:\n        # Replace X with x_val\n        if x_val is not None:\n            t = [str(x_val) if c == 'X' else c for c in s]\n        else:\n            t = list(s)\n        \n        # Find positions of '_'\n        blank_positions = [i for i, c in enumerate(t) if c == '_']\n        \n        for vals in product(range(10), repeat=len(blank_positions)):\n            u = t[:]\n            for pos, val in zip(blank_positions, vals):\n                u[pos] = str(val)\n            \n            # Check leading zeros\n            if n > 1 and u[0] == '0':\n                continue\n            \n            # Check divisibility by 25\n            num = int(''.join(u))\n            if num % 25 == 0:\n                count += 1\n    \n    print(count)\n\nsolve()",
