      "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    s = input().strip()\n    \n    # For rows: track cumulative vertical position\n    # For columns: track cumulative horizontal position\n    # We want to find starting position (r, c) such that max prefix steps are valid\n    \n    # Compute prefix sums for row and column movements\n    # row: D = +1, U = -1\n    # col: R = +1, L = -1\n    \n    # For rows:\n    # At each step k, position = r + row_prefix[k]\n    # Need 1 <= r + row_prefix[k] <= n for all k from 0..best_steps\n    # i.e., 1 - row_prefix[k] <= r <= n - row_prefix[k]\n    # So r must be in [max(1 - row_prefix[k]), min(n - row_prefix[k])]\n    # = [1 - min(row_prefix), n - max(row_prefix)]\n    \n    # Similarly for columns\n    \n    # We want to find the maximum prefix length where both row and col constraints are satisfiable\n    \n    # Precompute prefix sums\n    row_prefix = [0] * (len(s) + 1)\n    col_prefix = [0] * (len(s) + 1)\n    \n    for i, c in enumerate(s):\n        row_prefix[i+1] = row_prefix[i]\n        col_prefix[i+1] = col_prefix[i]\n        if c == 'D':\n            row_prefix[i+1] += 1\n        elif c == 'U':\n            row_prefix[i+1] -= 1\n        elif c == 'R':\n            col_prefix[i+1] += 1\n        elif c == 'L':\n            col_prefix[i+1] -= 1\n    \n    # For each prefix length k (0..len(s)), check if valid\n    # We want maximum k such that:\n    # 1 - min(row_prefix[0..k]) >= 1 and n - max(row_prefix[0..k]) >= 1\n    # i.e., min_row = min(row_prefix[0..k]), max_row = max(row_prefix[0..k])\n    # r_low = 1 - min_row, r_high = n - max_row\n    # r_low <= r_high means n - max_row >= 1 - min_row => n >= max_row - min_row + 1\n    # Similarly for columns\n    \n    # Compute running min/max\n    min_row = 0\n    max_row = 0\n    min_col = 0\n    max_col = 0\n    \n    best_k = 0\n    best_r_low = 1\n    best_c_low = 1\n    \n    for k in range(1, len(s) + 1):\