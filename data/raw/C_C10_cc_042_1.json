          "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = input().strip()\n    b = input().strip()\n    \n    if a == b:\n        print(0)\n        return\n    \n    comp_a = ''.join('1' if c=='0' else '0' for c in a)\n    \n    ones_a = sum(1 for c in a if c=='1')\n    ones_b = sum(1 for c in b if c=='1')\n    \n    # odd ops: need ones_b + ones_a - 1 == n-1, i.e. ones_a + ones_b = n... \n    # After odd op selecting pos i (a[i]=1): result has (n-1-ones_a+1) + ... \n    # ones in result = (n - ones_a) + 1 - (1 if a[i]=1 else 0)... \n    # = n - ones_a + 1 - 1 = n - ones_a (since a[i]=1)\n    # So ones_b must equal n - ones_a for odd ops\n    # For even ops: ones_b must equal ones_a\n    \n    ans = float('inf')\n    \n    if ones_b == n - ones_a:\n        # odd number of ops possible\n        # min odd ops: need to count how many positions where b[i]=1 but comp_a[i]=0 (a[i]=1)\n        # those positions need to be \"selected\" to stay as 1\n        # number of such positions = count where a[i]=1 and b[i]=1\n        k = sum(1 for i in range(n) if a[i]=='1' and b[i]=='1')\n        if k == 0:\n            # need at least 1 op but no position to select that stays 1... \n            # actually if k=0, we can't do it in odd ops directly\n            pass\n        else:\n            ans = min(ans, 2*k - 1)\n    \n    if ones_b == ones_a:\n        # even number of ops possible\n        # positions where b[i]=1 and a[i]=0: need to be \"fixed\" by selecting them\n        k = sum(1 for i in range(n) if a[i]=='0' and b[i]=='1')\n        ans = min(ans, 2*k)\n    \n    if ans == float('inf'):\n        print(-1)\n    else:\n        print(ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
