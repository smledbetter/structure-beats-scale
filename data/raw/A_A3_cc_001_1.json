    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom functools import lru_cache\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    # prev is always a[l-1], a[r+1], or -1 (start)\n    # encode: 0 = start (-inf), 1 = prev is a[l-1], 2 = prev is a[r+1]\n    @lru_cache(maxsize=None)\n    def dp(l, r, side):\n        # side: 0=initial(prev=-1), 1=prev=a[l-1], 2=prev=a[r+1]\n        if side == 0:\n            prev = -1\n        elif side == 1:\n            prev = a[l-1]\n        else:\n            prev = a[r+1]\n        \n        if l > r:\n            return False\n        \n        moves = []\n        if a[l] > prev:\n            if l == r:\n                moves.append(not dp(l+1, r, 1))\n            else:\n                moves.append(not dp(l+1, r, 1))\n        if l < r and a[r] > prev:\n            moves.append(not dp(l, r-1, 2))\n        elif l == r and a[r] > prev and side != 0:\n            pass  # already handled\n            \n        if not moves:\n            return False\n        return any(moves)\n    \n    if dp(0, n-1, 0):\n        print(\"Alice\")\n    else:\n        print(\"Bob\")\n\nsolve()",
