      "final_code": "import sys\nfrom array import array\n\ndef solve():\n    input_data = sys.stdin.readline().split()\n    n, m = int(input_data[0]), int(input_data[1])\n    \n    dp = array('l', [0] * (n + 2))\n    diff = array('l', [0] * (n + 2))\n    dp[1] = 1\n    S = 0  # prefix sum of dp[1..x-1]\n    \n    for x in range(2, n + 1):\n        # dp[x] = S[x-1] + div_contrib[x]\n        dp[x] = (S + diff[x]) % m\n        # update diff for future using dp[x]\n        j = x\n        z = 2\n        while j * z <= n:\n            lo = j * z\n            hi = min(lo + z - 1, n)  # (j+1)*z - 1 = j*z + z - 1\n            diff[lo] = (diff[lo] + dp[x]) % m\n            if hi + 1 <= n + 1:\n                diff[hi + 1] = (diff[hi + 1] - dp[x]) % m\n            z += 1\n        S = (S + dp[x]) % m\n        diff[x+1] = (diff[x+1] + diff[x]) % m  # propagate diff\n    \n    print(dp[n] % m)\n\nsolve()",
