      "code": "import sys\nfrom math import isqrt\n\ndef solve():\n    input_data = sys.stdin.readline().split()\n    n, m = int(input_data[0]), int(input_data[1])\n    \n    dp = [0] * (n + 1)\n    dp[1] = 1\n    S = [0] * (n + 2)\n    S[1] = 1\n    \n    for x in range(2, n + 1):\n        val = S[x-1]  # subtraction part\n        # division part\n        v = 1\n        while v <= x // 2:\n            q = x // v\n            # z ranges: floor(x/z) = v means z in [x//(v+1)+1, x//v]\n            # but z >= 2\n            z_max = x // v\n            z_min = x // (v + 1) + 1\n            z_min = max(z_min, 2)\n            if z_min <= z_max:\n                val = (val + dp[v] * (z_max - z_min + 1)) % m\n            v = x // (x // v) + 1  # skip to next distinct floor value... wait this iterates over z not v\n        \n        dp[x] = val % m\n        S[x] = (S[x-1] + dp[x]) % m\n    \n    print(dp[n])\n\nsolve()",
