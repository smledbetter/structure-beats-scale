  "fix": {
    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import deque\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    grid = []\n    lab_r, lab_c = 0, 0\n    for i in range(n):\n        row = list(input().strip())\n        grid.append(row)\n        for j in range(len(row)):\n            if row[j] == 'L':\n                lab_r, lab_c = i, j\n\n    # A cell is \"forceable\" if we can guarantee the robot reaches the lab.\n    # Key insight: a free cell is forceable if the number of free neighbors <= 1\n    # (degree <= 1 in the free-cell graph), because then no matter what command\n    # we send, the robot has at most 1 other direction to go (or none).\n    # We do a BFS starting from the lab, expanding cells whose free-neighbor count\n    # (among non-forceable cells) drops to <= 1.\n    \n    # Count free neighbors for each cell\n    dirs = [(0,1),(0,-1),(1,0),(-1,0)]\n    \n    free_neighbors = [[0]*m for _ in range(n)]\n    \n    for r in range(n):\n        for c in range(m):\n            if grid[r][c] == '#':\n                continue\n            cnt = 0\n            for dr, dc in dirs:\n                nr, nc = r+dr, c+dc\n                if 0 <= nr < n and 0 <= nc < m and grid[nr][nc] != '#':\n                    cnt += 1\n            free_neighbors[r][c] = cnt\n    \n    # BFS: a cell can be forced if it has at most 1 free neighbor\n    # When we mark a cell as forceable, we decrement neighbors' free_neighbor counts\n    # and if they drop to <=1, add them to queue\n    \n    forceable = [[False]*m for _ in range(n)]\n    queue = deque()\n    \n    # Start with lab\n    forceable[lab_r][lab_c] = True\n    queue.append((lab_r, lab_c))\n    \n    # Also add any free cell with free_neighbors <= 1\n    for r in range(n):\n        for c in range(m):\n            if grid[r][c] != '#' and not forceable[r][c] and free_neighbors[r][c] <= 1:\n                forceable[r][c] = True\n                queue.append((r, c))\n    \n    while queue:\n        r, c = queue.popleft()\n        for dr, dc in dirs:\n            nr, nc = r+dr, c+dc\n            if 0 <= nr < n and 0 <= nc < m and grid[nr][nc] != '#' and not forceable[nr][nc]:\n                free_neighbors[nr][nc] -= 1\n                if free_neighbors[nr][nc] <= 1:\n                    forceable[nr][nc] = True\n                    queue.append((nr, nc))\n    \n    # Build output\n    result = []\n    for r in range(n):\n        row = grid[r]\n        new_row = []\n        for c in range(m):\n            if row[c] == '.' and forceable[r][c]:\n                new_row.append('+')\n            else:\n                new_row.append(row[c])\n        result.append(''.join(new_row))\n    \n    print('\\n'.join(result))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
