      "code": "from collections import deque\n\ndef int_to_bin(n):\n    return bin(n)[2:]\n\ndef solve():\n    x, y = map(int, input().split())\n    visited = set()\n    q = deque()\n    q.append(x)\n    visited.add(x)\n    \n    while q:\n        current = q.popleft()\n        if current == y:\n            print(\"YES\")\n            return\n        # Generate next possible numbers\n        s = int_to_bin(current)\n        # Add 0 and reverse\n        s1 = s + '0'\n        s1_rev = s1[::-1].lstrip('0')\n        if not s1_rev:\n            continue\n        num1 = int(s1_rev, 2)\n        if num1 == y:\n            print(\"YES\")\n            return\n        if num1 not in visited and num1 <= 1e18:\n            visited.add(num1)\n            q.append(num1)\n        # Add 1 and reverse\n        s2 = s + '1'\n        s2_rev = s2[::-1].lstrip('0')\n        if not s2_rev:\n            continue\n        num2 = int(s2_rev, 2)\n        if num2 == y:\n            print(\"YES\")\n            return\n        if num2 not in visited and num2 <= 1e18:\n            visited.add(num2)\n            q.append(num2)\n    print(\"NO\")\n\nsolve()",
