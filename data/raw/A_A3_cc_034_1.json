    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import defaultdict\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        a = list(map(int, input_data[idx:idx+n])); idx += n\n        \n        # State: (left_slack, right_slack)\n        # left_slack = current_pos - lo, right_slack = hi - current_pos\n        # Initially pos=0, lo=0, hi=0 => left_slack=0, right_slack=0\n        # dp[left_slack] = min right_slack\n        \n        dp = defaultdict(lambda: float('inf'))\n        dp[0] = 0\n        \n        for d in a:\n            new_dp = defaultdict(lambda: float('inf'))\n            for ls, rs in dp.items():\n                if rs == float('inf'):\n                    continue\n                # Go right: new_ls = ls + d, new_rs = max(rs - d, 0)\n                new_ls = ls + d\n                new_rs = max(rs - d, 0)\n                if new_rs < new_dp[new_ls]:\n                    new_dp[new_ls] = new_rs\n                # Go left: new_ls = max(ls - d, 0), new_rs = rs + d\n                new_ls2 = max(ls - d, 0)\n                new_rs2 = rs + d\n                if new_rs2 < new_dp[new_ls2]:\n                    new_dp[new_ls2] = new_rs2\n            dp = new_dp\n        \n        ans = min(ls + rs for ls, rs in dp.items() if rs != float('inf'))\n        print(ans)\n\nsolve()",
