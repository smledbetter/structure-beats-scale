    "code": "import sys\nfrom sys import stdin\n\ndef solve():\n    input_data = stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx+=1\n    \n    for _ in range(t):\n        n, m = int(input_data[idx]), int(input_data[idx+1]); idx+=2\n        edges = []\n        for i in range(n-1):\n            x,y,v = int(input_data[idx]),int(input_data[idx+1]),int(input_data[idx+2]); idx+=3\n            edges.append((x,y,v))\n        queries = []\n        for i in range(m):\n            a,b,p = int(input_data[idx]),int(input_data[idx+1]),int(input_data[idx+2]); idx+=3\n            queries.append((a,b,p))\n        \n        parent = list(range(n+1))\n        rank = [0]*(n+1)\n        parity = [0]*(n+1)  # parity from node to parent\n        \n        def find(x):\n            if parent[x] == x:\n                return x, 0\n            root, p = find(parent[x])\n            parity[x] ^= parity[parent[x]]\n            parent[x] = root\n            return root, parity[x]\n        \n        def union(x, y, p):  # constraint: par[x] XOR par[y] = p\n            rx, px = find(x)\n            ry, py = find(y)\n            if rx == ry:\n                return (px ^ py) == p\n            if rank[rx] < rank[ry]:\n                rx, ry = ry, rx\n                px, py = py, px\n            parent[ry] = rx\n            parity[ry] = px ^ py ^ p\n            if rank[rx] == rank[ry]:\n                rank[rx] += 1\n            return True\n        \n        ok = True\n        for x,y,v in edges:\n            if v != -1:\n                p = bin(v).count('1') % 2\n                if not union(x, y, p):\n                    ok = False\n        \n        for a,b,p in queries:\n            if not union(a, b, p):\n                ok = False\n        \n        if not ok:\n            print(\"NO\")\n        else:\n            print(\"YES\")\n            for x,y,v in edges:\n                if v == -1:\n                    rx, px = find(x)\n                    ry, py = find(y)\