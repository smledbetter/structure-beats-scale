      "code": "from collections import deque\n\ndef solve():\n    x, y = map(int, input().split())\n    \n    if x == y:\n        print(\"YES\")\n        return\n    \n    visited = set()\n    queue = deque([x])\n    visited.add(x)\n    \n    while queue:\n        curr = queue.popleft()\n        \n        # Try adding 0 or 1\n        bin_str = bin(curr)[2:]  # without '0b'\n        \n        for bit in ['0', '1']:\n            new_bin = bin_str + bit\n            # Reverse it\n            rev_bin = new_bin[::-1]\n            # Remove leading zeros\n            rev_bin = rev_bin.lstrip('0')\n            if not rev_bin:\n                rev_bin = '0'\n            new_val = int(rev_bin, 2)\n            \n            if new_val == y:\n                print(\"YES\")\n                return\n            \n            if new_val not in visited:\n                # Pruning: if new_val > some threshold, skip\n                # The number of bits can only grow by 1 each step if we add 1\n                # But if we add 0, the leading bit after reverse might reduce bits\n                # We need a bound. x, y <= 10^18 < 2^60\n                # After operation, if we add 1, bits increase by 1\n                # The binary length of y is at most 60\n                # So we shouldn't go beyond ~64 bits or so\n                if new_val.bit_length() <= 63:\n                    visited.add(new_val)\n                    queue.append(new_val)\n    \n    print(\"NO\")\n\nsolve()",
