    "code": "from collections import deque\n\ndef solve():\n    x, y = map(int, input().split())\n    \n    if x == y:\n        print(\"YES\")\n        return\n    \n    visited = set()\n    visited.add(x)\n    queue = deque([x])\n    \n    limit = 2 * 10**18  # upper bound\n    \n    while queue:\n        curr = queue.popleft()\n        \n        # Generate next states\n        b = bin(curr)[2:]  # binary without '0b'\n        \n        for bit in ['0', '1']:\n            new_b = b + bit\n            # reverse\n            rev_b = new_b[::-1]\n            # remove leading zeros\n            rev_b = rev_b.lstrip('0')\n            if not rev_b:\n                next_val = 0\n            else:\n                next_val = int(rev_b, 2)\n            \n            if next_val == y:\n                print(\"YES\")\n                return\n            \n            if next_val > 0 and next_val <= limit and next_val not in visited:\n                visited.add(next_val)\n                queue.append(next_val)\n    \n    print(\"NO\")\n\nsolve()",
