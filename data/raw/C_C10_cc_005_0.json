          "code": "def solve():\n    s = input().strip()\n    n = len(s)\n    \n    has_x = 'X' in s\n    x_range = range(10) if has_x else [-1]\n    \n    count = 0\n    \n    for x_val in x_range:\n        # Build template with X replaced\n        t = []\n        for c in s:\n            if c == 'X':\n                t.append(str(x_val))\n            else:\n                t.append(c)\n        \n        # t[i] is either a digit char or '_'\n        # Enumerate all possibilities for last 2 positions (or 1 if n==1)\n        # For each valid ending, count free assignments for the rest\n        \n        if n == 1:\n            endings = [(i,) for i in range(10)]\n        else:\n            endings = [(i, j) for i in range(10) for j in range(10)]\n        \n        for ending in endings:\n            # Try assigning ending to last positions\n            u = t[:]\n            if n == 1:\n                last_digits = ending[0]\n                pos = [n-1]\n            else:\n                last_digits = ending[0] * 10 + ending[1]\n                pos = [n-2, n-1]\n            \n            # Check if assignment is consistent with template\n            valid = True\n            for k, p in enumerate(pos):\n                if u[p] != '_' and u[p] != str(ending[k]):\n                    valid = False\n                    break\n            \n            if not valid:\n                continue\n            \n            if last_digits % 25 != 0:\n                continue\n            \n            # Place ending digits\n            for k, p in enumerate(pos):\n                u[p] = str(ending[k])\n            \n            # Count free blanks in remaining positions\n            free_count = sum(1 for i in range(n) if i not in pos and u[i] == '_')\n            \n            # Total combinations for free blanks\n            total = 10 ** free_count\n            \n            # Subtract leading zero cases\n            if n > 1:\n                if u[0] == '_':\n                    # Leading zero: fix u[0] = '0', rest free_count-1 blanks\n                    leading_zero = 10 ** (free_count - 1)\n                    total -= leading_zero\n                elif u[0] == '0':\n                    total = 0\n            \n            count += total\n    \n    print(count)\n\nsolve()",
