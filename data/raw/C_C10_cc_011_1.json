      "final_code": "from collections import deque\n\ndef solve():\n    x, y = map(int, input().split())\n    \n    visited = set()\n    queue = deque([y])\n    visited.add(y)\n    \n    while queue:\n        curr = queue.popleft()\n        \n        if curr == x:\n            print(\"YES\")\n            return\n        \n        bin_curr = bin(curr)[2:]\n        reversed_bin = bin_curr[::-1]\n        \n        # The reversed_bin = bin(prev) + appended_bit, possibly with leading zeros stripped\n        # Try all possible numbers of leading zeros that were stripped (0 to 60)\n        for leading_zeros in range(62):\n            s = '0' * leading_zeros + reversed_bin\n            # s = bin(prev) + appended_bit, so bin(prev) = s[:-1]\n            prev_bin = s[:-1]\n            if not prev_bin:\n                continue\n            if prev_bin[0] == '0':\n                continue\n            prev_val = int(prev_bin, 2)\n            if prev_val == x:\n                print(\"YES\")\n                return\n            if 1 <= prev_val <= 2 * 10**18 and prev_val not in visited:\n                visited.add(prev_val)\n                queue.append(prev_val)\n    \n    print(\"NO\")\n\nsolve()",
