    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    # Find smallest v >= 0 such that v^n > m\n    # Try each bit from high to low: force v^n > m at this bit, minimize remaining bits of v\n    best = float('inf')\n    # Try making v^n > m by having a 1 at bit b where m has 0, and matching m above bit b\n    bits = 30\n    for b in range(bits, -1, -1):\n        # Check if bit b of m is 0\n        if not (m >> b & 1):\n            # We want v^n to match m on bits above b, then have 1 at bit b\n            # bits above b: (v^n) matches m means v matches (m^n) on those bits\n            # at bit b: (v^n) has 1 means v has (1 ^ (n>>b&1)) at bit b\n            # bits below b: minimize v, so set to 0\n            prefix = (m >> (b+1)) << (b+1)  # m's bits above b\n            v = (prefix ^ n) & ~((1<<(b+1))-1)  # v's bits above b to match m^n\n            v |= ((1 ^ (n>>b&1)) << b)  # bit b of v\n            # bits below b of v = 0\n            v = v & ((1<<31)-1)\n            if v >= 0 and v^n > m:\n                best = min(best, v)\n    print(best if best != float('inf') else 0)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
