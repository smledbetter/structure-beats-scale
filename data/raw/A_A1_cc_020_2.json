    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom math import gcd\ninput = sys.stdin.readline\n\ndef solve():\n    n, d = map(int, input().split())\n    a = list(map(int, input().split()))\n    \n    if not any(a):\n        print(0)\n        return\n    \n    g = gcd(n, d)\n    cycle_len = n // g\n    \n    visited = [False] * n\n    max_run = 0\n    \n    for start in range(g):\n        # Build the cycle starting from 'start', stepping by d each time\n        # The cycle in terms of the chain: i -> (i+d)%n -> (i+2d)%n -> ...\n        # (going forward by d gives the cycle)\n        cycle = []\n        cur = start\n        for _ in range(cycle_len):\n            cycle.append(a[cur])\n            cur = (cur + d) % n\n        \n        # Check if all ones\n        if all(x == 1 for x in cycle):\n            print(-1)\n            return\n        \n        # Find max run of 1s in circular array\n        # Double the array trick, but since not all 1s, we can find max run\n        # The run at position i (in cycle) going backwards means consecutive 1s ending at i\n        # We want max consecutive 1s in the circular sequence\n        \n        # Standard approach: find max run in circular array when not all 1s\n        doubled = cycle + cycle\n        cur_run = 0\n        best = 0\n        for x in doubled:\n            if x == 1:\n                cur_run += 1\n                best = max(best, min(cur_run, cycle_len))\n            else:\n                cur_run = 0\n        \n        max_run = max(max_run, best)\n    \n    print(max_run)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
