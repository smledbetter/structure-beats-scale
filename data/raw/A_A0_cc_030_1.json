    "code": "import sys\nfrom collections import Counter\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        a = [int(input_data[idx+j]) for j in range(n)]; idx += n\n        a_sorted = sorted(a)\n        \n        results = []\n        ptr = 0\n        cost = 0\n        # For each i from 0 to n\n        # We'll compute incrementally\n        \n        cnt = Counter(a)\n        \n        for i in range(n+1):\n            # Need 0..i-1 present, i absent\n            # cost_cover = cost accumulated so far (covering 0..i-1)\n            # cost_remove_i = number of elements equal to i (after assignments) * 1\n            # But elements equal to i that were used for covering < i are already moved\n            \n            # Count of i in remaining (not yet assigned) elements\n            # remaining elements are a_sorted[ptr:]\n            remaining_i = sum(1 for x in a_sorted[ptr:] if x == i)\n            total_cost = cost + remaining_i\n            results.append(total_cost)\n            \n            # Now extend: cover value i (for next iterations)\n            if ptr < n and a_sorted[ptr] <= i:\n                cost += i - a_sorted[ptr]\n                ptr += 1\n            else:\n                # Can't cover i, all future MEX > i are impossible\n                results.extend([-1] * (n - i))\n                break\n        \n        print(*results)\n\nsolve()",
