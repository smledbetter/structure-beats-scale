    "code": "import sys\nfrom math import isqrt\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx+=1\n    for _ in range(t):\n        n = int(input_data[idx]); idx+=1\n        a = list(map(int, input_data[idx:idx+n])); idx+=n\n        \n        prefix = [0]*(n+1)\n        for i in range(n):\n            prefix[i+1] = prefix[i] + a[i]\n        \n        def range_sum(l, r): # [l, r)\n            return prefix[r] - prefix[l]\n        \n        def check(k):\n            # segments of lengths k, k-1, ..., 1\n            # total length needed: k*(k+1)//2\n            if k*(k+1)//2 > n:\n                return False\n            if k == 0:\n                return True\n            \n            # dp[j] = minimum sum of current segment starting at j (if valid)\n            # INF means invalid\n            INF = float('inf')\n            \n            # Start from segment k (length 1) going to segment 1 (length k)\n            # suffix_min[j] = min of dp[j'], j' >= j\n            \n            # Initialize for segment k (length 1)\n            length = 1\n            # dp for segment k\n            dp = [INF]*n\n            for j in range(n - length + 1):\n                dp[j] = range_sum(j, j+length)\n            \n            # suffix min\n            suf_min = [INF]*(n+1)\n            for j in range(n-1, -1, -1):\n                suf_min[j] = min(suf_min[j+1], dp[j])\n            \n            # Now process segments k-1, k-2, ..., 1\n            for seg in range(k-1, 0, -1):\n                # current segment has length k+1-seg... wait\n                # seg goes from k-1 down to 1 (1-indexed segment number)\n                # segment number `seg` has length k+1-seg\n                length = k + 1 - seg\n                new_dp = [INF]*n\n                for j in range(n - length + 1):\n                    s = range_sum(j, j+length)\n                    # need suf_min of next segment starting at j+length > s\n                    nxt_start = j + length\n                    if nxt_start <= n and suf_min[nxt_start] > s:\n                        new_dp[j] = s\n                \n                dp = new_dp\n                suf_min = [INF]*(n+1)\n                for j in range(n-1, -1, -1):\n                    suf_min[j] = min(suf_min[j+1], dp[j])\n            \n            # Check if any valid starting position for segment 1 (length k)\n            # dp currently is for segment 1\n            return any(v < INF for v in dp)\n        \n        # Binary search on k\n        lo, hi = 0, 0\n        while (hi+1)*(hi+2)//2 <= n:\n            hi += 1\n        \n        ans = 0\n        lo, hi = 0, hi\n        while lo <= hi:\n            mid = (lo+hi)//2\n            if check(mid):\n                ans = mid\n                lo = mid+1\n            else:\n                hi = mid-1\n        \n        print(ans)\n\nsolve()",
