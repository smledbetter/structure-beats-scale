    "code": "import sys\nfrom sys import stdin\n\ndef solve():\n    input_data = stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx+=1\n    \n    for _ in range(t):\n        n, m = int(input_data[idx]), int(input_data[idx+1]); idx+=2\n        \n        edges = []\n        for i in range(n-1):\n            x,y,v = int(input_data[idx]),int(input_data[idx+1]),int(input_data[idx+2]); idx+=3\n            edges.append((x,y,v))\n        \n        queries = []\n        for i in range(m):\n            a,b,p = int(input_data[idx]),int(input_data[idx+1]),int(input_data[idx+2]); idx+=3\n            queries.append((a,b,p))\n        \n        parent = list(range(n+1))\n        rank = [0]*(n+1)\n        \n        def find(x):\n            if parent[x]==x: return x,0\n            root,r = find(parent[x])\n            rank[x] ^= rank[parent[x]]\n            parent[x] = root\n            return root, rank[x]\n        \n        def union(x,y,p):\n            rx,dx = find(x)\n            ry,dy = find(y)\n            if rx==ry:\n                return (dx^dy)==p\n            parent[rx]=ry\n            rank[rx]=dx^dy^p\n            return True\n        \n        ok = True\n        edge_parities = []\n        for (x,y,v) in edges:\n            if v>=0:\n                p = bin(v).count('1')%2\n                if not union(x,y,p):\n                    ok=False\n            edge_parities.append(-1 if v<0 else bin(v).count('1')%2)\n        \n        if ok:\n            for (a,b,p) in queries:\n                if not union(a,b,p):\n                    ok=False; break\n        \n        if not ok:\n            print(\"NO\")\n            continue\n        \n        print(\"YES\")\n        for i,(x,y,v) in enumerate(edges):\n            if v>=0:\n                print(x,y,v)\n            else:\n                rx,dx=find(x); ry,dy=find(y)\n                needed_parity = dx^dy\n                print(x,y,needed_parity)\n\nsolve()",
