      "final_code": "import sys\ninput = sys.stdin.readline\n\ndef min_xor_geq(n, target):\n    # Find minimum n^x for x >= target\n    # Try each bit position where we \"branch\" to make x > target prefix\n    best = float('inf')\n    # We'll try: for each bit i, fix bits above i to match target,\n    # set bit i higher than target's bit i (if possible while matching n),\n    # then set remaining bits to match n (minimize xor)\n    \n    # Greedy bit by bit\n    # At each bit, if we can match target's bit with n's bit and still reach target, do so\n    # Otherwise force x's bit to be 1 (making x > target at this bit), then set rest to n\n    \n    x = 0\n    for i in range(30, -1, -1):\n        t_bit = (target >> i) & 1\n        n_bit = (n >> i) & 1\n        # We want x_bit = n_bit to minimize xor\n        if n_bit >= t_bit:\n            # Setting x_bit = n_bit is fine (>= t_bit at this position)\n            x |= (n_bit << i)\n            if n_bit > t_bit:\n                # x is already > target at this bit, set remaining bits = n bits\n                for j in range(i-1, -1, -1):\n                    x |= ((n >> j) & 1) << j\n                return n ^ x  # should be 0 for remaining bits\n        else:\n            # n_bit=0, t_bit=1: must set x_bit=1, xor bit = 1\n            # but then x at this bit equals t_bit, continue\n            x |= (1 << i)\n    \n    return n ^ x\n\ndef solve(n, m):\n    if n > m:\n        return 0\n    return min_xor_geq(n, m + 1)\n\nt = int(input())\nfor _ in range(t):\n    n, m = map(int, input().split())\n    print(solve(n, m))",
