or num = m, can add to sequences with mex m-1, m, m+1\n                # Adding to m-1: mex becomes m+1\n                # Adding to m: mex becomes m-1 or m+1 (depending on whether m-1 is present)\n                # Adding to m+1: mex remains m+1\n                m = num\n                new_self = 1 if m <= 1 else 0  # new sequence [m], valid only if m is 0 or 1 (for m >=2, mex starts at 0)\n                # For m >=2, new sequence [m] has mex 0, but |m - 0| <=1 must hold, which is false unless m <=1\n                if m >= 2:\n                    new_self = 0\n                # Update dp[m+1] += dp[m-1] + dp[m] (adding m to mex m-1 or m sequences)\n                # Update dp[m] += dp[m] (option to not add m)\n                # Update dp[m-1] remains same (if not adding m)\n                add_m_plus = 0\n                if m - 1 >= 0:\n                    add_m_plus = (add_m_plus + dp[m - 1]) % MOD\n                add_m_plus = (add_m_plus + dp[m]) % MOD\n                dp[m + 1] = (dp[m + 1] + add_m_plus) % MOD\n                if m >= 1:\n                    dp[m] = (dp[m] * 2) % MOD\n                    if m == 1:\n                        dp[m] = (dp[m] + new_self) % MOD\n                # For m == 0 or 1, handled in earlier cases\n        total = 0\n        for i in range(n + 2):\n            total = (total + dp[i]) % MOD\n        print(total)\n        # Reset dp for next test case\n        dp = [0] * (n + 3)\n\ndef main():\n    solve()\n\nif __name__ == \"__main__\":\n    main()",
