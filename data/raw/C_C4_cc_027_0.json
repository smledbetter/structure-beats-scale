      "final_code": "import sys\nfrom math import comb\nfrom functools import lru_cache\n\ndef solve():\n    MOD = 998244353\n    n, x = map(int, input().split())\n    \n    @lru_cache(maxsize=None)\n    def dp(remaining, damage):\n        # Count ways to assign 'remaining' heroes with health in [damage+1, x]\n        # such that no winner\n        if remaining == 0:\n            return 1\n        \n        result = 0\n        # Heroes that die next round have health in [damage+1, damage+remaining-1]\n        # That's (remaining-1) possible values\n        die_range = remaining - 1  # number of values: damage+1 to damage+remaining-1\n        \n        if damage + remaining - 1 > x:\n            die_range = max(0, x - damage)\n        \n        # All remaining die together (k = remaining), values in [damage+1, damage+remaining-1]\n        # Each of 'remaining' heroes picks from die_range values\n        if die_range > 0:\n            all_die = pow(die_range, remaining, MOD)\n            result = (result + all_die) % MOD\n        \n        # k heroes die (2 <= k < remaining), rest survive\n        for k in range(2, remaining):\n            if die_range <= 0:\n                break\n            ways_die = pow(die_range, k, MOD) * comb(remaining, k) % MOD\n            ways_survive = dp(remaining - k, damage + remaining - 1)\n            result = (result + ways_die * ways_survive) % MOD\n        \n        return result\n    \n    print(dp(n, 0))\n\nsolve()",
