    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, k = map(int, input().split())\n    a = list(map(int, input().split()))\n    INF = float('inf')\n    # dp[j][c] = min total deletions selecting c elements, last at index j (1-indexed)\n    dp = [[INF]*(k+1) for _ in range(n+1)]\n    for j in range(1, n+1):\n        d = j - a[j-1]\n        if d >= 0:\n            dp[j][1] = d\n    for c in range(2, k+1):\n        for j2 in range(1, n+1):\n            d2 = j2 - a[j2-1]\n            if d2 < 0: continue\n            for j1 in range(1, j2):\n                d1 = j1 - a[j1-1]\n                if d1 < 0: continue\n                if dp[j1][c-1] == INF: continue\n                if d2 >= d1 and d2 - d1 <= j2 - j1 - 1:\n                    val = max(dp[j1][c-1], d2)\n                    if val < dp[j2][c]:\n                        dp[j2][c] = val\n    ans = min(dp[j][k] for j in range(1, n+1))\n    if ans == INF:\n        print(-1)\n    else:\n        print(ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
