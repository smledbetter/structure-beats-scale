      "final_code": "import sys\nfrom collections import defaultdict\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        a = list(map(int, input_data[idx:idx+n])); idx += n\n        \n        # State: (left_extent, right_extent)\n        # Pareto-optimal: sorted by left_extent ascending, right_extent descending\n        # Keep only states where no other state dominates (smaller left AND smaller right)\n        # Store as sorted list by left_extent, with right_extent strictly decreasing\n        \n        # Initial state: left=0, right=0\n        pareto = [(0, 0)]  # sorted by left asc, right desc (Pareto front)\n        \n        for d in a:\n            new_states = {}\n            for (L, R) in pareto:\n                # Go right: left stays L, right becomes max(R, d)\n                nL, nR = L, max(R, d)\n                key = nL\n                if key not in new_states or new_states[key] > nR:\n                    new_states[key] = nR\n                # Go left: right stays R, left becomes max(L, d)\n                nL2, nR2 = max(L, d), R\n                key2 = nL2\n                if key2 not in new_states or new_states[key2] > nR2:\n                    new_states[key2] = nR2\n            \n            # Build Pareto front: sort by L asc, keep only those with strictly decreasing R\n            sorted_states = sorted(new_states.items())\n            pareto = []\n            min_R = float('inf')\n            for (L, R) in sorted_states:\n                if R < min_R:\n                    pareto.append((L, R))\n                    min_R = R\n        \n        ans = min(L + R for (L, R) in pareto)\n        print(ans)\n\nsolve()",
