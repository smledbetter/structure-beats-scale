      "final_code": "import sys\ninput = sys.stdin.readline\n\ndef main():\n    q = int(input())\n    queries = []\n    for _ in range(q):\n        line = input().split()\n        if line[0] == '1':\n            queries.append((1, int(line[1])))\n        else:\n            queries.append((2, int(line[1]), int(line[2])))\n    \n    parent = list(range(500001))\n    \n    def find(x):\n        while parent[x] != x:\n            parent[x] = parent[parent[x]]\n            x = parent[x]\n        return x\n    \n    result = []\n    for query in reversed(queries):\n        if query[0] == 1:\n            result.append(find(query[1]))\n        else:\n            x, y = query[1], query[2]\n            fx = find(x)\n            fy = find(y)\n            # Only apply if x hasn't been replaced by a later query\n            if fx == x:\n                parent[x] = fy\n    \n    result.reverse()\n    print(*result)\n\nmain()",
