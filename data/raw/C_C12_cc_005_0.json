      "final_code": "def solve():\n    s = input().strip()\n    n = len(s)\n    \n    count = 0\n    \n    has_x = 'X' in s\n    x_range = range(10) if has_x else range(1)  # if no X, only iterate once\n    \n    for x_val in x_range:\n        # Replace X with x_val\n        t = [str(x_val) if c == 'X' else c for c in s]\n        \n        # Find positions of '_'\n        blank_positions = [i for i, c in enumerate(t) if c == '_']\n        num_blanks = len(blank_positions)\n        \n        # For each assignment of last two positions (or fewer), check divisibility\n        # We'll enumerate only blanks in last 2 positions, multiply free blanks\n        # Strategy: enumerate all combinations for blanks in positions n-2 and n-1 (if blank)\n        # For other blanks, count freely (but must handle leading zero)\n        \n        # Actually with n<=8 and at most 8 blanks, 10^8 is too slow\n        # But we can be smarter: only last 2 digits matter for div by 25\n        # Enumerate last 2 digits, check div by 25, then count valid prefixes\n        \n        from itertools import product as iproduct\n        \n        # Enumerate all possible (last1, last2) combinations\n        last_blanks = [i for i in blank_positions if i >= n-2]\n        other_blanks = [i for i in blank_positions if i < n-2]\n        \n        for last_vals in iproduct(range(10), repeat=len(last_blanks)):\n            u = t[:]\n            for pos, val in zip(last_blanks, last_vals):\n                u[pos] = str(val)\n            \n            # Check last two digits divisibility\n            suffix = ''.join(u[n-2:]) if n >= 2 else ''.join(u)\n            num_suffix = int(suffix)\n            if num_suffix % 25 != 0:\n                continue\n            \n            # Count valid assignments for other_blanks\n            # Must avoid leading zero: if n > 1, u[0] != '0'\n            \n            # Count free assignments for other blanks\n            # If position 0 is in other_blanks, it can't be 0 (if n > 1)\n            # Other positions can be anything\n            \n            if n == 1:\n                # Only one digit, already handled above\n                count += 1\n                continue\n            \n            # Check if first position is already fixed (not in other_blanks)\n            if 0 not in other_blanks:\n                # First char is fixed\n                if str(u[0]) == '0':\n                    continue  # leading zero\n                # All other_blanks are free (none at position 0)\n                free_count = 10 ** len(other_blanks)\n                count += free_count\n            else:\n                # Position 0 is in other_blanks\n                # It can be 1-9 (9 choices), rest are free\n                other_non_first = [i for i in other_blanks if i != 0]\n                free_count = 9 * (10 ** len(other_non_first))\n                count += free_count\n    \n    # If no X, we ran x_range = range(1) with x_val=0 but X replacements didn't happen\n    # Actually when has_x is False, x_val=0 but no 'X' in string so t is unchanged - correct\n    \n    print(count)\n\nsolve()",
