    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, k = map(int, input().split())\n    a = list(map(int, input().split()))\n    INF = float('inf')\n    \n    valid = []\n    for j in range(n):\n        pos = j + 1\n        d = pos - a[j]\n        if 0 <= d <= j:\n            valid.append((j, d))\n    \n    if len(valid) < k:\n        print(-1)\n        return\n    \n    m = len(valid)\n    dp = [[INF] * (k + 1) for _ in range(m)]\n    \n    for i in range(m):\n        dp[i][1] = valid[i][1]\n    \n    for cnt in range(2, k + 1):\n        for j in range(m):\n            jj, dj = valid[j]\n            best = INF\n            for i in range(j):\n                ii, di = valid[i]\n                prev = dp[i][cnt-1]\n                if prev == INF:\n                    continue\n                if prev <= dj and (ii - prev) < (jj - dj):\n                    if prev < best:\n                        best = prev\n            if best != INF:\n                dp[j][cnt] = dj\n    \n    ans = min(dp[j][k] for j in range(m))\n    print(-1 if ans == INF else ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
