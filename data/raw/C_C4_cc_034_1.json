          "code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        a = list(map(int, input_data[idx:idx+n])); idx += n\n        \n        # State: (left_dist, right_dist) where left_dist = x - lo >= 0, right_dist = hi - x >= 0\n        # Initially x=0, lo=0, hi=0: left_dist=0, right_dist=0\n        # Transition with segment d:\n        # Go right: new_x = x+d, new_hi = max(hi, x+d), new_lo = lo\n        #   new_right = max(right_dist, d) - ... let me recompute\n        # left_dist_new = (x+d) - lo = left_dist + d, right_dist_new = max(hi, x+d) - (x+d) = max(right_dist - d, 0)\n        # Go left: new_x = x-d, new_lo = min(lo, x-d)\n        #   left_dist_new = max(left_dist - d, 0), right_dist_new = right_dist + d\n        \n        states = {(0, 0)}\n        for d in a:\n            new_states = set()\n            for (l, r) in states:\n                # go right\n                new_states.add((l + d, max(r - d, 0)))\n                # go left\n                new_states.add((max(l - d, 0), r + d))\n            states = new_states\n        \n        print(min(l + r for l, r in states))\n\nsolve()",
