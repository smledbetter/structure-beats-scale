    "code": "import sys\nfrom collections import defaultdict\ninput = sys.stdin.readline\n\ndef solve():\n    n, k = map(int, input().split())\n    mines = []\n    for _ in range(n):\n        x, y, t = map(int, input().split())\n        mines.append((x, y, t))\n    \n    parent = list(range(n))\n    def find(a):\n        while parent[a] != a:\n            parent[a] = parent[parent[a]]\n            a = parent[a]\n        return a\n    def union(a, b):\n        a, b = find(a), find(b)\n        if a != b: parent[a] = b\n    \n    by_x = defaultdict(list)\n    by_y = defaultdict(list)\n    for i, (x, y, t) in enumerate(mines):\n        by_x[x].append((y, i))\n        by_y[y].append((x, i))\n    \n    for x, lst in by_x.items():\n        lst.sort()\n        for j in range(len(lst)-1):\n            if lst[j+1][0] - lst[j][0] <= k:\n                union(lst[j][1], lst[j+1][1])\n    for y, lst in by_y.items():\n        lst.sort()\n        for j in range(len(lst)-1):\n            if lst[j+1][0] - lst[j][0] <= k:\n                union(lst[j][1], lst[j+1][1])\n    \n    comp_min = {}\n    for i, (x, y, t) in enumerate(mines):\n        r = find(i)\n        if r not in comp_min or t < comp_min[r]:\n            comp_min[r] = t\n    \n    min_timers = sorted(comp_min.values())\n    C = len(min_timers)\n    \n    lo, hi = 0, int(2e9) + C + 1\n    while lo < hi:\n        mid = (lo + hi) // 2\n        import bisect\n        need = C - bisect.bisect_right(min_timers, mid)\n        if need <= mid + 1:\n            hi = mid\n        else:\n            lo = mid + 1\n    print(lo)\n\nimport sys, bisect\nfrom collections import defaultdict\ninput = sys.stdin.readline\n\nt = int(input())\nfor _ in range(t):\n    input()  # empty line\n    solve()",
