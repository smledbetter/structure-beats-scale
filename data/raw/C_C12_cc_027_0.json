      "final_code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    MOD = 998244353\n    n, x = map(int, input().split())\n    \n    @lru_cache(maxsize=None)\n    def dp(remaining, dmg):\n        # Count ways to assign health to 'remaining' heroes (sorted)\n        # each with effective health > dmg (original health in [dmg+1, x])\n        # Returns number of valid assignments (as ordered tuples)\n        \n        # The next group dies when cumulative damage = dmg + rounds*(remaining-1)\n        # They have health in (dmg, dmg + (remaining-1)] i.e. [dmg+1, dmg+remaining-1]\n        # After they die, survivors have health > dmg + (remaining-1)\n        \n        result = 0\n        # Choose group size k that dies next\n        for k in range(1, remaining + 1):\n            if k == remaining - 1:\n                # Would leave exactly 1 survivor = winner, forbidden\n                continue\n            # k heroes die, they have health in [dmg+1, dmg + (remaining-1)]\n            # but must be > dmg, so health in [dmg+1, dmg+remaining-1]\n            low = dmg + 1\n            high = min(dmg + remaining - 1, x)\n            if high < low:\n                break\n            # Number of ways to choose k values from [low, high] with repetition (ordered)\n            # = (high - low + 1)^k ... but they're sorted segment\n            # Actually we're counting ordered tuples overall, so choose k positions\n            # from remaining, assign values in [low,high], rest get values in (high, x]\n            \n            choices_die = high - low + 1  # values available for dying group\n            # ordered ways for k heroes: choices_die^k * C(remaining, k)\n            ways_die = pow(choices_die, k, MOD) * __import__('math').comb(remaining, k) % MOD\n            \n            if k == remaining:\n                result = (result + ways_die) % MOD\n            else:\n                new_dmg = dmg + (remaining - 1)\n                sub = dp(remaining - k, new_dmg)\n                result = (result + ways_die * sub) % MOD\n        \n        return result\n    \n    print(dp(n, 0))\n\nsolve()",
