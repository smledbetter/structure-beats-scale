    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import deque\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx+=1\n    for _ in range(t):\n        n,m = int(input_data[idx]),int(input_data[idx+1]); idx+=2\n        grid = []\n        lab = None\n        for i in range(n):\n            row = input_data[idx].decode(); idx+=1\n            grid.append(list(row))\n            for j in range(m):\n                if grid[i][j]=='L': lab=(i,j)\n        \n        # directions: 0=R,1=D,2=L,3=U\n        dr=[0,1,0,-1]; dc=[1,0,-1,0]\n        \n        # A cell is \"forceable\" if we can guarantee the robot reaches the lab.\n        # Key insight: from a free cell, we send a command (one of 4 directions).\n        # The robot picks any direction DIFFERENT from the command, as long as that\n        # direction leads to a non-blocked cell.\n        # \n        # A cell is good if there exists a command such that ALL possible moves\n        # the robot can make lead to good cells (or the lab).\n        # \n        # Equivalently: cell (i,j) is good if there exists a direction d (command) such that\n        # every neighbor in direction d' != d that is free leads to a good cell.\n        #\n        # We use a reverse BFS/propagation approach:\n        # - Count for each cell the number of free neighbors\n        # - A cell is \"safe\" if it has at most 1 free neighbor (then robot has no choice\n        #   but to go to that neighbor, or do nothing if 0 free neighbors... but 0 means stuck)\n        # Actually the correct approach:\n        # \n        # Cell is forceable if:\n        #   exists a command d such that for all d' != d where neighbor in d' is free,\n        #   that neighbor is forceable.\n        #\n        # We do BFS starting from lab. \n        # For each cell, track how many free neighbors are NOT yet forceable.\n        # A cell becomes forceable when there exists some direction d such that\n        # all free neighbors except possibly the one in direction d are forceable.\n        # i.e., (number of non-forceable free neighbors) <= 1\n        # Because we can always send command d = direction of the one non-forceable neighbor\n        # (or any command if all are forceable).\n        \n        # Count free neighbors for each cell\n        free_neighbors = [[0]*m for _ in range(n)]\n        for i in range(n):\n            for j in range(m):\n                if grid[i][j] == '#':\n                    continue\n                cnt = 0\n                for k in range(4):\n                    ni, nj = i+dr[k], j+dc[k]\n                    if 0<=ni<n and 0<=nj<m and grid[ni][nj]!='#':\n                        cnt += 1\n                free_neighbors[i][j] = cnt\n        \n        forceable = [[False]*m for _ in range(n)]\n        # non_forceable_free_neighbors count\n        nffn = [[0]*m for _ in range(n)]\n        for i in range(n):\n            for j in range(m):\n                nffn[i][j] = free_neighbors[i][j]\n        \n        queue = deque()\n        li, lj = lab\n        forceable[li][lj] = True\n        queue.append((li, lj))\n        \n        while queue:\n            ci, cj = queue.popleft()\n            # ci,cj just became forceable\n            # update all free neighbors of ci,cj\n            for k in range(4):\n                ni, nj = ci+dr[k], cj+dc[k]\n                if 0<=ni<n and 0<=nj<m and grid[ni][nj]!='#':\n                    if not forceable[ni][nj]:\n                        nffn[ni][nj] -= 1\n                        # cell (ni,nj) is forceable if nffn <= 1\n                        # because we can send command toward the one non-forceable neighbor\n                        if nffn[ni][nj] <= 1:\n                            forceable[ni][nj] = True\n                            queue.append((ni, nj))\n        \n        # Mark forceable '.' cells with '+'\n        for i in range(n):\n            for j in range(m):\n                if grid[i][j] == '.' and forceable[i][j]:\n                    grid[i][j] = '+'\n        \n        print('\\n'.join(''.join(r) for r in grid))\n\nsolve()",
