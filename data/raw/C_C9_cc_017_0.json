      "code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    n, k = int(input_data[0]), int(input_data[1])\n    s = input_data[2]\n    \n    MOD = 998244353\n    \n    total_ones = s.count('1')\n    \n    if k == 0 or k > total_ones:\n        print(1)\n        return\n    \n    # Precompute binomial coefficients\n    max_n = n + 5\n    C = [[0] * (max_n) for _ in range(max_n)]\n    C[0][0] = 1\n    for i in range(1, max_n):\n        C[i][0] = 1\n        for j in range(1, max_n):\n            C[i][j] = (C[i-1][j-1] + C[i-1][j]) % MOD\n    \n    # Precompute prefix ones\n    prefix = [0] * (n + 1)\n    for i in range(n):\n        prefix[i+1] = prefix[i] + (1 if s[i] == '1' else 0)\n    \n    ans = 1  # for s itself\n    \n    for a in range(n):\n        ones_so_far = 0\n        for b in range(a, n):\n            ones_so_far += (1 if s[b] == '1' else 0)\n            m = ones_so_far\n            if m > k:\n                break  # increasing b only increases m\n            # Wait, m can't decrease as b increases... actually it can't, so break is valid\n            # But wait, we want m <= k, and m is non-decreasing in b, so once m > k we can break\n            \n            if a == b:\n                continue  # f(a,a) = 0\n            \n            L = b - a + 1\n            sa = 1 if s[a] == '1' else 0\n            sb = 1 if s[b] == '1' else 0\n            \n            # f = C(L,m) - C(L-1, m-sa) - C(L-1, m-sb) + C(L-2, m-sa-sb)\n            def cc(nn, kk):\n                if kk < 0 or kk > nn or nn < 0:\n                    return 0\n                return C[nn][kk]\n            \n            f = (cc(L, m) - cc(L-1, m-sa) - cc(L-1, m-sb) + cc(L-2, m-sa-sb)) % MOD\n            ans = (ans + f) % MOD\n    \n    print(ans % MOD)\n\nsolve()",
