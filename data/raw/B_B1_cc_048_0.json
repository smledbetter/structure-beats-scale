    "code": "import sys\nfrom itertools import combinations\n\ndef smallest_with_digits(n_str, digits):\n    digits = sorted(digits)\n    L = len(n_str)\n    \n    # Try to build number of length L >= n_str using only these digits\n    result = try_same_length(n_str, digits, L)\n    if result is not None:\n        return result\n    \n    # Try length L+1\n    non_zero = [d for d in digits if d != '0']\n    if not non_zero:\n        return None\n    return non_zero[0] + digits[0] * L\n\ndef try_same_length(n_str, digits, L):\n    # Greedy: build digit by digit, try to match or exceed n_str\n    # tight: whether we're still constrained by n_str\n    result = [''] * L\n    return build(n_str, digits, 0, True, result, L)\n\ndef build(n_str, digits, pos, tight, result, L):\n    if pos == L:\n        return ''.join(result)\n    \n    lo = n_str[pos] if tight else '0'\n    \n    # Try each digit >= lo (and != '0' if pos == 0)\n    for d in digits:\n        if pos == 0 and d == '0':\n            continue\n        if d < lo:\n            continue\n        if d == lo:\n            # Stay tight\n            result[pos] = d\n            res = build(n_str, digits, pos + 1, True, result, L)\n            if res is not None:\n                return res\n        else:\n            # d > lo, no longer tight, fill rest with smallest digit\n            result[pos] = d\n            # Fill remaining with smallest digit\n            for i in range(pos + 1, L):\n                result[i] = digits[0]\n            return ''.join(result)\n    \n    return None\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    t = int(input_data[0])\n    idx = 1\n    results = []\n    \n    for _ in range(t):\n        n = int(input_data[idx])\n        k = int(input_data[idx+1])\n        idx += 2\n        \n        n_str = str(n)\n        all_digits = [str(i) for i in range(10)]\n        \n        best = None\n        \n        for size in range(1, k+1):\n            for combo in combinations(all_digits, size):\n                candidate = smallest_with_digits(n_str, list(combo))\n                if candidate is not None:\n                    # candidate is a string, compare as integer\n                    if best is None:\n                        best = candidate\n                    else:\n                        # Compare: shorter is smaller, same length compare lexicographically\n                        if len(candidate) < len(best) or (len(candidate) == len(best) and candidate < best):\n                            best = candidate\n        \n        results.append(best)\n    \n    print('\\n'.join(results))\n\nsolve()",
