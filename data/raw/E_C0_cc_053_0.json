      "final_code": "def max_intersections(t, test_cases):\n    results = []\n    for case in test_cases:\n        n, k, chords = case\n        used = set()\n        for x, y in chords:\n            used.add(x)\n            used.add(y)\n        available = sorted(set(range(1, 2*n+1)) - used)\n        new_chords = []\n        for i in range(0, len(available), 2):\n            new_chords.append((available[i], available[i+1]))\n        all_chords = chords + new_chords\n        intersections = 0\n        for i in range(len(all_chords)):\n            for j in range(i+1, len(all_chords)):\n                a, b = all_chords[i]\n                c, d = all_chords[j]\n                if (a < c < b < d) or (c < a < d < b):\n                    intersections += 1\n        results.append(intersections)\n    return results\n\ndef main():\n    import sys\n    input = sys.stdin.read\n    data = input().split()\n    idx = 0\n    t = int(data[idx])\n    idx += 1\n    test_cases = []\n    for _ in range(t):\n        n = int(data[idx])\n        k = int(data[idx+1])\n        idx += 2\n        chords = []\n        for _ in range(k):\n            x = int(data[idx])\n            y = int(data[idx+1])\n            chords.append((x, y))\n            idx += 2\n        test_cases.append((n, k, chords))\n    results = max_intersections(t, test_cases)\n    for res in results:\n        print(res)\n\nif __name__ == \"__main__\":\n    main()",
