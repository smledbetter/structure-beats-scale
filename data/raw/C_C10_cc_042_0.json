      "final_code": "import sys\ninput = sys.stdin.readline\n\ndef can_one_op(a, b, n):\n    # returns index i if possible, else -1\n    for i in range(n):\n        if a[i] == '1' and b[i] == '1':\n            ok = all(a[j] != b[j] for j in range(n) if j != i)\n            if ok:\n                return i\n    return -1\n\ndef apply_op(a, i, n):\n    res = list(a)\n    for j in range(n):\n        if j != i:\n            res[j] = '1' if a[j] == '0' else '0'\n    return ''.join(res)\n\nt = int(input())\nfor _ in range(t):\n    n = int(input())\n    a = input().strip()\n    b = input().strip()\n    \n    if a == b:\n        print(0)\n        continue\n    \n    # Try 1 op\n    idx = can_one_op(a, b, n)\n    if idx != -1:\n        print(1)\n        continue\n    \n    # Try 2 ops: after one op on a selecting i, get c, then check 1 op from c to b\n    found2 = False\n    for i in range(n):\n        if a[i] == '1':\n            c = apply_op(a, i, n)\n            if can_one_op(c, b, n) != -1 or c == b:\n                found2 = True\n                break\n    if found2:\n        print(2)\n        continue\n    \n    # Try 3 ops\n    found3 = False\n    for i in range(n):\n        if a[i] == '1':\n            c = apply_op(a, i, n)\n            for j in range(n):\n                if c[j] == '1':\n                    d = apply_op(c, j, n)\n                    if can_one_op(d, b, n) != -1 or d == b:\n                        found3 = True\n                        break\n            if found3:\n                break\n    if found3:\n        print(3)\n        continue\n    \n    print(-1)",
