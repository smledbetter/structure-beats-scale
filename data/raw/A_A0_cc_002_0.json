    "code": "import sys\nfrom collections import deque\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    n = int(input_data[idx]); idx+=1\n    a = [0] + [int(input_data[idx+i]) for i in range(n)]; idx+=n\n    b = [0] + [int(input_data[idx+i]) for i in range(n)]; idx+=n\n    \n    # nxt[i] = next unvisited node >= i (among 1..n, plus 0 as escape)\n    nxt = list(range(n+2))  # nxt[i] = i initially\n    \n    dist = [-1] * (n+1)\n    prev_jump = [-1] * (n+1)  # prev_jump[v] = the depth before slip that led to v\n    parent = [-1] * (n+1)  # parent[v] = position before the jump\n    \n    def find(x):\n        while nxt[x] != x:\n            nxt[x] = nxt[nxt[x]]\n            x = nxt[x]\n        return x\n    \n    def mark_visited(x):\n        nxt[x] = x+1  # point to next\n    \n    dist[n] = 0\n    queue = deque([n])\n    mark_visited(n)\n    found = False\n    escape_from = -1\n    \n    while queue:\n        x = queue.popleft()\n        # from x, can jump to any y in [x - a[x], x-1], or escape if x - a[x] <= 0\n        lo = x - a[x]\n        if lo <= 0:\n            # can escape\n            found = True\n            escape_from = x\n            break\n        # visit all unvisited y in [lo, x-1]\n        y = find(lo)\n        while y <= x-1:\n            dist[y] = dist[x] + 1\n            parent[y] = x\n            new_pos = y + b[y]\n            if new_pos not in [x] or True:\n                mark_visited(y)\n                queue.append(new_pos)  # but new_pos might already be visited...\n            y = find(lo)\n    \n    # Need to handle new_pos already visited case",
