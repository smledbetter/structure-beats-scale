      "code": "import sys\nimport math\n\nMOD = 10**9 + 7\n\ndef main():\n    n = int(sys.stdin.readline())\n    a = list(map(int, sys.stdin.readline().split()))\n    \n    # Precompute frequency of each a_i\n    freq_a = {}\n    for num in a:\n        freq_a[num] = freq_a.get(num, 0) + 1\n    \n    # Precompute gcd counts for i and j\n    # We need to compute the sum of gcd(i,j) for all i,j in 1..n\n    # We can precompute for each d, the number of pairs (i,j) where gcd(i,j) = d\n    # This can be done using inclusion-exclusion\n    # Let cnt[d] be the number of pairs (i,j) where d divides gcd(i,j)\n    # Then cnt[d] = (n//d) * (n//d)\n    # The number of pairs where gcd(i,j) = d is cnt[d] - sum_{k=2}^{n//d} cnt[k*d]\n    # We can compute this in a sieve-like manner\n    max_d = n\n    cnt = [0] * (max_d + 1)\n    for d in range(1, max_d + 1):\n        cnt[d] = (n // d) * (n // d)\n    \n    # Now, compute the number of pairs where gcd(i,j) = d\n    gcd_counts = [0] * (max_d + 1)\n    for d in range(max_d, 0, -1):\n        gcd_counts[d] = cnt[d]\n        for k in range(2 * d, max_d + 1, d):\n            gcd_counts[d] -= gcd_counts[k]\n    \n    # Now, precompute for each possible gcd of a_i and a_j\n    # We need to find for each possible d, the number of pairs (a_i, a_j) where gcd(a_i, a_j) = d\n    # Similarly, we can use inclusion-exclusion\n    # Let freq_a be the frequency of each a_i\n    # For each d, cnt_a[d] = sum_{x divisible by d} freq_a[x]\n    # Then, the number of pairs where gcd(a_i, a_j) = d is cnt_a[d] * cnt_a[d] - sum_{k=2}^{max_a//d} cnt_a[k*d] * cnt_a[k*d]\n    max_a = max(a)\n    cnt_a = [0] * (max_a + 1)\n    for num in a:\n        for d in range(1, int(math.sqrt(num)) + 1):\n            if num % d == 0:\n                cnt_a[d] += 1\n                if d != num // d:\n                    cnt_a[num // d] += 1\n    \n    # Now, compute the number of pairs where gcd(a_i, a_j) = d\n    gcd_counts_a = [0] * (max_a + 1)\n    for d in range(max_a, 0, -1):\n        gcd_counts_a[d] = cnt_a[d] * cnt_a[d]\n        for k in range(2 * d, max_a + 1, d):\n            gcd_counts_a[d] -= gcd_counts_a[k]\n    \n    # Now, compute the total prettiness\n    total = 0\n    for d in range(1, max_a + 1):\n        if gcd_counts_a[d] == 0:\n            continue\n        for e in range(1, max_d + 1):\n            if gcd_counts[e] == 0:\n                continue\n            g = math.gcd(d, e)\n            total = (total + g * gcd_counts_a[d] * gcd_counts[e]) % MOD\n    \n    print(total)\n\nif __name__ == \"__main__\":\n    main()",
