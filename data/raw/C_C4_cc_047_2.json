      "final_code": "import sys\nfrom math import ceil\ninput = sys.stdin.readline\n\ndef check(h, m, n):\n    h = list(h)\n    for i in range(2, n):\n        need = max(0, m - h[i-2])\n        d_min = (need + 1) // 2\n        d_max = (h[i] - m) // 3\n        if d_min > d_max:\n            return False\n        d = d_max\n        h[i] -= 3 * d\n        h[i-1] += d\n        h[i-2] += 2 * d\n    return h[n-2] >= m and h[n-1] >= m\n\ndef solve():\n    n = int(input())\n    h = list(map(int, input().split()))\n    lo, hi = 0, sum(h) // n\n    while lo < hi:\n        mid = (lo + hi + 1) // 2\n        if check(h, mid, n):\n            lo = mid\n        else:\n            hi = mid - 1\n    print(lo)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
