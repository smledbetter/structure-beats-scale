          "model": "claude-sonnet-4-6",
          "code": "import sys\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    def rd():\n        nonlocal idx\n        v = input_data[idx]; idx += 1\n        return int(v)\n    \n    t = rd()\n    for _ in range(t):\n        n, m = rd(), rd()\n        x = [rd() for _ in range(n)]\n        s = []\n        for i in range(n):\n            row = input_data[idx].decode(); idx += 1\n            s.append(row)\n        \n        # For each question j, compute pattern as integer bitmask\n        patterns = []\n        for j in range(m):\n            pat = 0\n            for i in range(n):\n                if s[i][j] == '1':\n                    pat |= (1 << i)\n            patterns.append(pat)\n        \n        # Group questions by pattern\n        from collections import defaultdict\n        pat_questions = defaultdict(list)\n        for j, pat in enumerate(patterns):\n            pat_questions[pat].append(j)\n        \n        unique_pats = list(pat_questions.keys())\n        \n        best_surprise = -1\n        best_p = None\n        \n        for signs in range(1 << n):\n            sigma = [1 if (signs >> i) & 1 else -1 for i in range(n)]\n            \n            # w for each unique pattern\n            pat_w = {}\n            for pat in unique_pats:\n                w = 0\n                for i in range(n):\n                    if (pat >> i) & 1:\n                        w += sigma[i]\n                pat_w[pat] = w\n            \n            # Sort unique patterns by w value\n            sorted_pats = sorted(unique_pats, key=lambda pat: pat_w[pat])\n            \n            # Assign ranks: smallest w gets largest p values\n            # Build p array\n            p = [0] * m\n            rank = m  # start from m, going down\n            for pat in sorted_pats:\n                qs = pat_questions[pat]\n                # assign ranks rank, rank-1, ... to these questions (order within group doesn't matter)\n                for j in qs:\n                    p[j] = rank\n                    rank -= 1\n            \n            r = [0] * n\n            for j in range(m):\n                if p[j] > 0:\n                    for i in range(n):\n                        if s[i][j] == '1':\n                            r[i] += p[j]\n            \n            surprise = sum(abs(x[i] - r[i]) for i in range(n))\n            if surprise > best_surprise:\n                best_surprise = surprise\n                best_p = p[:]\n        \n        print(*best_p)\n\nsolve()",
