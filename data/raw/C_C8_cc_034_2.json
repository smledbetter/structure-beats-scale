      "final_code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    # dp: dict r -> min_rmax, but keep pareto front\n    # State: (r, rmax), r=current pos from left boundary, rmax=right boundary from left\n    dp = {0: 0}  # r=0, rmax=0\n    \n    for ai in a:\n        ndp = {}\n        for r, rmax in dp.items():\n            # go right\n            nr = r + ai\n            nrmax = max(rmax, nr)\n            if nr not in ndp or ndp[nr] > nrmax:\n                ndp[nr] = nrmax\n            # go left\n            if r >= ai:\n                nr2 = r - ai\n                nrmax2 = rmax\n            else:\n                nr2 = 0\n                nrmax2 = rmax + (ai - r)\n            if nr2 not in ndp or ndp[nr2] > nrmax2:\n                ndp[nr2] = nrmax2\n        # Prune dominated states: sort by r, remove if rmax is not decreasing\n        sorted_states = sorted(ndp.items())\n        pruned = {}\n        min_rmax = float('inf')\n        for r, rmax in reversed(sorted_states):\n            if rmax < min_rmax:\n                min_rmax = rmax\n                pruned[r] = rmax\n        dp = pruned\n    \n    print(min(dp.values()))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
