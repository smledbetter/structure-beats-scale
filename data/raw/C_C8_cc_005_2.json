      "final_code": "def solve():\n    s = input().strip()\n    n = len(s)\n    \n    from itertools import product\n    \n    count = 0\n    x_range = range(10) if 'X' in s else [None]\n    \n    for xv in x_range:\n        t = list(s)\n        if xv is not None:\n            for i in range(n):\n                if t[i] == 'X':\n                    t[i] = str(xv)\n        \n        # Now t has digits and '_'\n        # Enumerate all _ combinations\n        blanks = [i for i in range(n) if t[i] == '_']\n        nb = len(blanks)\n        \n        for vals in product(range(10), repeat=nb):\n            u = t[:]\n            for i, v in zip(blanks, vals):\n                u[i] = str(v)\n            num_str = ''.join(u)\n            # Check leading zero\n            if n > 1 and num_str[0] == '0':\n                continue\n            if int(num_str) % 25 == 0:\n                count += 1\n    \n    print(count)\n\nsolve()",
