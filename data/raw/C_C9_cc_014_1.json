      "code": "import sys\nfrom collections import defaultdict\n\ninput = sys.stdin.readline\n\ndef solve():\n    n, k = map(int, input().split())\n    mines = []\n    for _ in range(n):\n        x, y, t = map(int, input().split())\n        mines.append((x, y, t))\n    \n    parent = list(range(n))\n    def find(a):\n        while parent[a] != a:\n            parent[a] = parent[parent[a]]\n            a = parent[a]\n        return a\n    def union(a, b):\n        a, b = find(a), find(b)\n        if a != b:\n            parent[a] = b\n    \n    # Group by x\n    by_x = defaultdict(list)\n    for i, (x, y, t) in enumerate(mines):\n        by_x[x].append((y, i))\n    for x, lst in by_x.items():\n        lst.sort()\n        for j in range(1, len(lst)):\n            if lst[j][0] - lst[j-1][0] <= k:\n                union(lst[j][1], lst[j-1][1])\n    \n    # Group by y\n    by_y = defaultdict(list)\n    for i, (x, y, t) in enumerate(mines):\n        by_y[y].append((x, i))\n    for y, lst in by_y.items():\n        lst.sort()\n        for j in range(1, len(lst)):\n            if lst[j][0] - lst[j-1][0] <= k:\n                union(lst[j][1], lst[j-1][1])\n    \n    comp_min = {}\n    for i, (x, y, t) in enumerate(mines):\n        r = find(i)\n        if r not in comp_min:\n            comp_min[r] = t\n        else:\n            comp_min[r] = min(comp_min[r], t)\n    \n    timers = sorted(comp_min.values())\n    \n    # Binary search on T\n    lo, hi = 0, 2 * 10**9\n    while lo < hi:\n        mid = (lo + hi) // 2\n        # count components with min_timer > mid\n        import bisect\n        cnt = len(timers) - bisect.bisect_right(timers, mid)\n        if cnt <= mid + 1:\n            hi = mid\n        else:\n            lo = mid + 1\n    print(lo)\n\nimport bisect\nt = int(input())\nfor _ in range(t):\n    input()  # empty line\n    solve()",
