      "final_code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    n = int(input_data[0])\n    A = list(map(int, input_data[1:n+1]))\n    \n    @lru_cache(maxsize=None)\n    def dp(i, j, last):\n        # returns max moves from this state\n        if i > j:\n            return 0\n        res = 0\n        if A[i] > last:\n            res = max(res, 1 + dp(i+1, j, A[i]))\n        if A[j] > last:\n            res = max(res, 1 + dp(i, j-1, A[j]))\n        return res\n    \n    total = dp(0, n-1, -1)\n    print(\"Alice\" if total % 2 == 1 else \"Bob\")\n\nsolve()",
