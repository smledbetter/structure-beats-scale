      "final_code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    n = int(input_data[0])\n    A = list(map(int, input_data[1:n+1]))\n    \n    # State: (l, r, side)\n    # side=0: last value is A[l-1] if l>0 else -1 (meaning -inf, use -1 since A[i]>=0)\n    # side=1: last value is A[r+1] if r<n-1 else -1\n    # Initial state: l=0, r=n-1, last=-1 (no element taken yet, use special side=2)\n    \n    NEG_INF = -1\n    \n    @lru_cache(maxsize=None)\n    def win(l, r, last):\n        # last is the actual last value (-1 means none)\n        if l > r:\n            return False\n        can_left = A[l] > last\n        can_right = A[r] > last\n        \n        if not can_left and not can_right:\n            return False\n        \n        if can_left and can_right:\n            # current player can choose either\n            # wins if any move makes opponent lose\n            left_result = not win(l+1, r, A[l])\n            if left_result:\n                return True\n            right_result = not win(l, r-1, A[r])\n            return right_result\n        elif can_left:\n            return not win(l+1, r, A[l])\n        else:\n            return not win(l, r-1, A[r])\n    \n    # But last can be any value, making states huge\n    # Instead encode last as boundary index\n    @lru_cache(maxsize=None)  \n    def win2(l, r, last_val):\n        if l > r:\n            return False\n        can_left = A[l] > last_val\n        can_right = A[r] > last_val\n        if not can_left and not can_right:\n            return False\n        if can_left and can_right:\n            if not win2(l+1, r, A[l]):\n                return True\n            return not win2(l, r-1, A[r])\n        elif can_left:\n            return not win2(l+1, r, A[l])\n        else:\n            return not win2(l, r-1, A[r])\n    \n    sys.setrecursionlimit(300000)\n    \n    result = win2(0, n-1, -1)\n    print(\"Alice\" if result else \"Bob\")\n\nsolve()",
