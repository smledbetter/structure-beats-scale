          "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    # dp[(pos, min_coord)] = min max_coord achieved\n    # start: one endpoint at 0, so pos=0, min=0, max=0\n    dp = {(0, 0): 0}\n    \n    for ai in a:\n        ndp = {}\n        for (pos, mn), mx in dp.items():\n            # go right: new pos = pos + ai\n            npos = pos + ai\n            nmn = mn\n            nmx = max(mx, npos)\n            key = (npos, nmn)\n            if key not in ndp or ndp[key] > nmx:\n                ndp[key] = nmx\n            \n            # go left: new pos = pos - ai\n            npos2 = pos - ai\n            nmn2 = min(mn, npos2)\n            nmx2 = mx\n            key2 = (npos2, nmn2)\n            if key2 not in ndp or ndp[key2] > nmx2:\n                ndp[key2] = nmx2\n        \n        # Prune: for same (pos, mn), keep only min mx (already done)\n        # Additional pruning: if two states have same pos and mn1 <= mn2 and mx1 <= mx2,\n        # then state2 is dominated by state1\n        # Group by pos, prune dominated (mn, mx) pairs\n        from collections import defaultdict\n        by_pos = defaultdict(list)\n        for (pos, mn), mx in ndp.items():\n            by_pos[pos].append((mn, mx))\n        \n        pruned = {}\n        for pos, pairs in by_pos.items():\n            # sort by mn ascending, keep only those where mx is non-increasing\n            pairs.sort(key=lambda x: x[0])\n            best_mx = float('inf')\n            for mn, mx in pairs:\n                if mx < best_mx:\n                    best_mx = mx\n                    pruned[(pos, mn)] = mx\n        \n        dp = pruned\n    \n    ans = min(mx - mn for (pos, mn), mx in dp.items())\n    print(ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
