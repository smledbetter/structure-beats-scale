      "code": "import sys\nfrom sys import stdin\n\ndef solve():\n    MOD = 10**9 + 7\n    input_data = stdin.read().split()\n    n = int(input_data[0])\n    a = list(map(int, input_data[1:n+1]))\n    \n    MAX_VAL = max(a) + 1\n    \n    # Compute phi using sieve\n    phi = list(range(MAX_VAL))\n    for i in range(2, MAX_VAL):\n        if phi[i] == i:  # i is prime\n            for j in range(i, MAX_VAL, i):\n                phi[j] -= phi[j] // i\n    \n    # Precompute divisors of each a[i]\n    divs = [[] for _ in range(n)]\n    for i in range(n):\n        x = a[i]\n        d = 1\n        while d * d <= x:\n            if x % d == 0:\n                divs[i].append(d)\n                if d != x // d:\n                    divs[i].append(x // d)\n            d += 1\n    \n    phi_idx = list(range(n+1))\n    for i in range(2, n+1):\n        if phi_idx[i] == i:\n            for j in range(i, n+1, i):\n                phi_idx[j] -= phi_idx[j] // i\n    \n    ans = 0\n    cnt = {}\n    \n    for d2 in range(1, n+1):\n        cnt.clear()\n        for k in range(d2, n+1, d2):\n            i = k - 1  # 0-indexed\n            for d1 in divs[i]:\n                cnt[d1] = cnt.get(d1, 0) + 1\n        ph2 = phi_idx[d2]\n        for d1, c in cnt.items():\n            ans = (ans + phi[d1] * ph2 % MOD * c % MOD * c) % MOD\n    \n    print(ans)\n\nsolve()",
