    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom math import gcd\ninput = sys.stdin.readline\n\ndef solve():\n    n, d = map(int, input().split())\n    a = list(map(int, input().split()))\n    \n    if not any(a):\n        print(0)\n        return\n    \n    cycle_len = n // gcd(n, d)\n    run = [0] * n\n    visited = [False] * n\n    \n    ans = 0\n    \n    for start in range(n):\n        if visited[start]:\n            continue\n        # Collect the cycle\n        cycle = []\n        cur = start\n        while not visited[cur]:\n            visited[cur] = True\n            cycle.append(cur)\n            cur = (cur - d) % n\n        \n        # cycle is the list of nodes in order: start, (start-d)%n, ...\n        # predecessor of cycle[i] is cycle[i+1] (with wrap)\n        # a[cycle[i]] depends on a[cycle[i+1]] (predecessor)\n        \n        m = len(cycle)\n        vals = [a[cycle[i]] for i in range(m)]\n        \n        # Check if all ones\n        if all(v == 1 for v in vals):\n            print(-1)\n            return\n        \n        # Compute run lengths: run[i] = consecutive 1s ending at i going forward in cycle\n        # (predecessor direction means cycle[i+1] is predecessor of cycle[i])\n        # run[i] = run[i+1] + 1 if vals[i] == 1, else 0\n        # We need to handle the circular array with a known zero\n        \n        # Find a position where vals[i] == 0 to break the cycle\n        # Double the array to handle wrap-around\n        runs = [0] * (2 * m)\n        for i in range(2 * m - 1, -1, -1):\n            if vals[i % m] == 1:\n                runs[i] = runs[i + 1] + 1 if i + 1 < 2 * m else 1\n            else:\n                runs[i] = 0\n        \n        # Find a zero position to start from\n        zero_pos = next(i for i in range(m) if vals[i] == 0)\n        # Start from zero_pos, go around once\n        for i in range(m):\n            idx = (zero_pos + i) % m\n            # run length for cycle[idx] is runs[zero_pos + i] but capped at m\n            r = runs[zero_pos + i]\n            if r > m:\n                r = m\n            ans = max(ans, r)\n    \n    print(ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
