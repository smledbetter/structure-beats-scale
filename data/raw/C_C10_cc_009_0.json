      "final_code": "from math import comb\nfrom fractions import Fraction\n\ndef compute_prob(k, N):\n    total = Fraction(0)\n    denom = comb(N, 3)\n    for s in range(0, 4):\n        if s > k or (3 - s) > (N - k):\n            continue\n        ways = comb(k, s) * comb(N - k, 3 - s)\n        # s studied maps (indices 0..s-1), 3-s unstudied (indices s..2)\n        # Johnny's optimal discard: if s < 3, discard index s (unstudied), else discard index 0\n        j_discard = s if s < 3 else 0\n        \n        cond = Fraction(0)\n        for opp in range(3):  # opponent picks uniformly\n            # remaining maps = all except those discarded\n            if opp == j_discard:\n                # same map discarded, 2 maps remain\n                remaining = [i for i in range(3) if i != j_discard]\n            else:\n                # different maps discarded, 1 map remains\n                remaining = [i for i in range(3) if i != j_discard and i != opp]\n            \n            studied_count = sum(1 for i in remaining if i < s)\n            cond += Fraction(studied_count, len(remaining))\n        \n        cond /= 3\n        total += Fraction(ways, denom) * cond\n    return total\n\nN, P_str = input().split()\nN = int(N)\nP = Fraction(P_str).limit_denominator(10000)\n\nfor k in range(0, N + 1):\n    if compute_prob(k, N) >= P:\n        print(k)\n        break",
