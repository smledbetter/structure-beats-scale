      "code": "def solve():\n    import sys\n    input_data = sys.stdin.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    \n    def smallest_geq(n_str, digits):\n        # Find smallest number >= n_str using only digits in `digits` (sorted list), no leading zeros\n        digits = sorted(digits)\n        nonzero_digits = [d for d in digits if d != '0']\n        if not nonzero_digits:\n            return None\n        \n        n = len(n_str)\n        \n        # Try same length first\n        result = try_length(n_str, digits, nonzero_digits)\n        if result is not None:\n            return result\n        \n        # Try length n+1\n        return nonzero_digits[0] + digits[0] * n\n    \n    def try_length(n_str, digits, nonzero_digits):\n        # Try to find smallest number of same length >= n_str\n        n = len(n_str)\n        chosen = []\n        \n        def backtrack(pos, tight):\n            if pos == n:\n                return ''.join(chosen)\n            \n            start_digit = n_str[pos] if tight else '0'\n            available = [d for d in digits if d >= start_digit]\n            if pos == 0:\n                available = [d for d in available if d != '0']\n            \n            for d in available:\n                chosen.append(d)\n                new_tight = tight and (d == n_str[pos])\n                if new_tight:\n                    res = backtrack(pos + 1, True)\n                    if res is not None:\n                        return res\n                else:\n                    # Fill rest with min digit\n                    min_d = digits[0]\n                    return ''.join(chosen) + min_d * (n - pos - 1)\n                chosen.pop()\n            \n            return None\n        \n        return backtrack(0, True)\n    \n    results = []\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        k = int(input_data[idx]); idx += 1\n        n_str = str(n)\n        \n        best = None\n        all_digits = [str(i) for i in range(10)]\n        \n        from itertools import combinations\n        for size in range(1, k+1):\n            for combo in combinations(all_digits, size):\n                digits = list(combo)\n                nonzero = [d for d in digits if d != '0']\n                if not nonzero:\n                    continue\n                res = smallest_geq(n_str, digits)\n                if res is not None:\n                    val = int(res)\n                    if best is None or val < best:\n                        best = val\n        \n        results.append(best)\n    \n    print('\\n'.join(map(str, results)))\n\nsolve()",
