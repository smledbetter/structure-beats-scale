    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    s = input().strip()\n    \n    # We need to find starting position (r, c) such that the robot executes max commands\n    # \n    # For rows and columns independently:\n    # Track prefix sums of vertical and horizontal movements\n    # For rows: U = -1, D = +1\n    # For cols: L = -1, R = +1\n    #\n    # After k commands, row offset = sum of row deltas for first k commands\n    # Starting at row r, after k commands: r + row_offset[k]\n    # Must satisfy: 1 <= r + row_offset[i] <= n for all i in 0..k\n    # i.e., 1 - row_offset[i] <= r <= n - row_offset[i] for all i\n    # i.e., max(1 - row_offset[i]) <= r <= min(n - row_offset[i])\n    # i.e., 1 - min(row_offset[i]) <= r <= n - max(row_offset[i])\n    #\n    # Similarly for columns.\n    #\n    # We want to maximize k (number of commands executed successfully).\n    # Binary search on k: check if valid starting position exists for first k commands.\n    \n    # Precompute prefix sums for rows and cols\n    row_prefix = [0] * (len(s) + 1)\n    col_prefix = [0] * (len(s) + 1)\n    \n    for i, c in enumerate(s):\n        if c == 'U':\n            row_prefix[i+1] = row_prefix[i] - 1\n        elif c == 'D':\n            row_prefix[i+1] = row_prefix[i] + 1\n        elif c == 'L':\n            col_prefix[i+1] = col_prefix[i] - 1\n        elif c == 'R':\n            col_prefix[i+1] = col_prefix[i] + 1\n        else:\n            row_prefix[i+1] = row_prefix[i]\n            col_prefix[i+1] = col_prefix[i]\n    \n    # For k commands (indices 0..k), check feasibility\n    # row: 1 - min(row_prefix[0..k]) <= r <= n - max(row_prefix[0..k])\n    # col: 1 - min(col_prefix[0..k]) <= c <= m - max(col_prefix[0..k])\n    \n    # Precompute prefix min and max\n    row_min = [0] * (len(s) + 1)\n    row_max = [0] * (len(s) + 1)\n    col_min = [0] * (len(s) + 1)\n    col_max = [0] * (len(s) + 1)\n    \n    row_min[0] = row_max[0] = 0\n    col_min[0] = col_max[0] = 0\n    \n    for i in range(1, len(s) + 1):\n        row_min[i] = min(row_min[i-1], row_prefix[i])\n        row_max[i] = max(row_max[i-1], row_prefix[i])\n        col_min[i] = min(col_min[i-1], col_prefix[i])\n        col_max[i] = max(col_max[i-1], col_prefix[i])\n    \n    def feasible(k):\n        # row: r_low <= r <= r_high\n        r_low = 1 - row_min[k]\n        r_high = n - row_max[k]\n        if r_low > r_high:\n            return False, 0, 0\n        # col: c_low <= c <= c_high\n        c_low = 1 - col_min[k]\n        c_high = m - col_max[k]\n        if c_low > c_high:\n            return False, 0, 0\n        return True, r_low, c_low\n    \n    # Binary search for maximum k\n    lo, hi = 0, len(s)\n    best_k = 0\n    best_r, best_c = 1, 1\n    \n    while lo <= hi:\n        mid = (lo + hi) // 2\n        ok, r, c = feasible(mid)\n        if ok:\n            best_k = mid\n            best_r, best_c = r, c\n            lo = mid + 1\n        else:\n            hi = mid - 1\n    \n    print(best_r, best_c)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
