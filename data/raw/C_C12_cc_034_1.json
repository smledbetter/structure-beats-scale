      "final_code": "import sys\nfrom collections import defaultdict\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        a = list(map(int, input_data[idx:idx+n])); idx += n\n        \n        # dp[x] = list of Pareto-optimal (lo, hi) for current position x\n        # lo <= 0, hi >= 0 initially\n        dp = defaultdict(list)\n        dp[0] = [(0, 0)]\n        \n        for d in a:\n            new_dp = defaultdict(list)\n            for x, states in dp.items():\n                for (lo, hi) in states:\n                    # Move right: new position x+d\n                    nx = x + d\n                    nlo = min(lo, x)  # x is already covered, nx=x+d >= x\n                    nhi = max(hi, nx)\n                    new_dp[nx].append((nlo, nhi))\n                    # Move left: new position x-d\n                    nx2 = x - d\n                    nlo2 = min(lo, nx2)\n                    nhi2 = max(hi, x)  # x-d to x, x already in range\n                    new_dp[nx2].append((nlo2, nhi2))\n            # Prune: for each x, keep Pareto-optimal (lo, hi)\n            dp = defaultdict(list)\n            for x, states in new_dp.items():\n                # Sort by lo descending, then keep only those where hi is non-decreasing... \n                # We want max lo and min hi. Sort by lo desc; keep if hi < current min_hi\n                states.sort(key=lambda s: (-s[0], s[1]))\n                pareto = []\n                min_hi = float('inf')\n                for (lo, hi) in states:\n                    if hi < min_hi:\n                        pareto.append((lo, hi))\n                        min_hi = hi\n                dp[x] = pareto\n        \n        ans = float('inf')\n        for x, states in dp.items():\n            for (lo, hi) in states:\n                ans = min(ans, hi - lo)\n        print(ans)\n\nsolve()",
