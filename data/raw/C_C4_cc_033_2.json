ts = dx if dx > 0 else r\n    # col_components = dy if dy > 0 else c\n    \n    row_components = dx if dx > 0 else r\n    col_components = dy if dy > 0 else c\n    rect_components = row_components * col_components\n    \n    # Total free cells = rect_components + (n*m - (2*r*c - grid_overlap))\n    # = rect_components + n*m - 2*r*c + grid_overlap\n    \n    free = rect_components + n * m - 2 * r * c + grid_overlap\n    \n    exponent = free % (MOD - 1)\n    \n    print(pow(k, exponent, MOD))\n\nsolve()",
