    "code": "import sys\nfrom math import isqrt\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    MOD = 10**9 + 7\n    n = int(input_data[0])\n    a = [int(x) for x in input_data[1:n+1]]\n    \n    A = max(a)\n    # Compute phi\n    phi = list(range(A+1))\n    for i in range(2, A+1):\n        if phi[i] == i:  # prime\n            for j in range(i, A+1, i):\n                phi[j] -= phi[j] // i\n    \n    # Precompute divisors of each a[i]\n    divs = [[] for _ in range(n)]\n    for idx in range(n):\n        x = a[idx]\n        for d in range(1, isqrt(x)+1):\n            if x % d == 0:\n                divs[idx].append(d)\n                if d != x // d:\n                    divs[idx].append(x // d)\n    \n    phi_n = [0] * (n+1)\n    for i in range(1, n+1):\n        phi_n[i] = i\n    for i in range(2, n+1):\n        if phi_n[i] == i:\n            for j in range(i, n+1, i):\n                phi_n[j] -= phi_n[j] // i\n    \n    ans = 0\n    f = [0] * (A+1)\n    \n    for d2 in range(1, n+1):\n        # collect indices that are multiples of d2\n        indices = range(d2-1, n, d2)  # 0-indexed: d2, 2*d2, ... -> indices d2-1, 2*d2-1,...\n        touched = []\n        for idx in indices:\n            for d1 in divs[idx]:\n                if f[d1] == 0:\n                    touched.append(d1)\n                f[d1] += 1\n        \n        s = 0\n        for d1 in touched:\n            s += phi[d1] * f[d1] * f[d1]\n            f[d1] = 0\n        \n        ans = (ans + phi_n[d2] * s) % MOD\n    \n    print(ans % MOD)\n\nsolve()",
