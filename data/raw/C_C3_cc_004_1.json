      "code": "import sys\nfrom sys import stdin\n\ndef resolve(v, mapping):\n    path = []\n    while mapping[v] != v:\n        path.append(v)\n        v = mapping[v]\n    for u in path:\n        mapping[u] = v\n    return v\n\ndef main():\n    input = stdin.buffer.read().split()\n    idx = 0\n    q = int(input[idx]); idx += 1\n    \n    MAX = 500001\n    mapping = list(range(MAX))\n    \n    array = []\n    \n    for _ in range(q):\n        t = int(input[idx]); idx += 1\n        if t == 1:\n            x = int(input[idx]); idx += 1\n            array.append(x)\n        else:\n            x = int(input[idx]); idx += 1\n            y = int(input[idx]); idx += 1\n            # replace all x with y\n            # mapping[x] = y means x now points to y\n            mapping[x] = y\n    \n    result = []\n    for v in array:\n        result.append(resolve(v, mapping))\n    \n    print(*result)\n\nmain()",
