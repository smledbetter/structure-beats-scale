    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, k = map(int, input().split())\n    a = list(map(int, input().split()))\n    \n    INF = float('inf')\n    # dp[j][cnt] = min d value, j is 0-indexed position (1-indexed position = j+1)\n    # d[j] = (j+1) - a[j]\n    \n    dp = [[INF] * (k + 1) for _ in range(n)]\n    \n    for j in range(n):\n        pos = j + 1  # 1-indexed\n        d = pos - a[j]\n        if d < 0 or d > pos - 1:\n            continue\n        dp[j][1] = d\n    \n    for cnt in range(2, k + 1):\n        for j in range(n):\n            pos_j = j + 1\n            d_j = pos_j - a[j]\n            if d_j < 0 or d_j > pos_j - 1:\n                continue\n            for i in range(j):\n                pos_i = i + 1\n                d_i = dp[i][cnt - 1]\n                if d_i == INF:\n                    continue\n                if d_j >= d_i and d_j - d_i < pos_j - pos_i:\n                    if d_j < dp[j][cnt]:\n                        dp[j][cnt] = d_j\n    \n    ans = INF\n    for j in range(n):\n        if dp[j][k] < ans:\n            ans = dp[j][k]\n    \n    print(-1 if ans == INF else ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
