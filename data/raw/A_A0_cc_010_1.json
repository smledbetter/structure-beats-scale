    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import deque\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx+=1\n    for _ in range(t):\n        n,m = int(input_data[idx]),int(input_data[idx+1]); idx+=2\n        grid = []\n        lab = None\n        for i in range(n):\n            row = input_data[idx].decode(); idx+=1\n            grid.append(list(row))\n            for j,c in enumerate(row):\n                if c=='L': lab=(i,j)\n        \n        good = [[False]*m for _ in range(n)]\n        deg = [[0]*m for _ in range(n)]\n        bad = [[0]*m for _ in range(n)]\n        dirs = [(-1,0),(1,0),(0,-1),(0,1)]\n        \n        for i in range(n):\n            for j in range(m):\n                if grid[i][j]!='#':\n                    for di,dj in dirs:\n                        ni,nj=i+di,j+dj\n                        if 0<=ni<n and 0<=nj<m and grid[ni][nj]!='#':\n                            deg[i][j]+=1\n        \n        # bad[i][j] = number of non-good free neighbors\n        for i in range(n):\n            for j in range(m):\n                if grid[i][j]!='#':\n                    bad[i][j]=deg[i][j]\n        \n        queue=deque()\n        li,lj=lab\n        good[li][lj]=True\n        queue.append((li,lj))\n        # when cell becomes good, update neighbors\n        while queue:\n            i,j=queue.popleft()\n            for di,dj in dirs:\n                ni,nj=i+di,j+dj\n                if 0<=ni<n and 0<=nj<m and grid[ni][nj]!='#' and not good[ni][nj]:\n                    bad[ni][nj]-=1\n                    d=deg[ni][nj]\n                    b=bad[ni][nj]\n                    if b==0 and d>=1:\n                        good[ni][nj]=True; queue.append((ni,nj))\n                    elif b==1 and d>=2:\n                        good[ni][nj]=True; queue.append((ni,nj))\n        \n        out=[]\n        for i in range(n):\n            row=[]\n            for j in range(m):\n                if grid[i][j]=='.':\n                    row.append('+' if good[i][j] else '.')\n                else:\n                    row.append(grid[i][j])\n            out.append(''.join(row))\n        print('\\n'.join(out))\n\nsolve()",
