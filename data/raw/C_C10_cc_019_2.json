      "final_code": "import sys\nfrom functools import lru_cache\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    @lru_cache(maxsize=None)\n    def dp(l, r):\n        if l == r:\n            return 0\n        # came from l+1,r (a[l] added to front) or l,r-1 (a[r] added to back)\n        # next element to have been added is a[l] or a[r] (whichever was added last = a[l+r] index-wise... \n        # last added index is l+r - (n-1)... \n        # Actually last element added has original index = n-1-(r-l) ... \n        # The last element added is a[l+r-(n-1)+n-1] - let's think: span size = r-l+1, last added = a[r] if from l,r-1 or a[l] if from l+1,r\n        res1 = dp(l+1, r) + sum(1 for x in a[l+1:r+1] if a[l] > x) + sum(1 for x in a[l+1:r+1] if a[l] < x) * 0\n        # a[l] added to front: inversions with all current elements (a[l+1..r])\n        front_inv = sum(1 for x in a[l+1:r+1] if a[l] > x)\n        back_inv = sum(1 for x in a[l:r] if x > a[r])\n        res1 = dp(l+1, r) + front_inv\n        res2 = dp(l, r-1) + back_inv\n        return min(res1, res2)\n    \n    print(dp(0, n-1))\n    dp.cache_clear()\n\nt = int(input())\nfor _ in range(t):\n    solve()",
