    "code": "import sys\nfrom collections import deque\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    results = []\n    for _ in range(t):\n        n, m = int(input_data[idx]), int(input_data[idx+1]); idx += 2\n        grid = []\n        lab = None\n        for i in range(n):\n            row = input_data[idx].decode(); idx += 1\n            grid.append(list(row))\n            for j in range(m):\n                if grid[i][j] == 'L':\n                    lab = (i, j)\n        \n        dr = [0, 1, 0, -1]\n        dc = [1, 0, -1, 0]\n        \n        free_degree = [[0]*m for _ in range(n)]\n        for i in range(n):\n            for j in range(m):\n                if grid[i][j] != '#':\n                    for d in range(4):\n                        ni, nj = i+dr[d], j+dc[d]\n                        if 0 <= ni < n and 0 <= nj < m and grid[ni][nj] != '#':\n                            free_degree[i][j] += 1\n        \n        good = [[False]*m for _ in range(n)]\n        good_count = [[0]*m for _ in range(n)]\n        \n        dq = deque()\n        li, lj = lab\n        good[li][lj] = True\n        dq.append((li, lj))\n        \n        while dq:\n            ci, cj = dq.popleft()\n            for d in range(4):\n                ni, nj = ci+dr[d], cj+dc[d]\n                if 0 <= ni < n and 0 <= nj < m and grid[ni][nj] != '#' and not good[ni][nj]:\n                    good_count[ni][nj] += 1\n                    if free_degree[ni][nj] - good_count[ni][nj] <= 1:\n                        good[ni][nj] = True\n                        dq.append((ni, nj))\n        \n        for i in range(n):\n            for j in range(m):\n                if grid[i][j] == '.' and good[i][j]:\n                    grid[i][j] = '+'\n        \n        results.append('\\n'.join(''.join(r) for r in grid))\n    \n    print('\\n'.join(results))\n\nsolve()",
