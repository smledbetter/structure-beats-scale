    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom math import ceil\ninput = sys.stdin.readline\n\ndef check(h, m, n):\n    h = list(h)\n    for i in range(2, n):\n        # Minimum d needed to bring h[i-2] up to m\n        need = max(0, m - h[i-2])\n        d_min = (need + 1) // 2  # ceil(need/2)\n        if 3 * d_min > h[i]:\n            return False\n        # Maximize d to give as much as possible to h[i-1]\n        d_max = h[i] // 3\n        d = d_max  # use maximum possible d\n        # But we must use at least d_min\n        d = max(d_min, d_max)\n        # d_max >= d_min already since d_max = h[i]//3 >= d_min (we checked 3*d_min <= h[i])\n        h[i-2] += 2 * d\n        h[i-1] += d\n        h[i] -= 3 * d\n    return all(x >= m for x in h)\n\nt = int(input())\nfor _ in range(t):\n    n = int(input())\n    h = list(map(int, input().split()))\n    lo, hi = 0, max(h)\n    while lo < hi:\n        mid = (lo + hi + 1) // 2\n        if check(h, mid, n):\n            lo = mid\n        else:\n            hi = mid - 1\n    print(lo)",
