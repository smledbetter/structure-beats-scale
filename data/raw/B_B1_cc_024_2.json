    "code": "import sys\nfrom collections import defaultdict\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    problems = []\n    cnt_a = defaultdict(int)\n    cnt_b = defaultdict(int)\n    for _ in range(n):\n        a, b = map(int, input().split())\n        problems.append((a, b))\n        cnt_a[a] += 1\n        cnt_b[b] += 1\n    \n    total = n * (n-1) * (n-2) // 6\n    \n    by_topic = defaultdict(list)\n    for a, b in problems:\n        by_topic[a].append(b)\n    \n    bad = 0\n    for a, bs in by_topic.items():\n        m = len(bs)\n        if m < 2:\n            continue\n        # Sum over all pairs (i,j): (cnt_b[bi]-1) + (cnt_b[bj]-1)\n        # = (m-1) * sum_i(cnt_b[bi] - 1)\n        s = sum(cnt_b[b] - 1 for b in bs)\n        bad += (m - 1) * s\n    \n    print(total - bad)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
