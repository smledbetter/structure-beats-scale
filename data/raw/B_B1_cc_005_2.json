    "code": "def solve():\n    s = input().strip()\n    n = len(s)\n    \n    if n == 1:\n        # Only valid if s is '0', 'X' (with xv=0), or '_'\n        count = 0\n        for xv in range(10):\n            t = s.replace('X', str(xv))\n            if t == '_' or t == '0':\n                count += 1\n        # '_' contributes 1 (only '0'), 'X' with xv=0 contributes 1\n        # But we need distinct values? No, count all assignments\n        # Actually recount properly\n        count = 0\n        chars = list(s)\n        for xv in range(10):\n            t = [str(xv) if c == 'X' else c for c in chars]\n            blanks = [i for i in range(n) if t[i] == '_']\n            from itertools import product\n            for vals in product('0123456789', repeat=len(blanks)):\n                u = t[:]\n                for i, v in zip(blanks, vals):\n                    u[i] = v\n                if u[0] == '0':\n                    count += 1\n        if 'X' not in s:\n            count = count  # already computed for xv=0 only effectively\n        # Simplify: just do brute force for n==1\n        count = 0\n        for xv in range(10):\n            t = s.replace('X', str(xv))\n            if '_' in t:\n                for d in '0123456789':\n                    if d == '0':\n                        count += 1\n            else:\n                if t == '0':\n                    count += 1\n        print(count)\n        return\n    \n    has_X = 'X' in s\n    x_range = range(10) if has_X else [None]\n    \n    endings = ['00', '25', '50', '75']\n    count = 0\n    \n    for xv in x_range:\n        t = [str(xv) if c == 'X' else c for c in s] if xv is not None else list(s)\n        \n        for ending in endings:\n            # Check last two positions match ending\n            valid = True\n            for i, e in zip([-2, -1], ending):\n                c = t[n-2+i+2] if i == -2 else t[n-1]\n                pass\n            # Check positions n-2 and n-1\n            for pos, e in [(n-2, ending[0]), (n-1, ending[1])]:\n                c = t[pos]\n                if c != '_' and c != e:\n                    valid = False\n                    break\n            if not valid:\n                continue\n            \n            # Count ways to fill blanks (positions other than n-2, n-1)\n            # First char cannot be 0 if n > 1\n            ways = 1\n            for pos in range(n):\n                if pos == n-2 or pos == n-1:\n                    continue\n                if t[pos] == '_':\n                    if pos == 0:\n                        ways *= 9  # 1-9\n                    else:\n                        ways *= 10\n            # Check if first position is fixed to 0\n            if t[0] != '_' and t[0] == '0' and n > 1:\n                if n == 2:\n                    # both positions are the ending, first is ending[0]\n                    if ending[0] == '0':\n                        ways = 0\n                else:\n                    ways = 0\n            count += ways\n    \n    print(count)\n\nsolve()",
