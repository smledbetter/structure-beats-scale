    "code": "def solve():\n    s = input().strip()\n    n = len(s)\n    count = 0\n    \n    for x_val in range(10):\n        # substitute X\n        t = [c if c != 'X' else str(x_val) for c in s]\n        \n        # enumerate last 1 or 2 positions wildcards\n        # positions: last2 = positions max(0,n-2) to n-1\n        last_positions = list(range(max(0, n-2), n))\n        \n        # enumerate all combos for wildcards in last_positions\n        from itertools import product\n        wildcards_last = [(i, t[i]) for i in last_positions if t[i] == '_']\n        fixed_last = [(i, t[i]) for i in last_positions if t[i] != '_']\n        \n        ranges = [range(10) for _ in wildcards_last]\n        for combo in product(*ranges):\n            tt = t[:]\n            for (i, _), v in zip(wildcards_last, combo):\n                tt[i] = str(v)\n            last_two = int(''.join(tt[max(0,n-2):n]))\n            if last_two % 25 != 0:\n                continue\n            # count valid first and middle\n            # check leading zero: if n==1, allow 0. else first digit != 0\n            first = tt[0]\n            middle_wildcards = sum(1 for i in range(1, max(0,n-2)) if tt[i] == '_')\n            middle_count = 10 ** middle_wildcards\n            if n == 1:\n                count += middle_count\n            else:\n                if first == '_':\n                    count += 9 * middle_count\n                elif first == '0':\n                    pass\n                else:\n                    count += middle_count\n    \n    print(count)\n\nsolve()",
