    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import deque\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n, m = int(input_data[idx]), int(input_data[idx+1]); idx += 2\n        grid = []\n        lab = None\n        for i in range(n):\n            row = input_data[idx].decode(); idx += 1\n            grid.append(list(row))\n            for j in range(m):\n                if grid[i][j] == 'L':\n                    lab = (i, j)\n        \n        dr = [0, 1, 0, -1]\n        dc = [1, 0, -1, 0]\n        \n        # For each free cell, count the number of free neighbors\n        # A cell is \"forceable\" if it has at most 1 free neighbor (degree <= 1)\n        # because then we can command the one direction that's free (or any direction if 0 free neighbors)\n        # and the robot has no valid alternative direction\n        \n        # Actually the logic:\n        # The robot receives a command direction d, and must move in some direction != d\n        # that is not blocked. If no such direction exists, it stays.\n        # We want to force the robot to the lab.\n        \n        # A cell is \"good\" (forceable) if:\n        # - It is the lab itself, OR\n        # - It has at most 1 free neighbor that is NOT good\n        #   (i.e., all free neighbors except possibly one are good)\n        #   Wait, let me think more carefully.\n        \n        # Key insight: A cell c can be forced if we can send a command such that\n        # ALL possible moves the robot can make lead to forceable cells.\n        # The robot moves in any direction != commanded direction that is free.\n        # So if we command direction d, the robot moves in any free direction except d.\n        # We want all free directions except d to be forceable cells.\n        # So we need: there exists a direction d such that all free neighbors of c\n        # except possibly the one in direction d are forceable.\n        # This means: the number of non-forceable free neighbors <= 1\n        # (we can \"block\" one by commanding that direction)\n        \n        # BFS: start with lab, then iteratively add cells whose\n        # number of non-forceable free neighbors <= 1\n        \n        # Count free neighbors for each cell\n        free_neighbors = [[0]*m for _ in range(n)]\n        for i in range(n):\n            for j in range(m):\n                if grid[i][j] == '#':\n                    continue\n                cnt = 0\n                for d in range(4):\n                    ni, nj = i + dr[d], j + dc[d]\n                    if 0 <= ni < n and 0 <= nj < m and grid[ni][nj] != '#':\n                        cnt += 1\n                free_neighbors[i][j] = cnt\n        \n        # forceable[i][j] = True if cell can be forced to reach lab\n        forceable = [[False]*m for _ in range(n)]\n        \n        # For each cell, track how many non-forceable free neighbors it has\n        # Initially all free neighbors are non-forceable\n        # non_forceable_count[i][j] = number of free neighbors that are not yet forceable\n        non_forceable_count = [row[:] for row in free_neighbors]\n        \n        queue = deque()\n        li, lj = lab\n        forceable[li][lj] = True\n        queue.append((li, lj))\n        \n        while queue:\n            ci, cj = queue.popleft()\n            # ci, cj just became forceable\n            # Update all free neighbors of ci, cj\n            for d in range(4):\n                ni, nj = ci + dr[d], cj + dc[d]\n                if 0 <= ni < n and 0 <= nj < m and grid[ni][nj] != '#':\n                    if not forceable[ni][nj]:\n                        non_forceable_count[ni][nj] -= 1\n                        if non_forceable_count[ni][nj] <= 1:\n                            forceable[ni][nj] = True\n                            queue.append((ni, nj))\n        \n        # Mark forceable cells (that are '.' not 'L') with '+'\n        for i in range(n):\n            for j in range(m):\n                if forceable[i][j] and grid[i][j] == '.':\n                    grid[i][j] = '+'\n        \n        print('\\n'.join(''.join(r) for r in grid))\n\nsolve()",
