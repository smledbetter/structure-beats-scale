          "code": "import sys\ninput = sys.stdin.readline\n\ndef solve(n, m):\n    if n > m:\n        return 0\n    \n    # Find minimum y = z XOR n, where z > m\n    # Equivalently, find z > m minimizing z XOR n\n    \n    # Greedy from highest bit\n    # We want z > m, minimize z^n\n    # Try bit by bit from high to low\n    \n    bits = 30\n    \n    # Try each bit: set z bit = n bit (XOR = 0) if possible\n    # \"possible\" means we can still achieve z > m\n    \n    result = None\n    # We'll try: for each prefix where z matches some pattern,\n    # find minimum XOR\n    \n    # Standard approach: iterate over the bit where z first exceeds m\n    best = float('inf')\n    \n    for bit in range(bits, -1, -1):\n        # Force z > m by having z[bit] > m[bit] at position `bit`,\n        # with higher bits equal to m's bits\n        if not (m >> bit & 1):  # m's bit is 0, set z's bit to 1\n            # Higher bits of z = higher bits of m\n            z_high = m & ~((1 << (bit+1)) - 1)  # bits above `bit` same as m... \n            # Actually: z agrees with m on bits above `bit`, z[bit]=1, lower bits free\n            z_prefix = (m & ~((1 << (bit+1)) - 1)) | (1 << bit)\n            # Lower bits: choose to minimize z^n, set lower bits of z = lower bits of n\n            z_lower = n & ((1 << bit) - 1)\n            z = z_prefix | z_lower\n            val = z ^ n\n            if val < best:\n                best = val\n    \n    return best\n\nt = int(input())\nfor _ in range(t):\n    n, m = map(int, input().split())\n    print(solve(n, m))",
