    "code": "import sys\nfrom itertools import product\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n, m = int(input_data[idx]), int(input_data[idx+1]); idx += 2\n        x = [int(input_data[idx+i]) for i in range(n)]; idx += n\n        s = []\n        for i in range(n):\n            s.append(input_data[idx].decode()); idx += 1\n        \n        # s[i][j] = '1' if student i answered question j correctly\n        # For each question j, compute column vector\n        \n        best_val = -1\n        best_perm = None\n        \n        for mask in range(1 << n):\n            # sigma[i] = +1 if bit i set, -1 otherwise\n            sigma = [1 if (mask >> i) & 1 else -1 for i in range(n)]\n            \n            # w[j] = sum_i sigma[i] * s[i][j]\n            w = [0] * m\n            for i in range(n):\n                si = s[i]\n                sg = sigma[i]\n                for j in range(m):\n                    if si[j] == '1':\n                        w[j] += sg\n            \n            # Sort questions by w[j], assign value k+1 to question with k-th smallest w\n            order = sorted(range(m), key=lambda j: w[j])\n            p = [0] * m\n            for rank, j in enumerate(order):\n                p[j] = rank + 1\n            \n            # Compute r_i\n            r = [0] * n\n            for i in range(n):\n                si = s[i]\n                for j in range(m):\n                    if si[j] == '1':\n                        r[i] += p[j]\n            \n            val = sum(abs(x[i] - r[i]) for i in range(n))\n            if val > best_val:\n                best_val = val\n                best_perm = p[:]\n        \n        print(*best_perm)\n\nsolve()",
