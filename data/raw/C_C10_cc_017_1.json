      "code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    MOD = 998244353\n    input_data = sys.stdin.read().split()\n    n, k = int(input_data[0]), int(input_data[1])\n    s = input_data[2]\n    \n    # Precompute prefix sums of ones\n    prefix = [0] * (n + 1)\n    for i in range(n):\n        prefix[i+1] = prefix[i] + int(s[i])\n    \n    # Precompute binomial coefficients\n    max_n = n + 5\n    C = [[0] * (max_n) for _ in range(max_n)]\n    C[0][0] = 1\n    for i in range(1, max_n):\n        C[i][0] = 1\n        for j in range(1, max_n):\n            C[i][j] = (C[i-1][j-1] + C[i-1][j]) % MOD\n    \n    def comb(n, r):\n        if r < 0 or r > n or n < 0:\n            return 0\n        return C[n][r]\n    \n    ans = 1  # for s itself\n    \n    for l in range(n):\n        for r in range(l, n):\n            ones_in_range = prefix[r+1] - prefix[l]\n            if ones_in_range != k:\n                continue\n            \n            length = r - l + 1\n            sl = int(s[l])\n            sr = int(s[r])\n            \n            total = comb(length, k)\n            a = comb(length - 1, k - sl)\n            b = comb(length - 1, k - sr)\n            ab = comb(length - 2, k - sl - sr)\n            \n            f = (total - a - b + ab) % MOD\n            ans = (ans + f) % MOD\n    \n    print(ans % MOD)\n\nsolve()",
