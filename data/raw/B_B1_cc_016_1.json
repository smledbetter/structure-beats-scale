    "model": "claude-sonnet-4-6",
    "code": "import math\n\ndef min_coins_needed(c1, c2, a):\n    # For given c1, c2, find minimum c3 needed to cover all amounts in a\n    max_c3 = 0\n    for x in a:\n        best = float('inf')\n        for x1 in range(c1 + 1):\n            for x2 in range(c2 + 1):\n                rem = x - x1 - 2 * x2\n                if rem < 0:\n                    continue\n                # need ceil(rem / 3) coins of 3\n                c3_needed = math.ceil(rem / 3)\n                best = min(best, c3_needed)\n        if best == float('inf'):\n            return float('inf')\n        max_c3 = max(max_c3, best)\n    return max_c3\n\nt = int(input())\nfor _ in range(t):\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    ans = float('inf')\n    for c1 in range(3):\n        for c2 in range(3):\n            c3 = min_coins_needed(c1, c2, a)\n            total = c1 + c2 + c3\n            ans = min(ans, total)\n    \n    print(ans)",
