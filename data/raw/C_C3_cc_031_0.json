      "code": "import sys\nfrom collections import defaultdict\n\ndef solve():\n    MOD = 10**9 + 7\n    input_data = sys.stdin.buffer.read().split()\n    n = int(input_data[0])\n    a = [int(x) for x in input_data[1:n+1]]\n    \n    MAX = 10**5 + 1\n    phi = list(range(MAX))\n    for i in range(2, MAX):\n        if phi[i] == i:  # i is prime\n            for j in range(i, MAX, i):\n                phi[j] -= phi[j] // i\n    \n    # For each d1, d2: f[d1][d2] = count of indices i (1-indexed) where d2|i and d1|a[i]\n    # Answer = sum over d1,d2 of phi[d1]*phi[d2]*f[d1][d2]^2\n    \n    ans = 0\n    \n    # cnt[d1] for fixed d2: number of multiples of d2 where d1 | a[i]\n    for d2 in range(1, n+1):\n        cnt = defaultdict(int)\n        for k in range(d2, n+1, d2):\n            val = a[k-1]\n            # find all divisors of val\n            d = 1\n            while d * d <= val:\n                if val % d == 0:\n                    cnt[d] += 1\n                    if d != val // d:\n                        cnt[val // d] += 1\n                d += 1\n        ph2 = phi[d2]\n        for d1, c in cnt.items():\n            ans = (ans + ph2 * phi[d1] % MOD * (c * c % MOD)) % MOD\n    \n    print(ans)\n\nsolve()",
