    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    n = int(input_data[0])\n    A = list(map(int, input_data[1:n+1]))\n    \n    sys.setrecursionlimit(300000)\n    \n    # State: (l, r, last) but last is always A[l-1] or A[r+1] or -1\n    # Encode: last_side: 0 = initial(-1), 1 = left side (A[l-1]), 2 = right side (A[r+1])\n    \n    @lru_cache(maxsize=None)\n    def wins(l, r, last):\n        if l > r:\n            return False\n        can_left = A[l] > last\n        can_right = A[r] > last\n        if not can_left and not can_right:\n            return False\n        if can_left and not wins(l+1, r, A[l]):\n            return True\n        if can_right and not wins(l, r-1, A[r]):\n            return True\n        return False\n    \n    # For large n, use iterative approach with the observation that\n    # last is always A[l-1] or A[r+1]\n    # Represent last as index: -1 means sentinel\n    A_ext = [-1] + A + [-1]  # 1-indexed, A_ext[i+1] = A[i]\n    \n    result = wins(0, n-1, -1)\n    print(\"Alice\" if result else \"Bob\")\n\nsolve()",
