    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom bisect import bisect_left, bisect_right, insort\ninput = sys.stdin.readline\n\ndef count_greater(sorted_list, val):\n    return len(sorted_list) - bisect_right(sorted_list, val)\n\ndef count_less(sorted_list, val):\n    return bisect_left(sorted_list, val)\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    INF = float('inf')\n    # dp[l][r] = min inversions, deque has a[l..r], a[l] at front, a[r] at back\n    dp = [[INF]*n for _ in range(n)]\n    \n    # Initialize: single elements\n    for i in range(n):\n        dp[i][i] = 0\n    \n    sorted_window = []\n    \n    from functools import lru_cache\n    \n    memo = {}\n    \n    def rec(l, r):\n        if (l,r) in memo:\n            return memo[(l,r)]\n        if l == r:\n            memo[(l,r)] = 0\n            return 0\n        # came from (l+1, r) by adding a[l] to front, or (l, r-1) by adding a[r] to back\n        # sorted elements in a[l+1..r]\n        sub1 = sorted(a[l+1:r+1])\n        cost1 = rec(l+1, r) + count_greater(sub1, a[l])  # a[l] at front, inversions with elements after it\n        \n        sub2 = sorted(a[l:r])\n        cost2 = rec(l, r-1) + count_less(sub2, a[r])  # a[r] at back, inversions with elements before it\n        \n        memo[(l,r)] = min(cost1, cost2)\n        return memo[(l,r)]\n    \n    print(rec(0, n-1))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
