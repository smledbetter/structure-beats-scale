      "final_code": "def min_with_digits(n_str, digits):\n    # digits is sorted list, may include 0\n    n = len(n_str)\n    result = []\n    \n    def solve(pos, tight):\n        if pos == n:\n            return result[:]\n        \n        lo = int(n_str[pos]) if tight else 0\n        # avoid leading zero\n        if pos == 0:\n            lo = max(lo, 1) if 0 in digits else lo\n            # actually first digit must be >= 1\n            valid_digits = [d for d in digits if d >= lo and (pos > 0 or d >= 1)]\n        else:\n            valid_digits = [d for d in digits if d >= lo]\n        \n        for d in valid_digits:\n            result.append(d)\n            new_tight = tight and (d == int(n_str[pos]))\n            if new_tight:\n                res = solve(pos + 1, True)\n                if res is not None:\n                    return res\n            else:\n                # fill rest with min digit\n                min_d = digits[0] if pos + 1 < n else None\n                rest = [digits[0]] * (n - pos - 1)\n                return result + rest\n            result.pop()\n        \n        return None\n    \n    res = solve(0, True)\n    if res:\n        return int(''.join(map(str, res)))\n    # need longer number\n    # smallest (n+1)-digit number using digits\n    first = min(d for d in digits if d >= 1)\n    return int(str(first) + str(digits[0]) * n)",
