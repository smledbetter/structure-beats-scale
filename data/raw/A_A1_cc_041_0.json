    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import defaultdict\nfrom bisect import bisect_left, insort\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    results = []\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        dishes = []\n        for i in range(n):\n            a, b, m = int(input_data[idx]), int(input_data[idx+1]), int(input_data[idx+2]); idx += 3\n            S = a + b - m\n            lo = max(0, a - m)\n            hi = min(a, S)\n            dishes.append((a, b, m, S, lo, hi))\n        \n        chosen_f = [0] * n\n        \n        groups = defaultdict(list)\n        for i, (a, b, m, S, lo, hi) in enumerate(dishes):\n            groups[S].append((lo, hi, i))\n        \n        for S, intervals in groups.items():\n            # Sort by right endpoint for greedy minimum stabbing\n            intervals.sort(key=lambda x: x[1])\n            pts = []  # sorted list of chosen points\n            \n            for lo, hi, i in intervals:\n                # Binary search for a point in [lo, hi]\n                # Find leftmost point >= lo\n                pos = bisect_left(pts, lo)\n                if pos < len(pts) and pts[pos] <= hi:\n                    # Found a point in [lo, hi]\n                    chosen_f[i] = pts[pos]\n                else:\n                    # No point in range, add hi (greedy: rightmost of current interval)\n                    chosen_f[i] = hi\n                    insort(pts, hi)\n        \n        variety = len(set((chosen_f[i], dishes[i][3] - chosen_f[i]) for i in range(n)))\n        out = [str(variety)]\n        for i in range(n):\n            a, b, m, S, lo, hi = dishes[i]\n            f = chosen_f[i]\n            x = a - f  # fish eaten\n            y = m - x  # meat eaten\n            out.append(f\"{x} {y}\")\n        results.append('\\n'.join(out))\n    \n    print('\\n\\n'.join(results))\n\nsolve()",
