          "model": "claude-sonnet-4-6",
          "code": "import sys\nfrom functools import lru_cache\n\ndef solve():\n    MOD = 998244353\n    n, x = map(int, input().split())\n    \n    # Precompute combinations\n    C = [[0]*(n+1) for _ in range(n+1)]\n    C[0][0] = 1\n    for i in range(1, n+1):\n        C[i][0] = 1\n        for j in range(1, i+1):\n            C[i][j] = (C[i-1][j-1] + C[i-1][j]) % MOD\n    \n    @lru_cache(maxsize=None)\n    def dp(remaining, damage):\n        # Count ways for 'remaining' heroes with health in [damage+1, x]\n        # such that no winner\n        if remaining == 0:\n            return 1\n        \n        total = 0\n        # Choose k heroes to die in the next round (health in [damage+1, damage+remaining-1])\n        # k can be 0 to remaining, but k != remaining-1 (would leave exactly 1 survivor)\n        # Also need damage+remaining-1 <= x for any to die in this range\n        # k=0 means no one dies this round - impossible since someone always dies eventually\n        # Actually k=remaining means all die together - valid\n        \n        max_k = min(remaining, x - damage)  # can't exceed available health values\n        \n        for k in range(1, remaining + 1):\n            if k == remaining - 1:\n                continue  # would leave exactly 1 winner\n            # k heroes choose health from [damage+1, damage+remaining-1]\n            # number of values available: remaining-1\n            avail = remaining - 1\n            if k > avail and k < remaining:\n                continue\n            if k == remaining:\n                # all die: each picks from [damage+1, x], but must be <= damage+remaining-1\n                ways_k = pow(min(remaining-1, x-damage), remaining, MOD)\n                if x - damage < 1:\n                    ways_k = 0\n                ways_k = pow(min(remaining-1, x-damage), remaining, MOD)\n            else:\n                if avail <= 0 or damage + avail > x:\n                    avail = min(avail, x - damage)\n                avail = min(remaining-1, x-damage)\n                if avail <= 0:\n                    break\n                ways_k = C[remaining][k] * pow(avail, k, MOD) % MOD\n                new_damage = damage + remaining - 1\n                ways_k = ways_k * dp(remaining - k, new_damage) % MOD\n            total = (total + ways_k) % MOD\n        \n        return total\n    \n    print(dp(n, 0))\n\nsolve()",
