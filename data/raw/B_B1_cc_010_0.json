    "code": "import sys\nfrom collections import deque\n\ninput_data = sys.stdin.buffer.read().split()\nidx = 0\n\ndef solve():\n    global idx\n    n = int(input_data[idx]); m = int(input_data[idx+1]); idx += 2\n    \n    grid = []\n    lab_r = lab_c = 0\n    for i in range(n):\n        row = input_data[idx].decode(); idx += 1\n        grid.append(list(row))\n        for j in range(len(row)):\n            if row[j] == 'L':\n                lab_r, lab_c = i, j\n    \n    dirs = [(0,1),(0,-1),(1,0),(-1,0)]\n    \n    # free_degree[i][j] = number of free (non-blocked) neighbors\n    # non_forceable[i][j] = number of free neighbors not yet forceable\n    # forceable[i][j] = bool\n    \n    free_degree = [[0]*m for _ in range(n)]\n    non_forceable = [[0]*m for _ in range(n)]\n    forceable = [[False]*m for _ in range(n)]\n    \n    for i in range(n):\n        for j in range(m):\n            if grid[i][j] == '#':\n                continue\n            cnt = 0\n            for dr, dc in dirs:\n                ni, nj = i+dr, j+dc\n                if 0 <= ni < n and 0 <= nj < m and grid[ni][nj] != '#':\n                    cnt += 1\n            free_degree[i][j] = cnt\n            non_forceable[i][j] = cnt\n    \n    queue = deque()\n    \n    # Lab is forceable\n    forceable[lab_r][lab_c] = True\n    queue.append((lab_r, lab_c))\n    \n    # When a cell becomes forceable, decrement non_forceable count of its neighbors\n    # If neighbor's non_forceable count drops to <= 1, it becomes forceable\n    \n    while queue:\n        r, c = queue.popleft()\n        for dr, dc in dirs:\n            nr, nc = r+dr, c+dc\n            if 0 <= nr < n and 0 <= nc < m and grid[nr][nc] != '#' and not forceable[nr][nc]:\n                non_forceable[nr][nc] -= 1\n                if non_forceable[nr][nc] <= 1:\n                    forceable[nr][nc] = True\n                    queue.append((nr, nc))\n    \n    result = []\n    for i in range(n):\n        row = []\n        for j in range(m):\n            if grid[i][j] == '.':\n                if forceable[i][j]:\n                    row.append('+')\n                else:\n                    row.append('.')\n            else:\n                row.append(grid[i][j])\n        result.append(''.join(row))\n    \n    print('\\n'.join(result))\n\nt = int(input_data[idx]); idx += 1\nfor _ in range(t):\n    solve()",
