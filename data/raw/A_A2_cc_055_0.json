    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve(n, m):\n    if n > m:\n        return 0\n    L = m + 1\n    best = float('inf')\n    bits = 30\n    for i in range(bits, -1, -1):\n        prefix_L = L >> (i+1) << (i+1)  # upper bits of L (above bit i)\n        bit_L = (L >> i) & 1\n        # set bit i of p to be > bit_L (i.e., 1 when bit_L=0)\n        if bit_L == 0:\n            p_candidate = prefix_L | (1 << i) | (n & ((1 << i) - 1))\n            best = min(best, n ^ p_candidate)\n    # also check p = L itself\n    best = min(best, n ^ L)\n    return best\n\ndef main():\n    t = int(input())\n    out = []\n    for _ in range(t):\n        n, m = map(int, input().split())\n        out.append(str(solve(n, m)))\n    print('\\n'.join(out))\n\nmain()",
