      "final_code": "import sys\nfrom collections import deque\n\ndef solve():\n    data = sys.stdin.buffer.read().split()\n    idx = 0\n    n, m = int(data[idx]), int(data[idx+1]); idx+=2\n    adj = [[] for _ in range(n+1)]\n    for _ in range(m):\n        u, v = int(data[idx]), int(data[idx+1]); idx+=2\n        adj[u].append(v); adj[v].append(u)\n    q = int(data[idx]); idx+=1\n    queries = []\n    for _ in range(q):\n        a, b = int(data[idx]), int(data[idx+1]); idx+=2\n        queries.append((a,b))\n    # BFS spanning tree\n    parent = [0]*(n+1); depth = [0]*(n+1); visited = [False]*(n+1)\n    visited[1]=True; queue=deque([1])\n    order=[]\n    while queue:\n        u=queue.popleft(); order.append(u)\n        for v in adj[u]:\n            if not visited[v]:\n                visited[v]=True; parent[v]=u; depth[v]=depth[u]+1; queue.append(v)\n    # parity count per node (subtree edge parity)\n    parity=[0]*(n+1)\n    for a,b in queries:\n        parity[a]^=1; parity[b]^=1\n    # propagate up\n    for u in reversed(order):\n        if parent[u]: parity[parent[u]]^=parity[u]\n    odd=sum(1 for i in range(2,n+1) if parity[i])\n    # LCA path\n    LOG=19\n    up=[[0]*(n+1) for _ in range(LOG)]\n    up[0]=parent[:]\n    up[0][1]=1\n    for k in range(1,LOG):\n        for v in range(1,n+1):\n            up[k][v]=up[k-1][up[k-1][v]]\n    def lca(u,v):\n        if depth[u]<depth[v]: u,v=v,u\n        diff=depth[u]-depth[v]\n        for k in range(LOG):\n            if (diff>>k)&1: u=up[k][u]\n        if u==v: return u\n        for k in range(LOG-1,-1,-1):\n            if up[k][u]!=up[k][v]: u=up[k][u];v=up[k][v]\n        return up[0][u]\n    def get_path(a,b):\n        l=lca(a,b)\n        pa,pb=[],[]\n        u=a\n        while u!=l: pa.append(u);u=parent[u]\n        pa.append(l)\n        u=b\n        while u!=l: pb.append(u);u=parent[u]\n        return pa+pb[::-1]\n    out=[]\n    if odd==0:\n        out.append(\"YES\")\n        for a,b in queries:\n            path=get_path(a,b)\n            out.append(str(len(path)))\n            out.append(' '.join(map(str,path)))\n    else:\n        out.append(\"NO\")\n        out.append(str(odd//2))\n    print('\\n'.join(out))\n\nsolve()",
