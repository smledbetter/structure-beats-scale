      "final_code": "import sys\nfrom bisect import bisect_right\n\ninput_data = sys.stdin.buffer.read().split()\nidx = 0\n\nt = int(input_data[idx]); idx += 1\nfor _ in range(t):\n    n, m, k = int(input_data[idx]), int(input_data[idx+1]), int(input_data[idx+2]); idx += 3\n    x_list = []\n    for i in range(n):\n        x_list.append(int(input_data[idx])); idx += 1\n    y_list = []\n    for i in range(m):\n        y_list.append(int(input_data[idx])); idx += 1\n    \n    xs = set(x_list)\n    ys = set(y_list)\n    \n    vert_x_count = {}   # x -> count of only-vertical persons\n    vert_yb_count = {}  # y_interval -> count of only-vertical persons\n    vert_xb_count = {}  # (x, y_interval) -> count\n    \n    horiz_y_count = {}\n    horiz_xb_count = {}\n    horiz_yb_count = {}\n    \n    for p in range(k):\n        xp, yp = int(input_data[idx]), int(input_data[idx+1]); idx += 2\n        on_v = xp in xs\n        on_h = yp in ys\n        if on_v and not on_h:\n            yb = bisect_right(y_list, yp) - 1\n            vert_x_count[xp] = vert_x_count.get(xp, 0) + 1\n            vert_yb_count[yb] = vert_yb_count.get(yb, 0) + 1\n            vert_xb_count[(xp, yb)] = vert_xb_count.get((xp, yb), 0) + 1\n        elif on_h and not on_v:\n            xb = bisect_right(x_list, xp) - 1\n            horiz_y_count[yp] = horiz_y_count.get(yp, 0) + 1\n            horiz_xb_count[xb] = horiz_xb_count.get(xb, 0) + 1\n            horiz_yb_count[(yp, xb)] = horiz_yb_count.get((yp, xb), 0) + 1\n    \n    def calc(total_count, line_count, band_count, both_count):\n        tv = sum(total_count.values())\n        ans = tv*(tv-1)//2\n        ans -= sum(v*(v-1)//2 for v in line_count.values())\n        ans -= sum(v*(v-1)//2 for v in band_count.values())\n        ans += sum(v*(v-1)//2 for v in both_count.values())\n        return ans\n    \n    ans = calc(vert_x_count, vert_x_count, vert_yb_count, vert_xb_count)\n    ans += calc(horiz_y_count, horiz_y_count, horiz_xb_count, horiz_yb_count)\n    print(ans)",
