      "code": "from math import comb\nfrom fractions import Fraction\n\ndef compute_prob(k, N):\n    # probability of playing a studied map\n    total = Fraction(0)\n    denom = comb(N, 3)\n    for s in range(0, 4):\n        if s > k or (3-s) > (N-k):\n            continue\n        ways = comb(k, s) * comb(N-k, 3-s)\n        # Given s studied, 3-s unstudied in the shown maps\n        # Johnny discards one unstudied if s<3, else discards one studied\n        # Opponent picks uniformly from 3\n        # compute prob of studied map being played\n        cond = Fraction(0)\n        for opp in range(3):  # opponent picks map index 0,1,2\n            # maps: first s are studied, last 3-s are unstudied\n            # Johnny discards: if s<3, discard map s (first unstudied), else discard map 0\n            j_discard = s if s < 3 else 0\n            remaining = [i for i in range(3) if i != j_discard and i != opp]\n            if not remaining:\n                remaining = [i for i in range(3) if i != j_discard or i == opp]\n                # Actually if j_discard == opp, remaining = all except j_discard\n                remaining = [i for i in range(3) if i != j_discard]\n            studied_count = sum(1 for i in remaining if i < s)\n            cond += Fraction(studied_count, len(remaining))\n        cond /= 3\n        total += Fraction(ways, denom) * cond\n    return total\n\nfrom fractions import Fraction\nN, P_str = input().split()\nN = int(N)\nP = Fraction(P_str).limit_denominator(10000)\n\nfor k in range(0, N+1):\n    if compute_prob(k, N) >= P:\n        print(k)\n        break",
