    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import deque\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    grid = []\n    lab = None\n    for i in range(n):\n        row = list(input().strip())\n        grid.append(row)\n        for j in range(len(row)):\n            if row[j] == 'L':\n                lab = (i, j)\n    \n    # For each free cell, count the number of free neighbors\n    # A cell is \"forceable\" if the robot can be forced to reach the lab\n    # \n    # Key insight: A cell is good if the number of free neighbors <= 1\n    # (meaning the robot has at most 1 choice of direction, so we can always\n    # send a command that blocks all other options)\n    # More precisely: a cell is good if (free_neighbors - 1) <= 0, i.e., free_neighbors <= 1\n    # Wait, let's think again.\n    #\n    # The robot chooses any direction DIFFERENT from the command, as long as it's not blocked.\n    # So if a cell has k free neighbors, and we send command X:\n    # - The robot can move to any free neighbor except in direction X\n    # - So the robot has (free_neighbors - (1 if direction X is free else 0)) choices\n    # \n    # We want: no matter what the robot does, it ends up in a good cell.\n    # A cell is \"safe\" (can be forced to lab) if:\n    # - It's the lab itself, OR\n    # - There exists a command such that ALL possible moves the robot can make lead to safe cells\n    #   AND the robot must make a move (i.e., there's at least one valid direction != command)\n    #\n    # The robot does nothing if there's no valid direction != command.\n    # So we need to be careful: we need the robot to eventually reach the lab.\n    #\n    # BFS/BFS approach:\n    # A cell is \"good\" if:\n    # 1. It's the lab, OR\n    # 2. The number of free neighbors that are NOT good is <= 1\n    #    (because we can send the command in the direction of that one bad neighbor,\n    #     forcing the robot to choose among good neighbors only)\n    #    But we also need the robot to have at least one valid move.\n    #\n    # More precisely: cell (i,j) is good if there exists a direction d such that:\n    # - Every free neighbor of (i,j) in direction != d is good\n    # - There is at least one free neighbor in direction != d (so robot moves)\n    #\n    # Equivalently: the number of free neighbors that are \"not good\" is <= 1\n    # (send command toward the bad neighbor; all other moves go to good cells)\n    # AND total free neighbors >= 1 (so robot has somewhere to go... wait)\n    # Actually if all free neighbors are good, send any command toward a non-free direction\n    # and robot must move to a good neighbor.\n    # If exactly 1 free neighbor is bad, send command in that direction, robot moves to good ones.\n    # But we need at least 1 good neighbor for the robot to move to.\n    \n    dirs = [(-1,0),(1,0),(0,-1),(0,1)]\n    \n    def free(i, j):\n        return 0 <= i < n and 0 <= j < m and grid[i][j] != '#'\n    \n    # Count free neighbors for each cell\n    free_neighbors = [[0]*m for _ in range(n)]\n    for i in range(n):\n        for j in range(m):\n            if grid[i][j] != '#':\n                cnt = 0\n                for di, dj in dirs:\n                    ni, nj = i+di, j+dj\n                    if free(ni, nj):\n                        cnt += 1\n                free_neighbors[i][j] = cnt\n    \n    # good[i][j] = True if cell is forceable\n    good = [[False]*m for _ in range(n)]\n    # bad_free_neighbors[i][j] = number of free neighbors that are not good\n    bad_free = [[0]*m for _ in range(n)]\n    for i in range(n):\n        for j in range(m):\n            if grid[i][j] != '#':\n                bad_free[i][j] = free_neighbors[i][j]\n    \n    queue = deque()\n    li, lj = lab\n    good[li][lj] = True\n    queue.append((li, lj))\n    \n    while queue:\n        i, j = queue.popleft()\n        # (i,j) just became good, update neighbors\n        for di, dj in dirs:\n            ni, nj = i+di, j+dj\n            if 0 <= ni < n and 0 <= nj < m and grid[ni][nj] != '#' and not good[ni][nj]:\n                bad_free[ni][nj] -= 1\n                # Check if (ni, nj) can now be good\n                # It's good if bad_free[ni][nj] <= 1 AND free_neighbors[ni][nj] - (1 if bad==1 else 0) >= 1\n                # Simplified: bad_free <= 1 and free_neighbors >= 1 (free_neighbors >= 1 always if cell is free and has neighbors)\n                # Actually need: there's at least one good neighbor to move to\n                # good_neighbors = free_neighbors[ni][nj] - bad_free[ni][nj]\n                good_neighbors = free_neighbors[ni][nj] - bad_free[ni][nj]\n                if bad_free[ni][nj] <= 1 and good_neighbors >= 1:\n                    good[ni][nj] = True\n                    queue.append((ni, nj))\n    \n    result = []\n    for i in range(n):\n        row = []\n        for j in range(m):\n            if grid[i][j] == '.' and good[i][j]:\n                row.append('+')\n            else:\n                row.append(grid[i][j])\n        result.append(''.join(row))\n    print('\\n'.join(result))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
