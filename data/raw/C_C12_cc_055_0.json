      "final_code": "import sys\ninput = sys.stdin.readline\n\ndef solve(n, m):\n    if n > m:\n        return 0\n    L = m + 1\n    best = n ^ L  # p = L is always valid (p >= L)\n    bits = 30\n    for i in range(bits, -1, -1):\n        prefix_L = (L >> (i+1)) << (i+1)  # upper bits of L (above bit i)\n        bit_L = (L >> i) & 1\n        # branch at bit i: upper bits match L, bit i of p > bit_L\n        # only possible if bit_L == 0 (then we set bit i to 1)\n        if bit_L == 0:\n            # lower bits: set to match n to minimize XOR\n            lower_mask = (1 << i) - 1\n            p_candidate = prefix_L | (1 << i) | (n & lower_mask)\n            best = min(best, n ^ p_candidate)\n    return best\n\nt = int(input())\nfor _ in range(t):\n    n, m = map(int, input().split())\n    print(solve(n, m))",
