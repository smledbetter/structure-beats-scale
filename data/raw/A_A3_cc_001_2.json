    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom functools import lru_cache\n\ndef main():\n    data = sys.stdin.read().split()\n    if not data:\n        print(\"Bob\")\n        return\n    n = int(data[0])\n    if n == 0:\n        print(\"Bob\")\n        return\n    if len(data) < n + 1:\n        print(\"Bob\")\n        return\n    A = list(map(int, data[1:n+1]))\n\n    @lru_cache(maxsize=None)\n    def wins(l, r, last):\n        if l > r:\n            return False\n        can_left = A[l] > last\n        can_right = A[r] > last\n        if not can_left and not can_right:\n            return False\n        if can_left and wins(l+1, r, A[l]) == False:\n            return True\n        if can_right and wins(l, r-1, A[r]) == False:\n            return True\n        return False\n\n    result = wins(0, n-1, -1)\n    print(\"Alice\" if result else \"Bob\")\n\nmain()",
