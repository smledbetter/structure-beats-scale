 # \"00\" - leading zero, skip\n                    continue\n                else:\n                    count += 1\n            else:\n                # remaining = t[0..n-3]\n                first = remaining[0]\n                ways = 10 ** blanks_count\n                if first == '0':\n                    continue  # leading zero\n                elif first == '_':\n                    # first digit can be 1-9, rest of blanks can be 0-9\n                    other_blanks = blanks_count - 1\n                    ways = 9 * (10 ** other_blanks)\n                    count += ways\n                else:\n                    count += ways\n    \n    print(count)\n\nsolve()",
