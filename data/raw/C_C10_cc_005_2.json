      "final_code": "def solve():\n    s = input().strip()\n    n = len(s)\n    \n    has_X = 'X' in s\n    x_range = range(10) if has_X else [None]\n    \n    valid_endings = ['00', '25', '50', '75']\n    \n    count = 0\n    \n    for xv in x_range:\n        # Build string with X replaced\n        t = list(s)\n        if xv is not None:\n            for i in range(n):\n                if t[i] == 'X':\n                    t[i] = str(xv)\n        \n        if n == 1:\n            # Must be 0\n            c = t[0]\n            if c == '0' or c == '_':\n                count += 1\n            continue\n        \n        # Try each valid ending\n        for ending in valid_endings:\n            e0, e1 = ending[0], ending[1]\n            \n            # Check last two positions match ending\n            last2 = t[n-2:n]\n            \n            # Can last2[0] == e0?\n            if last2[0] != '_' and last2[0] != e0:\n                continue\n            # Can last2[1] == e1?\n            if last2[1] != '_' and last2[1] != e1:\n                continue\n            \n            # Count ways to fill remaining positions (0 to n-3)\n            # with leading zero constraint\n            remaining = t[:n-2]\n            blanks_count = remaining.count('_')\n            \n            # First char constraint: must not be '0' if n > 1\n            # (n >= 2 here, so full string length >= 2)\n            # First char of full string is remaining[0] if n > 2, else it's last2[0]\n            \n            if n == 2:\n                # No remaining positions, just check leading zero\n                # First char is e0\n                if e0 == '0' and e1 != '0':\n                    # leading zero, skip (e.g., \"05\" - but wait, 00 is special?)\n                    # Actually 00 as a number is 0, which is fine only if it represents 0\n                    # But \"00\" has leading zero\n                    continue\n                elif e0 == '0' and e1 == '0':\n                    # \"00\" - leading zero, skip\n                    continue\n                else:\n                    count += 1\n            else:\n                # remaining = t[0..n-3]\n                first = remaining[0]\n                ways = 10 ** blanks_count\n                if first == '0':\n                    continue  # leading zero\n                elif first == '_':\n                    # first digit can be 1-9, rest of blanks can be 0-9\n                    other_blanks = blanks_count - 1\n                    ways = 9 * (10 ** other_blanks)\n                    count += ways\n                else:\n                    count += ways\n    \n    print(count)\n\nsolve()",
