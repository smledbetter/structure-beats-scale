    "code": "import sys\nfrom math import gcd\ninput = sys.stdin.readline\n\ndef solve():\n    n, d = map(int, input().split())\n    a = list(map(int, input().split()))\n    \n    if not any(a):\n        print(0)\n        return\n    \n    cycle_len = n // gcd(n, d)\n    num_cycles = n // cycle_len\n    \n    visited = [False] * n\n    max_run = 0\n    \n    for start in range(n):\n        if visited[start]:\n            continue\n        \n        # Collect cycle\n        cycle = []\n        cur = start\n        while not visited[cur]:\n            visited[cur] = True\n            cycle.append(cur)\n            cur = (cur - d) % n\n        \n        # cycle contains nodes in order: start, start-d, start-2d, ...\n        # Each node i depends on next node in cycle (i-d)%n\n        # run[i] = 1 + run[(i-d)%n] if a[i]=1 and a[(i-d)%n]=1, etc.\n        \n        vals = [a[c] for c in cycle]\n        \n        # Check if all ones in cycle -> -1\n        if all(v == 1 for v in vals):\n            print(-1)\n            return\n        \n        # Compute max run of consecutive 1s ending at each position\n        # vals[0] depends on vals[1], vals[1] depends on vals[2], ...\n        # vals[k] depends on vals[(k+1) % cycle_len]\n        # run[k] = 1 + run[(k+1)%cycle_len] if vals[k]==1 else 0\n        \n        L = len(cycle)\n        # Find a zero to start from\n        zero_pos = -1\n        for i in range(L):\n            if vals[i] == 0:\n                zero_pos = i\n                break\n        \n        # Traverse starting from zero_pos going backwards (decreasing index in cycle = going forward in dependency)\n        # Actually: run[k] depends on run[(k+1)%L]\n        # Start from zero_pos, go in direction of decreasing dependency\n        # We go: zero_pos, zero_pos-1, zero_pos-2, ... (mod L)\n        \n        run = 0\n        for j in range(L):\n            idx = (zero_pos - j) % L\n            if vals[idx] == 0:\n                run = 0\n            else:\n                run += 1\n            if run > max_run:\n                max_run = run\n    \n    print(max_run)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
