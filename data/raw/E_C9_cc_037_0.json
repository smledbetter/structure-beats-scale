      "code": "import sys\nfrom collections import deque\n\ndef main():\n    input = sys.stdin.read().split()\n    ptr = 0\n    n, m = map(int, input[ptr:ptr+2])\n    ptr +=2\n\n    adj = [[] for _ in range(n+1)]\n    for _ in range(m):\n        x, y = map(int, input[ptr:ptr+2])\n        ptr +=2\n        adj[x].append(y)\n        adj[y].append(x)\n\n    q = int(input[ptr])\n    ptr +=1\n    queries = []\n    degree = [0]*(n+1)\n    for _ in range(q):\n        a, b = map(int, input[ptr:ptr+2])\n        ptr +=2\n        queries.append((a, b))\n        degree[a] +=1\n        degree[b] +=1\n\n    odd_nodes = [i for i in range(1, n+1) if degree[i] %2 !=0]\n    if len(odd_nodes) ==0:\n        print(\"YES\")\n        # Build parent and depth for each node via BFS\n        parent = [0]*(n+1)\n        depth = [0]*(n+1)\n        visited = [False]*(n+1)\n        q_bfs = deque()\n        q_bfs.append(1)\n        visited[1] = True\n        while q_bfs:\n            u = q_bfs.popleft()\n            for v in adj[u]:\n                if not visited[v]:\n                    visited[v] = True\n                    parent[v] = u\n                    depth[v] = depth[u]+1\n                    q_bfs.append(v)\n        # Process each query\n        for a, b in queries:\n            # Get path from a to LCA and b to LCA\n            path_a = []\n            path_b = []\n            u, v = a, b\n            while u != v:\n                if depth[u] > depth[v]:\n                    path_a.append(u)\n                    u = parent[u]\n                else:\n                    path_b.append(v)\n                    v = parent[v]\n            path_a.append(u)\n            path = path_a + path_b[::-1]\n            print(len(path))\n            print(' '.join(map(str, path)))\n    else:\n        print(\"NO\")\n        print(len(odd_nodes)//2)\n\nif __name__ == \"__main__\":\n    main()",
