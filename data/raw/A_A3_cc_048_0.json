    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom itertools import combinations\n\ninput = sys.stdin.readline\n\ndef is_k_beautiful(x, k):\n    return len(set(str(x))) <= k\n\ndef smallest_geq_with_digits(n_str, digit_set):\n    \"\"\"Find smallest number >= n_str using only digits in digit_set\"\"\"\n    digits = sorted(digit_set)\n    n = len(n_str)\n    \n    # Try to build a number of the same length\n    result = try_build(n_str, digits, 0, False)\n    if result is not None:\n        return result\n    \n    # Try length n+1: smallest number of length n+1 with these digits\n    non_zero = [d for d in digits if d != '0']\n    if not non_zero:\n        return None\n    # smallest digit for leading position, then fill rest with smallest digit\n    return non_zero[0] + digits[0] * n\n\ndef try_build(n_str, digits, pos, is_greater):\n    \"\"\"Try to build number >= n_str using only given digits\"\"\"\n    if pos == len(n_str):\n        return \"\"\n    \n    for d in digits:\n        # Skip leading zero\n        if pos == 0 and d == '0' and len(n_str) > 1:\n            continue\n        \n        if is_greater:\n            # Already greater, just pick smallest digit\n            rest = try_build(n_str, digits, pos + 1, True)\n            if rest is not None:\n                return d + rest\n        else:\n            nd = ord(d) - ord('0')\n            cd = ord(n_str[pos]) - ord('0')\n            \n            if nd < cd:\n                continue\n            elif nd == cd:\n                rest = try_build(n_str, digits, pos + 1, False)\n                if rest is not None:\n                    return d + rest\n            else:  # nd > cd\n                rest = try_build(n_str, digits, pos + 1, True)\n                if rest is not None:\n                    return d + rest\n    \n    return None\n\ndef solve(n, k):\n    n_str = str(n)\n    \n    if k == 1:\n        # Only one digit repeated: 1...1, 2...2, ..., 9...9\n        # Also try longer lengths\n        best = None\n        for length in range(len(n_str), len(n_str) + 2):\n            for d in '123456789':\n                candidate = int(d * length)\n                if candidate >= n:\n                    if best is None or candidate < best:\n                        best = candidate\n                    break  # digits are sorted, first valid is smallest for this length\n        return best\n    \n    # k == 2\n    # Try all combinations of 2 digits from 0-9, plus single digit sets\n    best = None\n    all_digits = [str(i) for i in range(10)]\n    \n    # Single digit sets\n    for d in all_digits:\n        digit_set = [d]\n        res = smallest_geq_with_digits(n_str, digit_set)\n        if res is not None:\n            val = int(res)\n            if val >= n:\n                if best is None or val < best:\n                    best = val\n    \n    # Two digit sets\n    for i in range(10):\n        for j in range(i+1, 10):\n            digit_set = [str(i), str(j)]\n            res = smallest_geq_with_digits(n_str, digit_set)\n            if res is not None:\n                val = int(res)\n                if val >= n:\n                    if best is None or val < best:\n                        best = val\n    \n    return best\n\nt = int(input())\nfor _ in range(t):\n    line = input().split()\n    n, k = int(line[0]), int(line[1])\n    print(solve(n, k))",
