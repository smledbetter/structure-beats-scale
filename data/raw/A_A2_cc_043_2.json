ct path to root\n            path = []\n            cur = x\n            while parent[cur] != cur:\n                path.append(cur)\n                cur = parent[cur]\n            root = cur\n            # compute cumulative parity from each node in path to root\n            # path[0]=x, path[1], ..., path[-1] -> root\n            # parity[path[i]] = parity from path[i] to path[i+1] (or root)\n            cum = 0\n            for node in path:\n                cum ^= parity[node]\n                # after this loop, cum = parity from x to root... no\n            # Actually we need to accumulate properly\n            # parity from path[0] to root = parity[path[0]] ^ parity[path[1]] ^ ... ^ parity[path[-1]]\n            # parity from path[1] to root = parity[path[1]] ^ ... ^ parity[path[-1]]\n            # So compute suffix XOR\n            suffix = 0\n            for node in reversed(path):\n                suffix ^= parity[node]\n                parity[node] = suffix\n                parent[node] = root\n            return root, parity[x] if path else 0\n        \n        def union(x, y, p):  # d[x] XOR d[y] = p\n            rx, px = find2(x)\n            ry, py = find2(y)\n            if rx == ry:\n                return (px ^ py) == p\n            if rank[rx] < rank[ry]: rx,ry,px,py = ry,rx,py,px\n            parent[ry] = rx\n            parity[ry] = px ^ py ^ p\n            if rank[rx] == rank[ry]: rank[rx]+=1\n            return True\n        \n        ok = True\n        for x,y,v in edges:\n            if v != -1:\n                ep = bin(v).count('1') % 2\n                if not union(x, y, ep): ok = False\n        for a,b,p in queries:\n            if not union(a, b, p): ok = False\n        \n        if not ok:\n            print(\"NO\"); continue\n        \n        out = []\n        out.append(\"YES\")\n        for x,y,v in edges:\n            if v != -1:\n                out.append(f\"{x} {y} {v}\")\n            else:\n                rx,px = find2(x); ry,