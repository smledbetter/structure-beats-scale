      "final_code": "import sys\nfrom bisect import bisect_left, bisect_right, insort\n\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    if n == 1:\n        print(0)\n        return\n    \n    # dp[l] = min inversions when l elements added to front, (i-l) to back\n    # after processing i elements\n    INF = float('inf')\n    \n    dp = [INF] * (n + 1)\n    dp[0] = 0  # start: 0 elements added to front\n    \n    sorted_deque = [a[0]]\n    # After first element, dp[0]=0 (added to back) or dp[1]=0 (added to front)\n    dp[0] = 0\n    dp[1] = 0\n    \n    for i in range(1, n):\n        val = a[i]\n        # sorted_deque contains a[0..i-1]\n        less = bisect_left(sorted_deque, val)      # elements < val\n        greater = len(sorted_deque) - bisect_right(sorted_deque, val)  # elements > val\n        \n        new_dp = [INF] * (n + 1)\n        \n        for l in range(i + 1):\n            if dp[l] == INF:\n                continue\n            # Add to back: inversions += number of elements greater than val\n            cost_back = greater\n            if new_dp[l] > dp[l] + cost_back:\n                new_dp[l] = dp[l] + cost_back\n            # Add to front: inversions += number of elements less than val\n            cost_front = less\n            if new_dp[l + 1] > dp[l] + cost_front:\n                new_dp[l + 1] = dp[l] + cost_front\n        \n        insort(sorted_deque, val)\n        dp = new_dp\n    \n    print(min(dp[:n+1]))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
