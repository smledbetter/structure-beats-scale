      "final_code": "import sys\nfrom math import gcd\n\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    if n == 1:\n        print(1)\n        return\n    \n    d = [abs(a[i+1] - a[i]) for i in range(n-1)]\n    \n    best = 1\n    current = []  # list of (gcd_value, count), ordered decreasing gcd\n    \n    for i, x in enumerate(d):\n        new_current = []\n        # Start with singleton\n        new_current.append((x, 1))\n        # Extend with previous groups\n        for g, cnt in current:\n            ng = gcd(g, x)\n            if new_current[-1][0] == ng:\n                new_current[-1] = (ng, new_current[-1][1] + cnt)\n            else:\n                new_current.append((ng, cnt))\n        current = new_current\n        \n        # Sum counts where gcd >= 2\n        # current is ordered decreasing, but we can't just break on first < 2\n        # because after merging, order might not be strictly decreasing\n        # Actually after merging same gcds, values are non-increasing left to right\n        # So once we see gcd < 2, all subsequent are also < 2\n        total = 0\n        for g, cnt in current:\n            if g >= 2:\n                total += cnt\n            else:\n                break\n        \n        if total > 0:\n            best = max(best, total + 1)\n    \n    print(best)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
