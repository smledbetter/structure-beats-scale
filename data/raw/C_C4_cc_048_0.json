a[idx]); idx += 1\n    \n    n_str = str(n)\n    all_digits = [str(i) for i in range(10)]\n    \n    best = None\n    \n    if k >= 10:\n        print(n)\n        continue\n    \n    # Try all combinations of k digits from 0-9\n    for combo in combinations(all_digits, k):\n        res = smallest_geq(n_str, list(combo))\n        if res is not None:\n            if best is None or int(res) < int(best):\n                best = res\n    \n    print(int(best))",
