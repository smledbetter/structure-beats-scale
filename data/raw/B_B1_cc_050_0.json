    "code": "import sys\nfrom bisect import bisect_right\ninput = sys.stdin.readline\n\ndef solve():\n    n, m, k = map(int, input().split())\n    xs = list(map(int, input().split()))\n    ys = list(map(int, input().split()))\n    xs_set = set(xs)\n    ys_set = set(ys)\n    \n    from collections import defaultdict\n    # vertical-only persons: x in xs, y not in ys\n    # group by y-gap\n    vert = defaultdict(lambda: defaultdict(int))  # gap -> x -> count\n    horiz = defaultdict(lambda: defaultdict(int))  # gap -> y -> count\n    \n    for _ in range(k):\n        xp, yp = map(int, input().split())\n        on_v = xp in xs_set\n        on_h = yp in ys_set\n        if on_v and not on_h:\n            gap = bisect_right(ys, yp) - 1\n            vert[gap][xp] += 1\n        elif on_h and not on_v:\n            gap = bisect_right(xs, xp) - 1\n            horiz[gap][yp] += 1\n    \n    ans = 0\n    for gap, xmap in vert.items():\n        total = sum(xmap.values())\n        ans += total*(total-1)//2 - sum(c*(c-1)//2 for c in xmap.values())\n    for gap, ymap in horiz.items():\n        total = sum(ymap.values())\n        ans += total*(total-1)//2 - sum(c*(c-1)//2 for c in ymap.values())\n    \n    print(ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
