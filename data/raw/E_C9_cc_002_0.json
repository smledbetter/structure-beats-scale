      "code": "import sys\nfrom collections import deque\n\ndef main():\n    n = int(sys.stdin.readline())\n    a = list(map(int, sys.stdin.readline().split()))\n    b = list(map(int, sys.stdin.readline().split()))\n    \n    dp = [float('inf')] * (n + 1)\n    dp[n] = 0\n    q = deque()\n    q.append(n)\n    \n    while q:\n        u = q.popleft()\n        if u == 0:\n            break\n        for v in range(u - a[u - 1], u):\n            if v >= 0:\n                new_pos = v + b[v]\n                if dp[new_pos] > dp[u] + 1:\n                    dp[new_pos] = dp[u] + 1\n                    q.append(new_pos)\n    \n    if dp[0] == float('inf'):\n        print(-1)\n        return\n    \n    print(dp[0])\n    \n    path = []\n    current = 0\n    while current != n:\n        for v in range(n, -1, -1):\n            if v + b[v] == current and dp[v] == dp[current] - 1:\n                path.append(v)\n                current = v\n                break\n    \n    path.reverse()\n    print(' '.join(map(str, path)))\n\nif __name__ == \"__main__\":\n    main()",
