    "code": "import sys\nfrom bisect import bisect_left, bisect_right, insort\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    INF = float('inf')\n    dp = [[INF]*n for _ in range(n)]\n    for i in range(n):\n        dp[i][i] = 0\n    for length in range(2, n+1):\n        for l in range(n - length + 1):\n            r = l + length - 1\n            sub = sorted(a[l+1:r+1])\n            less_l = bisect_left(sub, a[l])\n            opt1 = dp[l+1][r] + less_l if length > 1 else 0\n            sub2 = sorted(a[l:r])\n            greater_r = len(sub2) - bisect_right(sub2, a[r])\n            opt2 = dp[l][r-1] + greater_r if length > 1 else 0\n            dp[l][r] = min(opt1, opt2)\n    print(dp[0][n-1])\n\nt = int(input())\nfor _ in range(t):\n    solve()",
