          "code": "import sys\n\ndef main():\n    data = sys.stdin.buffer.read().split()\n    idx = 0\n    q = int(data[idx]); idx += 1\n    \n    queries = []\n    for _ in range(q):\n        t = int(data[idx]); idx += 1\n        if t == 1:\n            x = int(data[idx]); idx += 1\n            queries.append((1, x))\n        else:\n            x = int(data[idx]); idx += 1\n            y = int(data[idx]); idx += 1\n            queries.append((2, x, y))\n    \n    # Process in reverse\n    # mapping[x] = what x ultimately becomes (through all future replacements)\n    mapping = {}\n    \n    def resolve(v):\n        path = []\n        visited = set()\n        while v in mapping:\n            if v in visited:\n                # cycle detected, v maps to itself effectively\n                break\n            visited.add(v)\n            path.append(v)\n            v = mapping[v]\n        # path compression\n        for u in path:\n            mapping[u] = v\n        return v\n    \n    results = []\n    \n    for i in range(q - 1, -1, -1):\n        query = queries[i]\n        if query[0] == 1:\n            x = query[1]\n            results.append(resolve(x))\n        else:\n            x, y = query[1], query[2]\n            # Going forward: replace x with y\n            # So in reverse: x should now map to whatever y resolves to\n            resolved_y = resolve(y)\n            resolved_x = resolve(x)\n            if resolved_x != resolved_y:\n                mapping[resolved_x] = resolved_y\n            # Also direct mapping for x\n            mapping[x] = resolved_y\n    \n    results.reverse()\n    sys.stdout.write(' '.join(map(str, results)) + '\\n')\n\nmain()",
