          "code": "import sys\nfrom functools import lru_cache\n\nMOD = 998244353\n\ndef solve():\n    n, x = map(int, input().split())\n    \n    # Precompute binomial coefficients\n    C = [[0]*(n+1) for _ in range(n+1)]\n    C[0][0] = 1\n    for i in range(1, n+1):\n        C[i][0] = 1\n        for j in range(1, i+1):\n            C[i][j] = (C[i-1][j-1] + C[i-1][j]) % MOD\n    \n    @lru_cache(maxsize=None)\n    def f(heroes, max_hp):\n        if heroes == 0:\n            return 1\n        if heroes == 1:\n            return 0\n        if max_hp <= 0:\n            return 0\n        if max_hp < heroes:\n            # all die in round 1\n            return pow(max_hp, heroes, MOD)\n        # max_hp >= heroes\n        die_hp = heroes - 1  # health values [1..die_hp] die\n        survive_hp = max_hp - die_hp  # new max hp for survivors\n        result = 0\n        for k in range(0, heroes+1):\n            if k == 1:\n                continue\n            ways = C[heroes][k] * pow(die_hp, heroes-k, MOD) % MOD * f(k, survive_hp) % MOD\n            result = (result + ways) % MOD\n        return result\n    \n    print(f(n, x))\n\nsolve()",
