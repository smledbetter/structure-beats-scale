          "code": "import sys\nfrom math import gcd\n\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    if n == 1:\n        print(1)\n        return\n    \n    # For each position, we maintain a list of (gcd_value, count) pairs\n    # representing all distinct GCDs of differences ending at current position\n    # A subarray a[i..j] is a friend group if there exists m>=2 dividing all differences\n    # i.e., gcd of consecutive differences >= 2\n    \n    best = 1\n    # current holds list of (gcd, length) for subarrays ending at current index\n    current = []\n    \n    for i in range(1, n):\n        diff = abs(a[i] - a[i-1])\n        new_current = []\n        \n        # Start new subarray of length 2 ending at i\n        new_current.append((diff, 2))\n        \n        # Extend all previous subarrays\n        for g, cnt in current:\n            new_g = gcd(g, diff)\n            new_current.append((new_g, cnt + 1))\n        \n        # Merge duplicates (keep max count for each gcd)\n        merged = {}\n        for g, cnt in new_current:\n            if g in merged:\n                merged[g] = max(merged[g], cnt)\n            else:\n                merged[g] = cnt\n        \n        current = list(merged.items())\n        \n        for g, cnt in current:\n            if g >= 2:\n                best = max(best, cnt)\n    \n    print(best)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
