    "model": "claude-sonnet-4-6",
    "code": "import sys\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    \n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        a = list(map(int, input_data[idx:idx+n])); idx += n\n        \n        # State: set of Pareto-optimal (lo, hi) pairs\n        # lo = current_pos - min_coord, hi = max_coord - current_pos\n        # Start: position=0, min=0, max=0 => lo=0, hi=0\n        states = [(0, 0)]\n        \n        for d in a:\n            new_states = []\n            for (lo, hi) in states:\n                # Go right: new position = current + d\n                # new_lo = lo (min unchanged), new_hi = max(hi, d)\n                new_states.append((lo, max(hi, d)))\n                # Go left: new position = current - d\n                # new_lo = max(lo, d), new_hi = hi (max unchanged)\n                new_states.append((max(lo, d), hi))\n            \n            # Prune dominated states\n            # Sort by lo ascending, then hi ascending\n            new_states = list(set(new_states))\n            new_states.sort(key=lambda x: (x[0], x[1]))\n            \n            # Keep Pareto front: as lo increases, hi must decrease\n            pareto = []\n            min_hi = float('inf')\n            for (lo, hi) in new_states:\n                if hi < min_hi:\n                    pareto.append((lo, hi))\n                    min_hi = hi\n            \n            states = pareto\n        \n        ans = min(lo + hi for (lo, hi) in states)\n        print(ans)\n\nsolve()",
