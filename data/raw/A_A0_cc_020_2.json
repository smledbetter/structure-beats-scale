    "code": "import sys\nfrom math import gcd\n\ninput_data = sys.stdin.buffer.read().split()\nidx = 0\nt = int(input_data[idx]); idx += 1\n\nresults = []\nfor _ in range(t):\n    n, d = int(input_data[idx]), int(input_data[idx+1]); idx += 2\n    a = [int(input_data[idx+i]) for i in range(n)]; idx += n\n    \n    g = gcd(n, d)\n    L = n // g\n    \n    ans = 0\n    found_minus1 = False\n    \n    for start in range(g):\n        # Build cycle: start, start+d, start+2d, ... mod n (going forward by d)\n        # Going backward by d means going forward in the cycle\n        cycle = []\n        pos = start\n        for _ in range(L):\n            cycle.append(a[pos])\n            pos = (pos + d) % n\n        \n        if all(x == 1 for x in cycle):\n            found_minus1 = True\n            break\n        \n        # For each position in cycle, find consecutive 1s going backward (which is forward in cycle traversal? No...)\n        # Position i in cycle: going backward by d means previous in cycle\n        # cycle[0] -> cycle[1] -> ... means adding d each time\n        # subtracting d from cycle[k] gives cycle[k-1]\n        # So \"backward\" in the subtract-d direction is previous in our cycle list\n        \n        # For each position with value 1, count consecutive 1s going to previous indices\n        doubled = cycle + cycle\n        count = 0\n        counts = [0] * L\n        for i in range(2*L-1, -1, -1):\n            if doubled[i] == 1:\n                count += 1\n            else:\n                count = 0\n            if i < L:\n                counts[i] = count\n        \n        for i in range(L):\n            if cycle[i] == 1:\n                ans = max(ans, counts[i])\n    \n    if found_minus1:\n        results.append(-1)\n    else:\n        results.append(ans)\n\nprint('\\n'.join(map(str, results)))",
