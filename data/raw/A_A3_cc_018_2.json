    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom bisect import bisect_right\n\ndef solve():\n    input_data = sys.stdin.buffer.read().split()\n    if len(input_data) < 1:\n        print(0)\n        return\n    n = int(input_data[0])\n    if n == 0:\n        print(0)\n        return\n    a = list(map(int, input_data[1:n+1]))\n    \n    # For each element, compute (v, d) where v = a[i-1], d = i - v (removals needed before it)\n    # Only valid if v >= 1 and v <= i (d >= 0)\n    best = {}  # v -> minimum d\n    for i in range(1, n+1):\n        v = a[i-1]\n        if v >= 1 and v <= i:\n            d = i - v\n            if v not in best or d < best[v]:\n                best[v] = d\n    \n    # Sort by v ascending, then we have one entry per v with minimum d\n    elements = sorted(best.items())  # (v, d) sorted by v\n    \n    # Find longest non-decreasing subsequence of d values\n    # Using patience sorting\n    tails = []\n    for _, d in elements:\n        pos = bisect_right(tails, d)\n        if pos == len(tails):\n            tails.append(d)\n        else:\n            tails[pos] = d\n    \n    print(len(tails))\n\nsolve()",
