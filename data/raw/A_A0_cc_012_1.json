    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    input()  # empty line\n    m, n = map(int, input().split())\n    p = []\n    for _ in range(m):\n        p.append(list(map(int, input().split())))\n    \n    # Binary search on alpha\n    # For given alpha, shop i covers friend j if p[i][j] >= alpha\n    # Feasible if some shop covers >= 2 friends (or n==1, but n>=2)\n    # Also feasible if any shop covers all friends\n    \n    # Collect all values for binary search\n    vals = sorted(set(p[i][j] for i in range(m) for j in range(n)))\n    \n    def feasible(alpha):\n        for i in range(m):\n            count = sum(1 for j in range(n) if p[i][j] >= alpha)\n            if count >= 2:\n                return True\n        return False\n    \n    # But wait - we also need every friend covered!\n    def feasible2(alpha):\n        # Check every friend has at least one covering shop\n        for j in range(n):\n            if all(p[i][j] < alpha for i in range(m)):\n                return False\n        # Check some shop covers >= 2 friends\n        for i in range(m):\n            count = sum(1 for j in range(n) if p[i][j] >= alpha)\n            if count >= 2:\n                return True\n        return False\n    \n    lo, hi = 0, len(vals) - 1\n    ans = vals[0] - 1\n    # Actually binary search on the value directly\n    lo, hi = 1, 10**9\n    # Better: binary search on vals\n    lo, hi = 0, len(vals)\n    ans = 0\n    while lo <= hi:\n        mid = (lo + hi) // 2\n        if mid == 0:\n            lo = mid + 1\n            continue\n        alpha = vals[mid-1] if mid <= len(vals) else 10**9+1\n        if feasible2(alpha):\n            ans = alpha\n            lo = mid + 1\n        else:\n            hi = mid - 1\n    print(ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
