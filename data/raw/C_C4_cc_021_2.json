      "final_code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, m = map(int, input().split())\n    grid = []\n    for _ in range(n):\n        row = list(map(int, list(input().strip())))\n        grid.append(row)\n    \n    # prefix sums\n    # col_zeros[i][j] = number of zeros in column j, rows 0..i-1\n    col_zeros = [[0]*(m) for _ in range(n+1)]\n    for j in range(m):\n        for i in range(n):\n            col_zeros[i+1][j] = col_zeros[i][j] + (1 - grid[i][j])\n    \n    # row_zeros[i][j] = number of zeros in row i, cols 0..j-1\n    row_zeros = [[0]*(m+1) for _ in range(n)]\n    for i in range(n):\n        for j in range(m):\n            row_zeros[i][j+1] = row_zeros[i][j] + (1 - grid[i][j])\n    \n    # interior ones: ones[i][j] = prefix sum of ones, rows 0..i-1, cols 0..j-1\n    ones = [[0]*(m+1) for _ in range(n+1)]\n    for i in range(n):\n        for j in range(m):\n            ones[i+1][j+1] = ones[i][j+1] + ones[i+1][j] - ones[i][j] + grid[i][j]\n    \n    def get_col_zeros(r1, r2, c):\n        # zeros in col c, rows r1..r2 inclusive\n        return col_zeros[r2+1][c] - col_zeros[r1][c]\n    \n    def get_row_zeros(r, c1, c2):\n        # zeros in row r, cols c1..c2 inclusive\n        return row_zeros[r][c2+1] - row_zeros[r][c1]\n    \n    def get_ones(r1, r2, c1, c2):\n        # ones in rows r1..r2, cols c1..c2\n        return ones[r2+1][c2+1] - ones[r1][c2+1] - ones[r2+1][c1] + ones[r1][c1]\n    \n    ans = float('inf')\n    \n    for r1 in range(n):\n        for r2 in range(r1+4, n):\n            # For each c1, precompute left col cost\n            # For each c2, precompute right col cost\n            left_col = [get_col_zeros(r1+1, r2-1, c) for c in range(m)]\n            right_col = left_col  # same array, index by c2\n            \n            for c1 in range(m):\n                lc = left_col[c1]\n                # running interior ones and top/bottom row zeros as c2 increases\n                interior_ones = 0\n                top_zeros = 0\n                bot_zeros = 0\n                for c2 in range(c1+3, m):\n                    # add column c2-1 contributions (the new interior column added)\n                    # interior cols are c1+1..c2-1\n                    if c2 > c1+1:\n                        col = c2 - 1\n                        interior_ones += get_ones(r1+1, r2-1, col, col)\n                        top_zeros += (1 - grid[r1][col])\n                        bot_zeros += (1 - grid[r2][col])\n                    \n                    rc = right_col[c2]\n                    cost = lc + rc + top_zeros + bot_zeros + interior_ones\n                    if cost < ans:\n                        ans = cost\n    \n    print(ans)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
