      "code": "def min_with_digits(n_str, digits):\n    digits = sorted(digits)\n    # digits must not include 0 as first digit (handle leading zero)\n    n = len(n_str)\n    \n    def solve(length):\n        # find minimum number of given length using digits, >= n_str if length == n\n        if length > n:\n            # just use smallest non-zero digit repeated\n            non_zero = [d for d in digits if d != '0']\n            if not non_zero:\n                return None\n            return non_zero[0] * length\n        # length == n (we try equal length first)\n        # greedy with backtracking\n        result = [''] * length\n        # Try to build number >= n_str\n        # Use recursive approach\n        def build(pos, tight):\n            if pos == length:\n                return []\n            lo = n_str[pos] if tight else '0'\n            # find smallest digit in digits >= lo, and if pos==0 must be > '0'\n            for d in digits:\n                if pos == 0 and d == '0':\n                    continue\n                if tight and d < lo:\n                    continue\n                new_tight = tight and (d == lo)\n                rest = build(pos + 1, new_tight)\n                if rest is not None:\n                    return [d] + rest\n            return None\n        \n        res = build(0, True)\n        if res is None:\n            return None\n        return ''.join(res)\n    \n    r = solve(n)\n    if r is None:\n        r = solve(n + 1)\n    return r",
