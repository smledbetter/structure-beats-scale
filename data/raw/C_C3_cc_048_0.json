      "final_code": "def smallest_with_digits(n_str, digits):\n    digits = sorted(digits)\n    s = list(n_str)\n    L = len(s)\n    \n    # Try same length\n    result = try_same_length(s, digits)\n    if result is not None:\n        return result\n    \n    # Try length L+1: smallest number of length L+1 using digits\n    # First digit must be non-zero\n    non_zero = [d for d in digits if d != '0']\n    if not non_zero:\n        return None\n    return non_zero[0] + digits[0] * L\n\ndef try_same_length(s, digits):\n    L = len(s)\n    chosen = [''] * L\n    # greedy with backtracking\n    i = 0\n    tight = True\n    # Use iterative approach\n    pos = 0\n    state = []  # stack of (pos, digit_index, tight)\n    \n    # Let me do recursive with memo... actually just iterative backtracking\n    idx = [0] * L  # index into digits for each position\n    tight_arr = [True] + [False] * L\n    \n    result = []\n    pos = 0\n    while pos < L:\n        tight = (pos == 0 or tight_arr[pos])\n        min_d = s[pos] if tight else '0'\n        # find smallest digit in digits >= min_d\n        found = False\n        start = idx[pos]\n        for di in range(start, len(digits)):\n            d = digits[di]\n            if d >= min_d:\n                chosen[pos] = d\n                idx[pos] = di\n                tight_arr[pos+1] = (d == s[pos]) if tight else False\n                # reset future indices\n                for j in range(pos+1, L):\n                    idx[j] = 0\n                pos += 1\n                found = True\n                break\n        if not found:\n            # backtrack\n            idx[pos] = 0\n            pos -= 1\n            if pos < 0:\n                return None\n            idx[pos] += 1  # try next digit at pos\n            # recompute tight for pos\n            tight_arr[pos] = tight_arr[pos]  # unchanged\n    \n    return ''.join(chosen)",
