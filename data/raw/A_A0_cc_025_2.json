    "model": "claude-sonnet-4-6",
    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n, m, q = map(int, input().split())\n    grid = [[True]*m for _ in range(n)]  # True = free\n    \n    # Precompute arrays\n    left = [[0]*m for _ in range(n)]\n    right = [[0]*m for _ in range(n)]\n    up = [[0]*m for _ in range(n)]\n    down = [[0]*m for _ in range(n)]\n    \n    def recompute_row(r):\n        # left\n        for c in range(m):\n            if grid[r][c]:\n                left[r][c] = (left[r][c-1] if c > 0 else 0) + 1\n            else:\n                left[r][c] = 0\n        # right\n        for c in range(m-1,-1,-1):\n            if grid[r][c]:\n                right[r][c] = (right[r][c+1] if c < m-1 else 0) + 1\n            else:\n                right[r][c] = 0\n    \n    def recompute_col(c):\n        for r in range(n):\n            if grid[r][c]:\n                up[r][c] = (up[r-1][c] if r > 0 else 0) + 1\n            else:\n                up[r][c] = 0\n        for r in range(n-1,-1,-1):\n            if grid[r][c]:\n                down[r][c] = (down[r+1][c] if r < n-1 else 0) + 1\n            else:\n                down[r][c] = 0\n    \n    def compute_total():\n        total = 0\n        # length 1\n        for r in range(n):\n            for c in range(m):\n                if grid[r][c]:\n                    total += 1\n        # length 2 horizontal and vertical counted via corners\n        # corners: for each free cell, add (left-1)*(down-1) + (up-1)*(right-1)\n        # plus length-2: horizontal pairs and vertical pairs\n        for r in range(n):\n            for c in range(m):\n                if grid[r][c]:\n                    # corner contributions (length >= 3... wait no)\n                    # (left[r][c]-1)*(down[r][c]-1) counts staircases where\n                    # this cell is the turn point, with >=1 cell to left and >=1 below\n                    total += (left[r][c]-1)*(down[r][c]-1)\n                    total += (up[r][c]-1)*(right[r][c]-1)\n                    # length-2 horizontal: right[r][c]-1 ... no\n        # length-2 horizontal: for each cell, if right[r][c]>=2, count right[r][c]-1? No\n        # Actually horizontal pairs: sum over r,c of (right[r][c] >= 2 ? ... )\n        # = sum of max(0, right[r][c]-1) but that overcounts\n        # Simpler: for each r, sum of (run_length choose 2) for each run... \n        # Actually pairs = sum over r of sum over c of (1 if grid[r][c] and grid[r][c+1])\n        for r in range(n):\n            for c in range(m-1):\n                if grid[r][c] and grid[r][c+1]:\n                    total += 1\n        for c in range(m):\n            for r in range(n-1):\n                if grid[r][c] and grid[r+1][c]:\n                    total += 1\n        return total\n    \n    # Initialize\n    for r in range(n):\n        recompute_row(r)\n    for c in range(m):\n        recompute_col(c)\n    \n    # But compute_total is O(nm) which is fine for initial\n    # After each query, we need to update efficiently\n    # With q=10^4 and nm=10^6, O(nm) per query = 10^10 ops... too slow\n    \n    # Need smarter approach\n    # After flipping (x,y), recompute row x and col y\n    # Then recompute the contribution of affected cells\n    \n    # Let's maintain per-cell contributions\n    # contrib[r][c] = (left-1)*(down-1) + (up-1)*(right-1) if free else 0\n    # total = sum(free cells) + sum(contrib) + horiz_pairs + vert_pairs\n    \n    # horiz_pairs = sum over r,c of (grid[r][c] and grid[r][c+1])\n    # vert_pairs = sum over r,c of (grid[r][c] and grid[r+1][c])\n    \n    # When we flip (x,y):\n    # - recompute_row(x): affects left[x][*] and right[x][*]\n    # - recompute_col(y): affects up[*][y] and down[*][y]\n    # - contrib changes for:\n    #   - cells in row x (their left/right changed -> (up-1)*(right-1) part)\n    #   - cells in col y (their up/down changed -> (left-1)*(down-1) part)\n    #   - cell (x,y) itself: both parts change\n    # - horiz_pairs: only pairs involving column y in row x change\n    #   Actually only (x,y-1)-(x,y) and (x,y)-(x,y+1)\n    # - vert_pairs: only (x-1,y)-(x,y) and (x,y)-(x+1,y)\n    \n    # So total update cost is O(n + m) per query. That's 10^4 * 2000 = 2*10^7, fine!\n    \n    contrib = [[0]*m for _ in range(n)]\n    \n    def cell_contrib(r, c):\n        if not grid[r][c]:\n            return 0\n        return (left[r][c]-1)*(down[r][c]-1) + (up[r][c]-1)*(right[r][c]-1)\n    \n    # Initialize contrib\n    for r in range(n):\n        for c in range(m):\n            contrib[r][c] = cell_contrib(r, c)\n    \n    total_contrib = sum(contrib[r][c] for r in range(n) for c in range(m))\n    total_free = sum(grid[r][c] for r in range(n) for c in range(m))\n    \n    horiz = sum(1 for r in range(n) for c in range(m-1) if grid[r][c] and grid[r][c+1])\n    vert = sum(1 for r in range(n-1) for c in range(m) if grid[r][c] and grid[r+1][c])\n    \n    results = []\n    \n    for _ in range(q):\n        x, y = map(int, input().split())\n        x -= 1; y -= 1\n        \n        # Subtract old contributions of row x and col y\n        for c in range(m):\n            total_contrib -= contrib[x][c]\n        for r in range(n):\n            if r != x:\n                total_contrib -= contrib[r][y]\n        \n        # Subtract old horiz pairs affected by (x,y)\n        if y > 0 and grid[x][y-1] and grid[x][y]:\n            horiz -= 1\n        if y < m-1 and grid[x][y] and grid[x][y+1]:\n            horiz -= 1\n        \n        # Subtract old vert pairs affected by (x,y)\n        if x > 0 and grid[x-1][y] and grid[x][y]:\n            vert -= 1\n        if x < n-1 and grid[x][y] and grid[x+1][y]:\n            vert -= 1\n        \n        # Flip\n        grid[x][y] = not grid[x][y]\n        if grid[x][y]:\n            total_free += 1\n        else:\n            total_free -= 1\n        \n        # Recompute row x and col y\n        recompute_row(x)\n        recompute_col(y)\n        \n        # Recompute contrib for row x and col y\n        for c in range(m):\n            contrib[x][c] = cell_contrib(x, c)\n        for r in range(n):\n            contrib[r][y] = cell_contrib(r, y)\n        \n        # Add new contributions\n        for c in range(m):\n            total_contrib += contrib[x][c]\n        for r in range(n):\n            if r != x:\n                total_contrib += contrib[r][y]\n        \n        # Add new horiz pairs\n        if y > 0 and grid[x][y-1] and grid[x][y]:\n            horiz += 1\n        if y < m-1 and grid[x][y] and grid[x][y+1]:\n            horiz += 1\n        \n        # Add new vert pairs\n        if x > 0 and grid[x-1][y] and grid[x][y]:\n            vert += 1\n        if x < n-1 and grid[x][y] and grid[x+1][y]:\n            vert += 1\n        \n        results.append(total_free + total_contrib + horiz + vert)\n    \n    print('\\n'.join(map(str, results)))\n\nsolve()",
