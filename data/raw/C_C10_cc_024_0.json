      "final_code": "import sys\nfrom collections import defaultdict\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a, b = [], []\n    cnt_b = defaultdict(int)\n    topic = defaultdict(list)\n    for i in range(n):\n        x, y = map(int, input().split())\n        a.append(x); b.append(y)\n        cnt_b[y] += 1\n        topic[x].append(i)\n    total = n * (n-1) * (n-2) // 6\n    bad = 0\n    for x, lst in topic.items():\n        m = len(lst)\n        if m < 2: continue\n        S = sum(cnt_b[b[i]] - 1 for i in lst)\n        # each pair (i,j): contributes (cnt_b[bi]-1)+(cnt_b[bj]-1)\n        # sum over pairs = (m-1)*S\n        bad += (m-1) * S\n        # subtract overcounting: all-3-same-topic triples counted 3 times, should be 0 times\n        bad -= 3 * (m * (m-1) * (m-2) // 6)\n    print(total - bad)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
