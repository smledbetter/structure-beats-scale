      "code": "import sys\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    n = int(input_data[0])\n    a = list(map(int, input_data[1:n+1]))\n    \n    MAX_VAL = 501\n    MAX_XOR = 512\n    \n    # dp[v] is a bitmask of achievable XOR values for increasing subsequences ending with value v\n    dp = [0] * MAX_VAL\n    # prefix[v] = union of dp[0..v]\n    prefix = [0] * MAX_VAL\n    \n    for val in a:\n        # Get all achievable XOR values from subsequences ending with value < val\n        if val > 0:\n            prev = prefix[val - 1]\n        else:\n            prev = 0\n        \n        # XOR each of those with val, plus start fresh with val\n        new_mask = 0\n        # {x ^ val : x in prev} union {val}\n        temp = prev\n        while temp:\n            lsb = temp & (-temp)\n            x = lsb.bit_length() - 1\n            new_mask |= (1 << (x ^ val))\n            temp ^= lsb\n        new_mask |= (1 << val)\n        \n        dp[val] |= new_mask\n        # Update prefix from val onwards\n        for v in range(val, MAX_VAL):\n            prefix[v] |= dp[val]\n    \n    # All achievable XOR values: 0 (empty) plus all bits set in prefix[MAX_VAL-1]\n    all_xors = prefix[MAX_VAL - 1] | 1  # include 0\n    \n    result = []\n    for x in range(MAX_XOR):\n        if all_xors & (1 << x):\n            result.append(x)\n    \n    print(len(result))\n    print(*result)\n\nsolve()",
