    "code": "import sys\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    b = list(map(int, input().split()))\n    \n    if n == 1:\n        print(\"1\")\n        return\n    \n    result = ['0'] * n\n    players = list(range(n))\n    \n    for start in range(n):\n        max_a = a[start]\n        max_b = b[start]\n        count = 1\n        changed = True\n        while changed:\n            changed = False\n            for i in range(n):\n                if i == start:\n                    continue\n                if a[i] < max_a or b[i] < max_b:\n                    if a[i] > max_a or b[i] > max_b:\n                        changed = True\n                    new_max_a = max(max_a, a[i])\n                    new_max_b = max(max_b, b[i])\n                    if new_max_a != max_a or new_max_b != max_b:\n                        changed = True\n                    max_a = new_max_a\n                    max_b = new_max_b\n                    count += 1  # wrong counting\n        # need proper BFS\n    \n    print(''.join(result))\n\nt = int(input())\nfor _ in range(t):\n    solve()",
