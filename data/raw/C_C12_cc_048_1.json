      "final_code": "def min_kbeautiful_with_digits(n_str, digits):\n    # digits is a sorted list of allowed digits (as chars)\n    # Find minimum number >= n_str using only these digits, same length\n    length = len(n_str)\n    result = []\n    \n    def solve(pos, tight):\n        if pos == length:\n            return []\n        d = n_str[pos]\n        if tight:\n            # find smallest digit in digits >= d\n            for c in digits:\n                if c > d:\n                    # fill rest with smallest digit\n                    return [c] + [digits[0]] * (length - pos - 1)\n                elif c == d:\n                    rest = solve(pos + 1, True)\n                    if rest is not None:\n                        return [c] + rest\n            return None  # can't place any digit >= d\n        else:\n            return [digits[0]] * (length - pos)\n    \n    # Handle leading zero: first digit must be non-zero\n    valid_digits = [c for c in digits if c != '0']\n    if not valid_digits:\n        return None\n    \n    # First digit must be from valid_digits (no leading zero)\n    d = n_str[0]\n    for c in valid_digits:\n        if c > d:\n            return c + digits[0] * (length - 1)\n        elif c == d:\n            rest = solve(1, True)\n            if rest is not None:\n                return c + ''.join(rest)\n    return None\n\ndef find_min(n, k):\n    n_str = str(n)\n    best = None\n    \n    from itertools import combinations\n    \n    all_digits = [str(i) for i in range(10)]\n    \n    for combo in combinations(all_digits, k):\n        digits = list(combo)\n        # Try same length\n        res = min_kbeautiful_with_digits(n_str, digits)\n        if res is None:\n            # Try length+1\n            non_zero = [c for c in digits if c != '0']\n            if non_zero:\n                res = non_zero[0] + digits[0] * len(n_str)\n        if res is not None:\n            if best is None or int(res) < int(best):\n                best = res\n    \n    return int(best)\n\nimport sys\nfrom itertools import combinations\ninput_data = sys.stdin.read().split()\nt = int(input_data[0])\nidx = 1\nfor _ in range(t):\n    n, k = int(input_data[idx]), int(input_data[idx+1])\n    idx += 2\n    print(find_min(n, k))",
