    "model": "claude-sonnet-4-6",
    "code": "import sys\nfrom collections import defaultdict\n\ndef solve():\n    input_data = sys.stdin.read().split()\n    idx = 0\n    t = int(input_data[idx]); idx += 1\n    for _ in range(t):\n        n = int(input_data[idx]); idx += 1\n        a = list(map(int, input_data[idx:idx+n])); idx += n\n        \n        # dp[x] = list of Pareto-optimal (lo, hi) pairs\n        # Pareto: no pair has both lo >= other's lo AND hi <= other's hi (strictly better)\n        # Sort by lo descending -> hi must be ascending for Pareto optimality\n        dp = defaultdict(list)\n        dp[0] = [(0, 0)]\n        \n        for d in a:\n            new_dp = defaultdict(list)\n            for x, pairs in dp.items():\n                # Go right: new_x = x + d\n                nx = x + d\n                for (lo, hi) in pairs:\n                    new_lo = lo\n                    new_hi = max(hi, nx)\n                    new_dp[nx].append((new_lo, new_hi))\n                # Go left: new_x = x - d\n                nx = x - d\n                for (lo, hi) in pairs:\n                    new_lo = min(lo, nx)\n                    new_hi = hi\n                    new_dp[nx].append((new_lo, new_hi))\n            \n            # Prune each position's pairs to Pareto-optimal set\n            # Maximize lo, minimize hi\n            pruned = defaultdict(list)\n            for x, pairs in new_dp.items():\n                # Sort by lo descending, then hi ascending\n                pairs.sort(key=lambda p: (-p[0], p[1]))\n                pareto = []\n                min_hi = float('inf')\n                for (lo, hi) in pairs:\n                    if hi < min_hi:\n                        pareto.append((lo, hi))\n                        min_hi = hi\n                pruned[x] = pareto\n            dp = pruned\n        \n        ans = float('inf')\n        for x, pairs in dp.items():\n            for (lo, hi) in pairs:\n                ans = min(ans, hi - lo)\n        \n        print(ans)\n\nsolve()",
