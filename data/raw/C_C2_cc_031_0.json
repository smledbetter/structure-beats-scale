      "final_code": "import sys\nfrom collections import defaultdict\n\ndef solve():\n    MOD = 10**9 + 7\n    input_data = sys.stdin.read().split()\n    n = int(input_data[0])\n    a = list(map(int, input_data[1:n+1]))\n    \n    MAX_VAL = max(max(a), n) + 1\n    \n    # Euler's totient sieve\n    phi = list(range(MAX_VAL))\n    for i in range(2, MAX_VAL):\n        if phi[i] == i:  # i is prime\n            for j in range(i, MAX_VAL, i):\n                phi[j] -= phi[j] // i\n    \n    # Precompute divisors for each a[i]\n    divs = [[] for _ in range(MAX_VAL)]\n    for v in range(1, MAX_VAL):\n        for multiple in range(v, MAX_VAL, v):\n            divs[multiple].append(v)\n    \n    ans = 0\n    \n    for e in range(1, n+1):\n        cnt = defaultdict(int)\n        k = e\n        while k <= n:\n            val = a[k-1]  # a is 0-indexed, index k\n            for d in divs[val]:\n                cnt[d] += 1\n            k += e\n        \n        phi_e = phi[e]\n        for d, c in cnt.items():\n            ans = (ans + phi[d] * phi_e % MOD * (c * c % MOD)) % MOD\n    \n    print(ans)\n\nsolve()",
