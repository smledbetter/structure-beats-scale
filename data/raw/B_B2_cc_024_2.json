    "code": "import sys\nfrom collections import defaultdict\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    problems = []\n    cnt_a = defaultdict(int)\n    cnt_b = defaultdict(int)\n    for _ in range(n):\n        a, b = map(int, input().split())\n        problems.append((a, b))\n        cnt_a[a] += 1\n        cnt_b[b] += 1\n    \n    total = n * (n-1) * (n-2) // 6\n    \n    # Count bad triples\n    # Group by topic\n    by_topic = defaultdict(list)\n    for a, b in problems:\n        by_topic[a].append(b)\n    \n    bad = 0\n    for a, bs in by_topic.items():\n        m = len(bs)\n        if m >= 3:\n            # All triples within same topic: need same difficulty pair too\n            # Count triples within bs where at least two b's are same\n            # But all problems distinct, so no two have same (a,b), so all b's in bs are distinct\n            # So no same-difficulty pair within all-same-topic triple\n            pass\n        # For each pair in bs, count k with b_k in {bi, bj}\n        for i in range(len(bs)):\n            for j in range(i+1, len(bs)):\n                bi, bj = bs[i], bs[j]\n                bad += (cnt_b[bi] - 1) + (cnt_b[bj] - 1)\n    \n    # Each bad triple counted once per same-topic pair it contains\n    # Since within same topic all b's distinct, a triple can't have all 3 same topic with a same-difficulty pair\n    # Actually if all 3 same topic, b's all distinct, so no same-difficulty pair -> not bad\n    # So bad triples have exactly one same-topic pair -> counted exactly once... wait no\n    # A triple could have two different same-topic pairs if two pairs share topics differently\n    # e.g., p1,p2 same topic AND p1,p3 same topic -> all three same topic\n    # but then no same-difficulty pair (since b's distinct within topic)\n    # So bad triples have exactly one same-topic pair. Good, no division needed.\n    \n    print(total - bad)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
