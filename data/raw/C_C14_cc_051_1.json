      "final_code": "import sys\nfrom math import gcd\n\ninput = sys.stdin.readline\n\ndef solve():\n    n = int(input())\n    a = list(map(int, input().split()))\n    \n    if n == 1:\n        print(1)\n        return\n    \n    d = [abs(a[i+1] - a[i]) for i in range(n-1)]\n    \n    # Find longest subarray of d with gcd >= 2\n    # groups: list of (gcd_value, start_index), deduplicated\n    best = 0  # length of longest subarray in d with gcd >= 2\n    \n    groups = []  # (gcd, start)\n    \n    for i, val in enumerate(d):\n        new_groups = []\n        for g, s in groups:\n            ng = gcd(g, val)\n            if not new_groups or new_groups[-1][0] != ng:\n                new_groups.append((ng, s))\n            # keep earliest start for same gcd\n        \n        # Add current element alone\n        if not new_groups or new_groups[-1][0] != val:\n            new_groups.append((val, i))\n        \n        groups = new_groups\n        \n        # Find best: earliest start with gcd >= 2\n        for g, s in groups:\n            if g >= 2:\n                best = max(best, i - s + 1)\n                break  # earliest start gives longest\n    \n    print(best + 1)\n\nt = int(input())\nfor _ in range(t):\n    solve()",
